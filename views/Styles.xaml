  <Color  x:Key="WarnAmberLightColor">#FBBF24</Color>
  <Color  x:Key="WarnAmberLighterColor">#FCD34D</Color>
  <Color  x:Key="WarnAmberSubtleColor">#FDE68A</Color>
  <Color  x:Key="WarnBannerBgDarkColor">#92400E</Color>
  <Color  x:Key="WarnBannerBgDeepColor">#451A03</Color>
  <SolidColorBrush x:Key="WarnAmberBrush"         Color="{StaticResource WarnAmberColor}"/>
  <SolidColorBrush x:Key="WarnAmberLightBrush"     Color="{StaticResource WarnAmberLightColor}"/>
