<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════════════════
       SMDWin — Modern UI v2  |  Windows 7 / 8 / 10 / 11 compatible
       Design: Clean flat, refined cards, sharp typography, no Mica/blur
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- TYPOGRAPHY -->
  <FontFamily x:Key="AppFont">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
  <FontFamily x:Key="AppFontDisplay">Segoe UI Variable Display, Segoe UI Semibold, Segoe UI, sans-serif</FontFamily>
  <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Courier New</FontFamily>

  <!-- GLOBAL: kill dotted focus rectangles on common controls -->
  <Style x:Key="NoFocusVisual">
    <Setter Property="Control.FocusVisualStyle" Value="{x:Null}"/>
  </Style>
  <Style TargetType="Window">
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
  </Style>
  <Style TargetType="Grid">
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
  </Style>
  <Style TargetType="StackPanel">
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
  </Style>

  <!-- EASING FUNCTIONS — defined first so StaticResource can find them anywhere -->
  <QuinticEase x:Key="EaseOut" EasingMode="EaseOut"/>
  <QuadraticEase x:Key="EaseIn" EasingMode="EaseIn"/>

  <!-- DEFAULT COLOR TOKENS (Dark theme — overridden by ThemeManager) -->
  <Color x:Key="BgDarkColor">#111418</Color>
  <Color x:Key="BgCardColor">#1C2128</Color>
  <Color x:Key="BgHoverColor">#252D3A</Color>
  <Color x:Key="SidebarHoverColor">#1E2A3D</Color>
  <Color x:Key="AccentColor">#3B82F6</Color>
  <Color x:Key="TextPrimaryColor">#EEF2F7</Color>
  <Color x:Key="TextSecondaryColor">#7A94B8</Color>
  <Color x:Key="BorderColor">#2A3345</Color>
  <Color x:Key="CardBorderColor">#232D3F</Color>
  <Color x:Key="SidebarColor">#0E1420</Color>

  <Color x:Key="NavActiveColor">#1A2D4F</Color>
  <Color x:Key="NavAccentBarColor">#3B82F6</Color>
  <Color x:Key="NavActiveFgColor">#60A5FA</Color>
  <Color x:Key="NavCatFgColor">#3A5A8A</Color>
  <Color x:Key="SidebarTextColor">#7A94B8</Color>
  <Color x:Key="SidebarTextPrimaryColor">#EEF2F7</Color>
  <Color x:Key="ChartGreenColor">#22C55E</Color>
  <Color x:Key="ActionGreenColor">#16A34A</Color>
  <Color x:Key="ActionRedColor">#DC2626</Color>
  <Color x:Key="RowSeparatorColor">#1F2D42</Color>
  <Color x:Key="RowAltColor">#111620</Color>
  <Color x:Key="PrimaryButtonFgColor">#FFFFFF</Color>
  <Color x:Key="RowHoverColor">#1E2840</Color>
  <Color x:Key="TableHeaderBgColor">#0D1422</Color>
  <Color x:Key="ThrottleBannerBgColor">#7F1D1D</Color>
  <Color x:Key="ThrottleBannerBorderColor">#EF4444</Color>
  <Color x:Key="ThrottleBannerFgColor">#FCA5A5</Color>

  <!-- BRUSHES -->
  <SolidColorBrush x:Key="BgDarkBrush"             Color="{DynamicResource BgDarkColor}"/>
  <!-- Alias for dialog/panel background - same as BgCard -->
  <SolidColorBrush x:Key="BgPanelBrush"            Color="{DynamicResource BgCardColor}"/>
  <SolidColorBrush x:Key="BgCardBrush"             Color="{DynamicResource BgCardColor}"/>
  <SolidColorBrush x:Key="BgHoverBrush"            Color="{DynamicResource BgHoverColor}"/>
  <SolidColorBrush x:Key="BgInputBrush"            Color="{DynamicResource BgInputColor}"/>
  <SolidColorBrush x:Key="SidebarHoverBrush"       Color="{DynamicResource SidebarHoverColor}"/>
  <SolidColorBrush x:Key="AccentBrush"             Color="{DynamicResource AccentColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush"        Color="{DynamicResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush"      Color="{DynamicResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="BorderBrush2"            Color="{DynamicResource BorderColor}"/>
  <SolidColorBrush x:Key="CardBorderBrush"         Color="{DynamicResource CardBorderColor}"/>
  <SolidColorBrush x:Key="GridLineBrush"           Color="{DynamicResource BorderColor}" Opacity="0.4"/>
  <SolidColorBrush x:Key="NavCatFgBrush"           Color="{DynamicResource NavCatFgColor}"/>
  <SolidColorBrush x:Key="SidebarBrush"            Color="{DynamicResource SidebarColor}"/>
  <SolidColorBrush x:Key="NavActiveBrush"          Color="{DynamicResource NavActiveColor}"/>
  <SolidColorBrush x:Key="NavAccentBarBrush"       Color="{DynamicResource NavAccentBarColor}"/>
  <SolidColorBrush x:Key="NavActiveFgBrush"        Color="{DynamicResource NavActiveFgColor}"/>
  <SolidColorBrush x:Key="SidebarTextBrush"        Color="{DynamicResource SidebarTextColor}"/>
  <SolidColorBrush x:Key="SidebarTextPrimaryBrush" Color="{DynamicResource SidebarTextPrimaryColor}"/>
  <SolidColorBrush x:Key="ChartGreenBrush"         Color="{DynamicResource ChartGreenColor}"/>
  <SolidColorBrush x:Key="ActionGreenBrush"        Color="{DynamicResource ActionGreenColor}"/>
  <SolidColorBrush x:Key="ActionRedBrush"          Color="{DynamicResource ActionRedColor}"/>
  <SolidColorBrush x:Key="RowSeparatorBrush"       Color="{DynamicResource RowSeparatorColor}"/>
  <SolidColorBrush x:Key="RowAltBrush"             Color="{DynamicResource RowAltColor}"/>
  <SolidColorBrush x:Key="PrimaryButtonFgBrush"    Color="{DynamicResource PrimaryButtonFgColor}"/>
  <SolidColorBrush x:Key="RowHoverBrush"           Color="{DynamicResource RowHoverColor}"/>
  <SolidColorBrush x:Key="TableHeaderBgBrush"      Color="{DynamicResource TableHeaderBgColor}"/>
  <SolidColorBrush x:Key="ThrottleBannerBgBrush"     Color="{DynamicResource ThrottleBannerBgColor}"/>
  <SolidColorBrush x:Key="ThrottleBannerBorderBrush" Color="{DynamicResource ThrottleBannerBorderColor}"/>
  <SolidColorBrush x:Key="ThrottleBannerFgBrush"     Color="{DynamicResource ThrottleBannerFgColor}"/>
  <SolidColorBrush x:Key="RowSelectBrush"          Color="{DynamicResource AccentColor}" Opacity="0.165"/>

  <!-- Semantic fixed -->
  <Color  x:Key="GpuAccentColor">#A855F7</Color>
  <SolidColorBrush x:Key="GpuAccentBrush"  Color="{StaticResource GpuAccentColor}"/>
  <SolidColorBrush x:Key="GreenBrush"  Color="#16A34A"/>
  <SolidColorBrush x:Key="YellowBrush" Color="#D97706"/>
  <SolidColorBrush x:Key="RedBrush"    Color="#EF4444"/>
  <SolidColorBrush x:Key="OrangeBrush" Color="#F97316"/>

  <!-- Status -->
  <SolidColorBrush x:Key="StatusOkBrush"     Color="#22C55E"/>
  <SolidColorBrush x:Key="StatusWarnBrush"   Color="#F59E0B"/>
  <SolidColorBrush x:Key="StatusCritBrush"   Color="#EF4444"/>
  <SolidColorBrush x:Key="StatusInfoBrush"   Color="{DynamicResource AccentColor}"/>
  <SolidColorBrush x:Key="StatusNaBrush"     Color="#4B5563"/>
  <SolidColorBrush x:Key="StatusOkBgBrush"   Color="#14532D"/>
  <SolidColorBrush x:Key="StatusWarnBgBrush" Color="#451A03"/>
  <SolidColorBrush x:Key="StatusCritBgBrush" Color="#450A0A"/>
  <SolidColorBrush x:Key="StatusInfoBgBrush" Color="#1E3A5F"/>

  <!-- Status aliases (ThemeManager sets these dynamically; static fallbacks here) -->
  <SolidColorBrush x:Key="StatusSuccessBrush" Color="#22C55E"/>
  <SolidColorBrush x:Key="StatusErrorBrush"   Color="#EF4444"/>
  <SolidColorBrush x:Key="StatusErrorBgBrush" Color="#7F1D1D"/>
  <SolidColorBrush x:Key="StatusWarningBrush" Color="#F59E0B"/>

  <!-- Chart palette — semantic, theme-aware via ThemeManager -->
  <Color  x:Key="ChartGreenDimColor">#16A34A</Color>
  <SolidColorBrush x:Key="ChartGreenDimBrush"   Color="{DynamicResource ChartGreenDimColor}"/>
  <Color  x:Key="ChartGreenDark2Color">#15803D</Color>
  <SolidColorBrush x:Key="ChartGreenDark2Brush"  Color="{DynamicResource ChartGreenDark2Color}"/>
  <Color  x:Key="ChartOrangeColor">#F97316</Color>
  <SolidColorBrush x:Key="ChartOrangeBrush"      Color="{DynamicResource ChartOrangeColor}"/>
  <Color  x:Key="ChartAmberColor">#F59E0B</Color>
  <SolidColorBrush x:Key="ChartAmberBrush"       Color="{DynamicResource ChartAmberColor}"/>

  <!-- Cyan accent — used for RAM latency bars and similar hardware charts -->
  <Color  x:Key="CyanAccentColor">#38BDF8</Color>
  <SolidColorBrush x:Key="CyanAccentBrush"       Color="{DynamicResource CyanAccentColor}"/>
  <Color  x:Key="CyanAccentDimColor">#60AFFF</Color>
  <SolidColorBrush x:Key="CyanAccentDimBrush"    Color="{DynamicResource CyanAccentDimColor}"/>
  <Color  x:Key="RamCyanColor">#0E7490</Color>
  <SolidColorBrush x:Key="RamCyanBrush"          Color="{DynamicResource RamCyanColor}"/>

  <!-- Purple accent — pinned process / GPU secondary channel -->
  <Color  x:Key="PurpleAccentColor">#8B5CF6</Color>
  <SolidColorBrush x:Key="PurpleAccentBrush"     Color="{DynamicResource PurpleAccentColor}"/>

  <!-- Win accent blue (fixed Windows blue, not user accent) -->
  <Color  x:Key="WinBlueColor">#0078D4</Color>
  <SolidColorBrush x:Key="WinBlueBrush"          Color="{DynamicResource WinBlueColor}"/>

  <!-- SHARED EFFECTS -->
  <DropShadowEffect x:Key="SubtleShadow"     x:Shared="False" BlurRadius="8"  ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.18" RenderingBias="Performance"/>
  <DropShadowEffect x:Key="CardShadow"       x:Shared="False" BlurRadius="16" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.26" RenderingBias="Performance"/>
  <DropShadowEffect x:Key="CardHoverShadow"  x:Shared="False" BlurRadius="24" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.34" RenderingBias="Performance"/>
  <DropShadowEffect x:Key="AccentGlowShadow" x:Shared="False" BlurRadius="14" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.30" RenderingBias="Performance"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       GLOBAL BASE STYLES — font + background on every control type
       These MUST live here (not in App.xaml) to avoid overriding themed styles.
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- TextBlock — font + rendering -->
  <Style TargetType="TextBlock">
    <Setter Property="FontFamily"                        Value="{StaticResource AppFont}"/>
    <Setter Property="TextOptions.TextFormattingMode"    Value="Display"/>
    <Setter Property="TextOptions.TextRenderingMode"     Value="ClearType"/>
  </Style>

  <!-- TextBox — font (full style defined lower, this ensures no override) -->

  <!-- Button — base font (actual styles defined as named keys below) -->
  <Style TargetType="Button">
    <Setter Property="FontFamily"       Value="{StaticResource AppFont}"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
  </Style>

  <!-- ListBox — themed background/border, no system chrome -->
  <Style TargetType="ListBox">
    <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
    <Setter Property="Background"      Value="{DynamicResource BgCardBrush}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush2}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="2"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBox">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8" Padding="{TemplateBinding Padding}">
            <ScrollViewer Focusable="False">
              <ItemsPresenter/>
            </ScrollViewer>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ListBoxItem — themed hover/select -->
  <Style TargetType="ListBoxItem">
    <Setter Property="Background"       Value="Transparent"/>
    <Setter Property="Foreground"       Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="Padding"          Value="10,7"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border x:Name="Bd" Background="{TemplateBinding Background}"
                  CornerRadius="6" Margin="2,1"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
              <Setter Property="Foreground" Value="White"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ItemsControl — transparent background, themed font -->
  <Style TargetType="ItemsControl">
    <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <!-- GroupBox — themed -->
  <Style TargetType="GroupBox">
    <Setter Property="Background"      Value="{DynamicResource BgCardBrush}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush2}"/>
    <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
    <Setter Property="FontSize"        Value="12"/>
  </Style>

  <!-- Expander — themed -->
  <Style TargetType="Expander">
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
    <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
    <Setter Property="FontSize"    Value="12"/>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════════════════
       UNIFIED CARD SYSTEM
       BaseCardStyle      — single source of truth: BgCard bg, CardBorder, radius 12, shadow
       CardStyle          — alias for BaseCardStyle (legacy compatibility)
       DashCardStyle      — dashboard metric card (BasedOn BaseCardStyle)
       DashClickCardStyle — clickable dashboard card (BasedOn DashCardStyle, Cursor=Hand)
       SpecCardStyle      — static info card (BasedOn BaseCardStyle)
       ═══════════════════════════════════════════════════════════════════════ -->

  <Style x:Key="BaseCardStyle" TargetType="Border">
    <Setter Property="Background"      Value="{DynamicResource BgCardBrush}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource CardBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="12"/>
    <Setter Property="Padding"         Value="14,12"/>
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect BlurRadius="14" ShadowDepth="2" Direction="270"
                          Color="#000000" Opacity="0.13" RenderingBias="Performance"/>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Effect">
          <Setter.Value>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Direction="270"
                              Color="{DynamicResource AccentColor}" Opacity="0.28" RenderingBias="Performance"/>
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Legacy aliases — all existing XAML continues to work without changes -->
  <Style x:Key="CardStyle"          TargetType="Border" BasedOn="{StaticResource BaseCardStyle}"/>
  <Style x:Key="DashCardStyle"      TargetType="Border" BasedOn="{StaticResource BaseCardStyle}"/>
  <Style x:Key="DashClickCardStyle" TargetType="Border" BasedOn="{StaticResource DashCardStyle}">
    <Setter Property="Cursor"           Value="Hand"/>
    <Setter Property="Padding"          Value="0"/>
    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    <Setter Property="RenderTransform">
      <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
    </Setter>
    <Style.Triggers>
      <EventTrigger RoutedEvent="MouseEnter">
        <BeginStoryboard>
          <Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             To="1.012" Duration="0:0:0.12" EasingFunction="{StaticResource EaseOut}"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             To="1.012" Duration="0:0:0.12" EasingFunction="{StaticResource EaseOut}"/>
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
      <EventTrigger RoutedEvent="MouseLeave">
        <BeginStoryboard>
          <Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             To="1" Duration="0:0:0.15" EasingFunction="{StaticResource EaseOut}"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             To="1" Duration="0:0:0.15" EasingFunction="{StaticResource EaseOut}"/>
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="SpecCardStyle" TargetType="Border" BasedOn="{StaticResource BaseCardStyle}">
    <Setter Property="Padding" Value="0"/>
  </Style>

  <!-- NAV BUTTON -->
  <Style x:Key="NavButtonStyle" TargetType="Button">
    <Setter Property="Background"                 Value="Transparent"/>
    <Setter Property="Foreground"                 Value="{DynamicResource SidebarTextBrush}"/>
    <Setter Property="BorderThickness"            Value="0"/>
    <Setter Property="Padding"                    Value="9,8"/>
    <Setter Property="FontSize"                   Value="12"/>
    <Setter Property="FontFamily"                 Value="{StaticResource AppFont}"/>
    <Setter Property="Cursor"                     Value="Hand"/>
    <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Margin="6,0,6,0">
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
            </Border>
            <!-- Accent underline: bottom of button, inset 16px — no corner issues -->
            <Border x:Name="AccentBar" Height="2" VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch" Margin="16,0,16,2"
                    Background="{DynamicResource NavAccentBarBrush}"
                    CornerRadius="1" Opacity="0"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd"        Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
              <Setter Property="Foreground"  Value="{DynamicResource SidebarTextPrimaryBrush}"/>
              <Setter TargetName="AccentBar" Property="Opacity"    Value="0.35"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
    <Setter Property="Background"       Value="{DynamicResource NavActiveBrush}"/>
    <Setter Property="Foreground"       Value="{DynamicResource NavActiveFgBrush}"/>
    <Setter Property="FontWeight"       Value="SemiBold"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <Border x:Name="BdTint" Background="{DynamicResource NavActiveBrush}" CornerRadius="6" Margin="6,0,6,0"/>
            <Border x:Name="BdContent" Background="Transparent" CornerRadius="6" Margin="6,0,6,0">
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
            </Border>
            <!-- Accent underline — always visible on active item -->
            <Border Height="2" VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch" Margin="16,0,16,2"
                    Background="{DynamicResource NavAccentBarBrush}"
                    CornerRadius="1"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="BdTint" Property="Opacity" Value="0.80"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- UIAccentBrush — fixed blue for buttons/borders, independent of user accent color.
       AccentBrush follows user accent setting; UIAccentBrush is always the design blue. -->
  <Color  x:Key="UIAccentColor">#3B82F6</Color>
  <SolidColorBrush x:Key="UIAccentBrush" Color="#3B82F6"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       UNIFIED BUTTON SYSTEM  —  3 variante canonice
       ───────────────────────────────────────────────────────────────────────
       PrimaryButtonStyle   — fill accent bg, white text  (Run, Start, Save)
       SecondaryButtonStyle — underline accent jos, sidebar-style (toate celelalte)
       GhostButtonStyle     — text only, fără linie (acțiuni minore)
       ───────────────────────────────────────────────────────────────────────
       AppButtonStyle / OutlineButtonStyle / SmallButtonStyle / etc.
       → toate rămân ca aliasuri pentru compatibilitate XAML fără modificări.
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- BASE — template comun pentru PrimaryButtonStyle -->
  <Style x:Key="BaseButtonStyle" TargetType="Button">
    <Setter Property="FontSize"            Value="12"/>
    <Setter Property="FontWeight"          Value="SemiBold"/>
    <Setter Property="Cursor"             Value="Hand"/>
    <Setter Property="MinHeight"           Value="32"/>
    <Setter Property="Height"             Value="Auto"/>
    <Setter Property="Padding"            Value="12,0"/>
    <Setter Property="BorderThickness"    Value="0"/>
    <Setter Property="FocusVisualStyle"   Value="{x:Null}"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="UseLayoutRounding"   Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderThickness="0"
                  CornerRadius="8" Padding="{TemplateBinding Padding}"
                  UseLayoutRounding="True" SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              RecognizesAccessKey="True"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Opacity" Value="0.70"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ① PRIMARY — accent fill, white text (Run Benchmark, Start Scan, Save) -->
  <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
    <Setter Property="Background"  Value="{DynamicResource AccentBrush}"/>
    <Setter Property="Foreground"  Value="{DynamicResource PrimaryButtonFgBrush}"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ② SECONDARY — sidebar underline style: linie accent jos, hover subtil -->
  <Style x:Key="SecondaryButtonStyle" TargetType="Button">
    <Setter Property="FontSize"            Value="12"/>
    <Setter Property="FontWeight"          Value="SemiBold"/>
    <Setter Property="Cursor"             Value="Hand"/>
    <Setter Property="MinHeight"           Value="32"/>
    <Setter Property="Height"             Value="Auto"/>
    <Setter Property="Padding"            Value="12,6"/>
    <Setter Property="BorderThickness"    Value="0"/>
    <Setter Property="Background"         Value="Transparent"/>
    <Setter Property="Foreground"         Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FocusVisualStyle"   Value="{x:Null}"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="UseLayoutRounding"   Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
            <!-- Hover/press background -->
            <Border x:Name="BdBg" Background="Transparent" CornerRadius="6"/>
            <!-- Content -->
            <Border x:Name="BdContent" Background="Transparent"
                    Padding="{TemplateBinding Padding}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <!-- Accent underline — linie jos, culoarea temei, ca în sidebar -->
            <Border x:Name="AccentLine"
                    Height="2" VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="8,0,8,0"
                    CornerRadius="1"
                    Background="{DynamicResource AccentBrush}"
                    Opacity="0.55"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="BdBg"      Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter TargetName="AccentLine" Property="Opacity"   Value="1.0"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="BdBg"      Property="Opacity"    Value="0.6"/>
              <Setter TargetName="AccentLine" Property="Opacity"   Value="1.0"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="BdContent"  Property="Opacity"   Value="0.4"/>
              <Setter TargetName="AccentLine" Property="Opacity"   Value="0.2"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ③ GHOST — text only, fără linie (acțiuni minore: Open folder, Copy path) -->
  <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="Foreground"  Value="{DynamicResource TextSecondaryBrush}"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ───────────────────────────────────────────────────────────────────────
       LEGACY ALIASES — păstrate pentru compatibilitate, fără a modifica XAML
       Toate pointează la SecondaryButtonStyle (underline) sau variante proprii.
       ─────────────────────────────────────────────────────────────────────── -->

  <!-- Secondary aliases — toți cu underline accent -->
  <Style x:Key="AppButtonStyle"     TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}"/>
  <Style x:Key="OutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}"/>
  <Style x:Key="ToggleButtonStyle"  TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
    <Setter Property="MinWidth" Value="110"/>
  </Style>
  <Style x:Key="NetToolButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
    <Setter Property="MinWidth" Value="100"/>
  </Style>
  <Style x:Key="TabButtonStyle"     TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
    <Setter Property="MinWidth" Value="80"/>
  </Style>
  <Style x:Key="SmallButtonStyle"   TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
    <Setter Property="Padding"  Value="10,4"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="MinHeight" Value="28"/>
  </Style>

  <!-- Primary aliases (accent fill) -->
  <Style x:Key="SaveButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
    <Setter Property="MinWidth" Value="140"/>
  </Style>

  <!-- Green / Red — underline în culoarea acțiunii, nu accent temă -->
  <Style x:Key="GreenButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
    <Setter Property="Foreground" Value="{DynamicResource ActionGreenBrush}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border x:Name="BdBg" Background="Transparent" CornerRadius="6"/>
            <Border Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <Border x:Name="AccentLine" Height="2" VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch" Margin="8,0,8,0" CornerRadius="1"
                    Background="{DynamicResource ActionGreenBrush}" Opacity="0.6"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="BdBg"       Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter TargetName="AccentLine"  Property="Opacity"   Value="1.0"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="BdBg"       Property="Opacity"   Value="0.6"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="AccentLine" Property="Opacity"   Value="0.2"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="RedButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
    <Setter Property="Foreground" Value="{DynamicResource ActionRedBrush}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border x:Name="BdBg" Background="Transparent" CornerRadius="6"/>
            <Border Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <Border x:Name="AccentLine" Height="2" VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch" Margin="8,0,8,0" CornerRadius="1"
                    Background="{DynamicResource ActionRedBrush}" Opacity="0.6"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="BdBg"       Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter TargetName="AccentLine"  Property="Opacity"   Value="1.0"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="BdBg"       Property="Opacity"   Value="0.6"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="AccentLine" Property="Opacity"   Value="0.2"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="ActionGreenStyle" TargetType="Button" BasedOn="{StaticResource GreenButtonStyle}"/>
  <Style x:Key="ActionRedStyle"   TargetType="Button" BasedOn="{StaticResource RedButtonStyle}"/>

  <!-- SECTION TITLE -->
  <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="18"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="FontFamily" Value="{StaticResource AppFontDisplay}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="Margin"     Value="0,0,0,14"/>
  </Style>

  <!-- DATAGRID -->
  <Style TargetType="DataGrid">
    <Setter Property="Background"               Value="{DynamicResource BgCardBrush}"/>
    <Setter Property="Foreground"               Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderThickness"          Value="0"/>
    <Setter Property="GridLinesVisibility"      Value="None"/>
    <Setter Property="RowBackground"            Value="Transparent"/>
    <Setter Property="AlternatingRowBackground" Value="{DynamicResource RowAltBrush}"/>
    <Setter Property="FontSize"                 Value="13"/>
    <Setter Property="ColumnHeaderHeight"       Value="30"/>
    <Setter Property="RowHeight"                Value="30"/>
    <Setter Property="SelectionMode"            Value="Single"/>
    <Setter Property="RowHeaderWidth"           Value="0"/>
    <Setter Property="HeadersVisibility"        Value="Column"/>
    <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
    <Setter Property="ScrollViewer.PanningMode"      Value="VerticalFirst"/>
    <!-- Fix: DataGridTextColumn internal TextBlock ignores DataGridCell.Foreground.
         Injecting an implicit TextBlock style via DataGrid.Resources fixes all text columns. -->
    <Style.Resources>
      <!-- Override TextBlock foreground inside DataGrid cells (fixes DataGridTextColumn text color) -->
      <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
      </Style>
    </Style.Resources>
  </Style>

  <!-- Named style for DataGridTextColumn ElementStyle -->
  <Style x:Key="DataGridCellTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground"       Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
  </Style>

  <!-- DATAGRID COLUMN HEADER -->
  <Style TargetType="DataGridColumnHeader">
    <Setter Property="Background"      Value="{DynamicResource TableHeaderBgBrush}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="FontSize"        Value="10"/>
    <Setter Property="FontWeight"      Value="SemiBold"/>
    <Setter Property="Padding"         Value="10,0"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource CardBorderBrush}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="DataGridColumnHeader">
          <Grid>
            <Border x:Name="HdrBd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
              <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True"/>
            </Border>
            <Path x:Name="SortArrow" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Center"
                  Margin="0,0,6,0" Fill="{DynamicResource AccentBrush}" Data="M 0 4 L 4 0 L 8 4 Z"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="HdrBd" Property="Opacity" Value="0.82"/></Trigger>
            <Trigger Property="SortDirection" Value="Ascending">
              <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
              <Setter TargetName="SortArrow" Property="RenderTransform"><Setter.Value><RotateTransform Angle="0"/></Setter.Value></Setter>
            </Trigger>
            <Trigger Property="SortDirection" Value="Descending">
              <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
              <Setter TargetName="SortArrow" Property="RenderTransform"><Setter.Value><RotateTransform Angle="180" CenterX="4" CenterY="2"/></Setter.Value></Setter>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- DATAGRID CELL -->
  <Style TargetType="DataGridCell">
    <Setter Property="BorderThickness"  Value="0"/>
    <Setter Property="Padding"          Value="10,2"/>
    <Setter Property="Foreground"       Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="Background"       Value="Transparent"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="DataGridCell">
          <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderThickness="0" SnapsToDevicePixels="True">
            <ContentPresenter VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- DATAGRID ROW -->
  <Style TargetType="DataGridRow">
    <Setter Property="Background"       Value="Transparent"/>
    <Setter Property="Foreground"       Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderThickness"  Value="0,0,0,1"/>
    <Setter Property="BorderBrush"      Value="{DynamicResource RowSeparatorBrush}"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="DataGridRow">
          <Border x:Name="DGR_Border" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
            <Grid>
              <Border x:Name="AccentBar" Width="3" HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}" Opacity="0"/>
              <SelectiveScrollingGrid>
                <SelectiveScrollingGrid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </SelectiveScrollingGrid.ColumnDefinitions>
                <SelectiveScrollingGrid.RowDefinitions>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </SelectiveScrollingGrid.RowDefinitions>
                <DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                <DataGridDetailsPresenter Grid.Column="1" Grid.Row="1"
                                          SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                          Visibility="{TemplateBinding DetailsVisibility}"/>
                <DataGridRowHeader Grid.RowSpan="2" SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical"
                                   Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Row}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"/>
              </SelectiveScrollingGrid>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation Storyboard.TargetName="AccentBar" Storyboard.TargetProperty="Opacity"
                                   To="0.55" Duration="0:0:0.12"/>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation Storyboard.TargetName="AccentBar" Storyboard.TargetProperty="Opacity"
                                   To="0" Duration="0:0:0.15"/>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="DGR_Border" Property="Background" Value="{DynamicResource RowHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="DGR_Border" Property="Background" Value="{DynamicResource RowSelectBrush}"/>
              <Setter TargetName="AccentBar"  Property="Opacity"    Value="1"/>
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsSelected"  Value="True"/>
                <Condition Property="IsMouseOver" Value="True"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="DGR_Border" Property="Opacity" Value="0.9"/>
            </MultiTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- TEXTBOX -->
  <Style TargetType="TextBox">
    <Setter Property="Background"      Value="{DynamicResource BgInputBrush}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush2}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="9,6"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="CaretBrush"      Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="SelectionBrush"  Value="{DynamicResource AccentBrush}"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsFocused" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource BgCardBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- COMBOBOX -->
  <Style TargetType="ComboBox">
    <Setter Property="Background"      Value="{DynamicResource BgInputBrush}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush2}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="9,6"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                          Padding="{TemplateBinding Padding}"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
              <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                  <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="22"/>
                      </Grid.ColumnDefinitions>
                      <ContentPresenter Grid.Column="0" VerticalAlignment="Center" TextElement.Foreground="{DynamicResource TextPrimaryBrush}"/>
                      <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="{TemplateBinding Foreground}"
                            VerticalAlignment="Center" HorizontalAlignment="Center" Width="8" Height="4"/>
                    </Grid>
                  </Border>
                </ControlTemplate>
              </ToggleButton.Template>
            </ToggleButton>
            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                              Margin="9,6,26,6" VerticalAlignment="Center" HorizontalAlignment="Left"
                              TextElement.Foreground="{DynamicResource TextPrimaryBrush}"/>
            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
              <Grid x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}"
                    MaxHeight="{TemplateBinding MaxDropDownHeight}" SnapsToDevicePixels="True">
                <Border x:Name="DropDownBorder" Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="7" ClipToBounds="True">
                  <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Direction="270" Color="#000000" Opacity="0.28" RenderingBias="Performance"/>
                  </Border.Effect>
                  <ScrollViewer Margin="4,4,4,4" SnapsToDevicePixels="True">
                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                  </ScrollViewer>
                </Border>
              </Grid>
            </Popup>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ComboBoxItem">
    <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="Padding"    Value="9,5"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5" Margin="3,1" Padding="{TemplateBinding Padding}">
            <ContentPresenter VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/></Trigger>
            <Trigger Property="IsSelected"  Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
              <Setter Property="Foreground" Value="White"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- OTHER CONTROLS -->
  <Style TargetType="DatePicker">
    <Setter Property="Background"  Value="{DynamicResource BgInputBrush}"/>
    <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
    <Setter Property="FontSize"    Value="12"/>
  </Style>
  <Style TargetType="Slider">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
  </Style>
  <Style TargetType="Label">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontSize"   Value="12"/>
  </Style>

  <!-- SCROLLBAR — slim 5px -->
  <Style TargetType="ScrollBar">
    <Setter Property="Width"    Value="5"/>
    <Setter Property="MinWidth" Value="5"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid Background="Transparent" Width="5">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="ScrollBar.LineUpCommand"   Opacity="0" Width="0" Height="0" Focusable="False"/>
              </Track.DecreaseRepeatButton>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" Width="0" Height="0" Focusable="False"/>
              </Track.IncreaseRepeatButton>
              <Track.Thumb>
                <Thumb>
                  <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                      <Border CornerRadius="3" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.32" Margin="1,2"/>
                    </ControlTemplate>
                  </Thumb.Template>
                </Thumb>
              </Track.Thumb>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="ScrollViewer">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
  </Style>

  <!-- THEME SWATCH / CARD -->
  <Style x:Key="ThemeSwatchStyle" TargetType="Button" BasedOn="{StaticResource OutlineButtonStyle}">
    <Setter Property="Height"   Value="34"/>
    <Setter Property="Padding"  Value="12,6"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style x:Key="ThemeCardButtonStyle" TargetType="Button">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="0"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Outer" CornerRadius="12" BorderBrush="Transparent" BorderThickness="2" Background="Transparent">
            <Border x:Name="Inner" Background="{TemplateBinding Background}" CornerRadius="10" ClipToBounds="True">
              <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </Border>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="Inner" Property="Opacity"     Value="0.9"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Inner" Property="Opacity" Value="0.75"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- CHECKBOX -->
  <Style TargetType="CheckBox">
    <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontSize"    Value="13"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Cursor"      Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="24"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="CheckBd" Width="18" Height="18" CornerRadius="5"
                    Background="Transparent" BorderBrush="{DynamicResource BorderBrush2}"
                    BorderThickness="1.5" VerticalAlignment="Center">
              <Path x:Name="CheckMark" Data="M 3 9 L 7 13 L 15 5" Stroke="White" StrokeThickness="2"
                    StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                    Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ContentPresenter Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="CheckBd"   Property="Background"  Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="CheckBd"   Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="CheckMark" Property="Visibility"  Value="Visible"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="CheckBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="CheckBd" Property="Opacity" Value="0.4"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- RADIOBUTTON -->
  <Style TargetType="RadioButton">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontSize"   Value="13"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Cursor"     Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="26"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="RadioBd" Width="18" Height="18" CornerRadius="9"
                    Background="Transparent" BorderBrush="{DynamicResource BorderBrush2}"
                    BorderThickness="1.5" VerticalAlignment="Center">
              <Ellipse x:Name="RadioDot" Width="8" Height="8" Fill="{DynamicResource AccentBrush}"
                       Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ContentPresenter Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="RadioBd"  Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="RadioDot" Property="Visibility"  Value="Visible"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="RadioBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="RadioBd" Property="Opacity" Value="0.4"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- CHIP STYLES -->
  <!-- UnderlineChipStyle — RadioButton with bottom accent line (like SubTabButtonStyle) -->
  <Style x:Key="UnderlineChipStyle" TargetType="RadioButton">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="FontSize"        Value="11"/>
    <Setter Property="FontWeight"      Value="SemiBold"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Height"          Value="30"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Grid>
            <Border x:Name="BdBg" Background="Transparent" CornerRadius="6"
                    Padding="10,5">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                TextElement.FontSize="11" TextElement.FontWeight="SemiBold"/>
            </Border>
            <Border x:Name="AccentLine" Height="2" VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch" Margin="4,0,4,0" CornerRadius="1"
                    Background="{DynamicResource AccentBrush}" Opacity="0"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter Property="Foreground"                  Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="BdBg"       Property="Background" Value="{DynamicResource NavActiveBrush}"/>
              <Setter TargetName="AccentLine"  Property="Opacity"   Value="1"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="BdBg"       Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter TargetName="AccentLine"  Property="Opacity"   Value="0.4"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DurationChipStyle" TargetType="RadioButton">
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Grid>
            <Border x:Name="BdBg" Background="Transparent" CornerRadius="6"
                    Padding="12,5" Cursor="Hand">
              <TextBlock x:Name="ChipText" Text="{TemplateBinding Content}"
                         FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <!-- Bottom accent line — hidden when unchecked -->
            <Border x:Name="AccentLine" Height="2" VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch" Margin="6,0,6,0" CornerRadius="1"
                    Background="{DynamicResource AccentBrush}" Opacity="0"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="AccentLine" Property="Opacity"   Value="1"/>
              <Setter TargetName="ChipText"   Property="Foreground" Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="BdBg"       Property="Background" Value="{DynamicResource NavActiveBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="BdBg"       Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter TargetName="AccentLine" Property="Opacity"    Value="0.4"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ChipButtonStyle" TargetType="Button">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush2}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="12,6"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="ChipBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}" Cursor="Hand">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.FontSize="12" TextElement.FontWeight="SemiBold"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter Property="Foreground"   Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="ChipBorder" Property="Background"  Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
              <Setter Property="Foreground"   Value="White"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ChipButtonActiveStyle — chip with accent fill (selected state) -->
  <Style x:Key="ChipButtonActiveStyle" TargetType="Button">
    <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
    <Setter Property="Foreground"      Value="White"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="12,6"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="ChipBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}" Cursor="Hand">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.FontSize="12" TextElement.FontWeight="SemiBold"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="ChipBorder" Property="Opacity" Value="0.85"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="ChipBorder" Property="Opacity" Value="0.70"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ANIMATIONS -->
  <Style x:Key="PageFadeStyle" TargetType="FrameworkElement">
    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    <Setter Property="RenderTransform">
      <Setter.Value>
        <TranslateTransform Y="8"/>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <EventTrigger RoutedEvent="Loaded">
        <BeginStoryboard>
          <Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"
                             EasingFunction="{StaticResource EaseOut}"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="8" To="0" Duration="0:0:0.25"
                             EasingFunction="{StaticResource EaseOut}"/>
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
    </Style.Triggers>
  </Style>

  <!-- Fade-in only (for overlays, popups) -->
  <Style x:Key="FadeInStyle" TargetType="FrameworkElement">
    <Style.Triggers>
      <EventTrigger RoutedEvent="Loaded">
        <BeginStoryboard>
          <Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.18"
                             EasingFunction="{StaticResource EaseOut}"/>
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
    </Style.Triggers>
  </Style>

  <!-- ANIMATED PROGRESSBAR -->
  <Style x:Key="AnimatedProgressBarStyle" TargetType="ProgressBar">
    <Setter Property="Height"     Value="5"/>
    <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Border CornerRadius="3" Background="{TemplateBinding Background}" BorderThickness="0" ClipToBounds="True">
            <Border x:Name="PART_Track" CornerRadius="3">
              <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="3">
                <Border.RenderTransform><TranslateTransform x:Name="IndTrans"/></Border.RenderTransform>
              </Border>
            </Border>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsIndeterminate" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="IndTrans" Storyboard.TargetProperty="X"
                                     From="-150" To="300" Duration="0:0:1.2"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- CONTEXT MENU -->
  <Style TargetType="ContextMenu">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="0"/>
    <Setter Property="HasDropShadow"   Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContextMenu">
          <!-- Outer border provides padding so shadow isn't clipped -->
          <Border Padding="10" Background="Transparent">
            <Border x:Name="Bd" Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="4">
              <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.22" RenderingBias="Performance"/>
              </Border.Effect>
              <ItemsPresenter/>
            </Border>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- MENU ITEM -->
  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontSize"   Value="12"/>
    <Setter Property="Padding"    Value="12,7"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="MenuItem">
          <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Margin="2,1" Padding="{TemplateBinding Padding}">
            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/></Trigger>
            <Trigger Property="IsEnabled"     Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- SEPARATOR -->
  <Style TargetType="Separator">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Separator">
          <Border Height="1" Margin="10,3" Background="{DynamicResource BorderBrush2}" Opacity="0.5"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- STATUS BADGES -->
  <Style x:Key="StatusBadgeBase" TargetType="Border">
    <Setter Property="CornerRadius"        Value="4"/>
    <Setter Property="Padding"             Value="6,2"/>
    <Setter Property="HorizontalAlignment" Value="Left"/>
  </Style>
  <Style x:Key="StatusBadgeOk"   BasedOn="{StaticResource StatusBadgeBase}" TargetType="Border">
    <Setter Property="Background"      Value="{StaticResource StatusOkBgBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource StatusOkBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style x:Key="StatusBadgeWarn" BasedOn="{StaticResource StatusBadgeBase}" TargetType="Border">
    <Setter Property="Background"      Value="{StaticResource StatusWarnBgBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource StatusWarnBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style x:Key="StatusBadgeCrit" BasedOn="{StaticResource StatusBadgeBase}" TargetType="Border">
    <Setter Property="Background"      Value="{StaticResource StatusCritBgBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource StatusCritBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- ═══ SUB-TAB PILL BUTTONS ══════════════════════════════════════════════
       Used for Network sub-tabs, Startup toggle, Ping intervals, etc.
       Active state = underline accent + accent text
       Inactive state = transparent, hover → subtle bg
       ═══════════════════════════════════════════════════════════════════════ -->
  <Style x:Key="SubTabButtonStyle" TargetType="Button">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="14,6"/>
    <Setter Property="FontSize"        Value="11"/>
    <Setter Property="FontWeight"      Value="SemiBold"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Height"          Value="32"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    <Setter Property="RenderTransform"><Setter.Value><ScaleTransform/></Setter.Value></Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <Border x:Name="BdBg" Background="Transparent" CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <Border x:Name="AccentLine" Height="2" VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch" Margin="6,0,6,0" CornerRadius="1"
                    Background="{DynamicResource AccentBrush}" Opacity="0"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="BdBg"       Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter TargetName="AccentLine"  Property="Opacity"   Value="0.4"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="BdBg" Property="Opacity" Value="0.7"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SubTabButtonActiveStyle" TargetType="Button">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="{DynamicResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="14,6"/>
    <Setter Property="FontSize"        Value="11"/>
    <Setter Property="FontWeight"      Value="SemiBold"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Height"          Value="32"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <Border x:Name="BdBg" Background="{DynamicResource NavActiveBrush}" CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <Border Height="2" VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch" Margin="6,0,6,0" CornerRadius="1"
                    Background="{DynamicResource AccentBrush}" Opacity="1"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="BdBg" Property="Opacity" Value="0.8"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="BdBg" Property="Opacity" Value="0.6"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ CLOSE / DISMISS ICON BUTTON ════════════════════════════════════════
       Tiny ✕ buttons used to close banners, popups etc.
       ═══════════════════════════════════════════════════════════════════════ -->
  <Style x:Key="CloseIconButtonStyle" TargetType="Button">
    <Setter Property="Background"            Value="Transparent"/>
    <Setter Property="Foreground"            Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="BorderThickness"       Value="0"/>
    <Setter Property="Width"                 Value="22"/>
    <Setter Property="Height"                Value="22"/>
    <Setter Property="Padding"               Value="0"/>
    <Setter Property="FontSize"              Value="11"/>
    <Setter Property="Cursor"                Value="Hand"/>
    <Setter Property="FocusVisualStyle"      Value="{x:Null}"/>
    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    <Setter Property="RenderTransform"><Setter.Value><ScaleTransform/></Setter.Value></Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd" Background="{TemplateBinding Background}"
                  CornerRadius="5" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActionRedBrush}"/>
              <Setter Property="Foreground" Value="White"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>


  <!-- ═══ TOOLTIP — themed, no more white popups ═══════════════════════════ -->
  <Style TargetType="ToolTip">
    <Setter Property="Background"      Value="{DynamicResource BgCardBrush}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush2}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="10,6"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI, sans-serif"/>
    <Setter Property="HasDropShadow"   Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToolTip">
          <!-- Outer transparent padding absorbs the shadow so popup clipping
               doesn't cut into the rounded corners -->
          <Border Padding="8" Background="Transparent">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7"
                    Padding="{TemplateBinding Padding}">
              <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270"
                                  Color="#000000" Opacity="0.28" RenderingBias="Performance"/>
              </Border.Effect>
              <ContentPresenter/>
            </Border>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ DATAGRIDTEXTCOLUMN ELEMENTSTYLE — fixes text color in all DataGrid text cells ══
       WPF DataGridTextColumn does NOT inherit Foreground from DataGridCell.
       This global ElementStyle resource is referenced from App.xaml or
       applied via DataGrid.Resources. Since we cannot set a default
       ElementStyle globally, we expose it as a named resource and apply
       it via DataGrid.Resources in App.xaml.
       ═══════════════════════════════════════════════════════════════════════ -->
  <Style x:Key="DataGridTextCellStyle" TargetType="TextBlock">
    <Setter Property="Foreground"       Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Margin"           Value="0,0,4,0"/>
  </Style>

  <!-- PasswordBox — themed -->
  <Style TargetType="PasswordBox">
    <Setter Property="Background"      Value="{DynamicResource BgInputBrush}"/>
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush2}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="9,6"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI, sans-serif"/>
    <Setter Property="CaretBrush"      Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>




  
  <!-- Extra resources from Assets/Styles.xaml -->
  <SolidColorBrush x:Key="AccentGradientBrush"  Color="{DynamicResource AccentColor}"/>
  <SolidColorBrush x:Key="GreenGradientBrush"   Color="#107C10"/>
  <SolidColorBrush x:Key="RedGradientBrush"     Color="#C42B1C"/>
  <SolidColorBrush x:Key="PurpleGradientBrush"  Color="{DynamicResource AccentColor}"/>
  <SolidColorBrush x:Key="OutlineGradientBrush" Color="Transparent"/>
  <Color  x:Key="ActionPurpleColor">#7C3AED</Color>
  <SolidColorBrush x:Key="ActionPurpleBrush" Color="{StaticResource ActionPurpleColor}"/>
  <Color  x:Key="ToastBgColor">#CC131820</Color>
  <SolidColorBrush x:Key="ToastBgBrush"     Color="{DynamicResource ToastBgColor}"/>
  <SolidColorBrush x:Key="ToastBorderBrush" Color="#44FFFFFF"/>
  <Color  x:Key="WarningBannerBgColor">#EF7C00</Color>
  <SolidColorBrush x:Key="WarningBannerBgBrush" Color="{DynamicResource WarningBannerBgColor}"/>
  <!-- ActionGreenStyle / ActionRedStyle defined as aliases above -->

