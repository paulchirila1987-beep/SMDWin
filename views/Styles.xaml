  <SolidColorBrush x:Key="CritBannerBgDarkBrush" Color="{StaticResource CritBannerBgDarkColor}"/>

  <!-- ═══════════════════════════════════════════════════════════
     SMD Win Icon Pack — DrawingImage resources
     Usage: <Image Source="{StaticResource Icon.nav-dashboard}" Width="16" Height="16"/>
     All icons respond to TextPrimaryBrush (dark/light theme auto)
     ═══════════════════════════════════════════════════════════ -->

  <DrawingImage x:Key="Icon.action-benchmark">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="Transparent" Geometry="M2,20 L7,10 L12,14 L17,6 L22,20">
          <GeometryDrawing.Pen>
            <Pen Brush="{DynamicResource TextPrimaryBrush}" Thickness="1.4" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
          </GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Brush="Transparent" Geometry="M2,20 L22,20">
          <GeometryDrawing.Pen>
            <Pen Brush="{DynamicResource TextPrimaryBrush}" Thickness="1.4" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
          </GeometryDrawing.Pen>
        </GeometryDrawing>
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <DrawingImage x:Key="Icon.action-block">
