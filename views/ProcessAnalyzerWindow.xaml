<Window x:Class="SMDWin.Views.ProcessAnalyzerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Process Analyzer — SMDWin"
        Height="620" Width="980"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDarkBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ResizeMode="CanResize"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SourceInitialized="Window_SourceInitialized">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                        GlassFrameThickness="-1,-1,-1,-1"
                        UseAeroCaptionButtons="True"/>
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <!-- Force dark palette for this window regardless of app theme -->
    <!-- BgDarkBrush inherited from Styles.xaml -->
    <!-- BgCardBrush inherited from Styles.xaml -->
    <!-- BgHoverBrush inherited from Styles.xaml -->
    <!-- TextPrimaryBrush inherited from Styles.xaml -->
    <!-- TextSecondaryBrush inherited from Styles.xaml -->
    <!-- BorderBrush2 inherited from Styles.xaml -->
    <!-- CardBorderBrush inherited from Styles.xaml -->
    <!-- AccentBrush inherited from Styles.xaml -->
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- header -->
      <RowDefinition Height="Auto"/>   <!-- live stat cards -->
      <RowDefinition Height="*"/>      <!-- charts 2x2 -->
      <RowDefinition Height="Auto"/>   <!-- footer -->
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,8">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="📈 " FontSize="18"/>
        <StackPanel>
          <TextBlock x:Name="TxtProcName" Text="Process Analyzer" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="TxtProcSubtitle" Text="PID: —  |  Status: monitoring…" FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
      </StackPanel>
      <!-- Close button top-right -->
      <Button Click="CloseBtn_Click" Width="32" Height="32"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Content="✕" FontSize="13" ToolTip="Close"
              Style="{StaticResource CloseIconButtonStyle}"/>
    </Grid>

    <!-- Live stats: 4 grouped cards (CPU, RAM, Network, Disk) -->
    <Grid Grid.Row="1" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- CPU group: live + peak -->
      <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="10,8">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="1"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" HorizontalAlignment="Center">
            <TextBlock Text="CPU" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtLiveCpu" Text="—%" FontSize="19" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
          </StackPanel>
          <Border Grid.Column="1" Background="{DynamicResource BorderBrush2}" Width="1" Margin="0,4"/>
          <StackPanel Grid.Column="2" HorizontalAlignment="Center">
            <TextBlock Text="Peak" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtMaxCpu" Text="—%" FontSize="19" FontWeight="Bold"
                       Foreground="{StaticResource YellowBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtAvgCpu" Text="" FontSize="9"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Opacity="0.75"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- RAM group: live + peak -->
      <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10,8">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="1"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" HorizontalAlignment="Center">
            <TextBlock Text="RAM" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtLiveRam" Text="—" FontSize="19" FontWeight="Bold"
                       Foreground="{StaticResource GreenBrush}" HorizontalAlignment="Center"/>
          </StackPanel>
          <Border Grid.Column="1" Background="{DynamicResource BorderBrush2}" Width="1" Margin="0,4"/>
          <StackPanel Grid.Column="2" HorizontalAlignment="Center">
            <TextBlock Text="Peak" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtMaxRam" Text="—" FontSize="19" FontWeight="Bold"
                       Foreground="{StaticResource RedBrush}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Network group: send + recv totals -->
      <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="10,8">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="1"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" HorizontalAlignment="Center">
            <TextBlock Text="↑ Send" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtLiveNetSend" Text="—" FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtTotalNetSend" Text="—" FontSize="9"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Opacity="0.75"/>
          </StackPanel>
          <Border Grid.Column="1" Background="{DynamicResource BorderBrush2}" Width="1" Margin="0,4"/>
          <StackPanel Grid.Column="2" HorizontalAlignment="Center">
            <TextBlock Text="↓ Recv" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtLiveNetRecv" Text="—" FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource GreenBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtTotalNetRecv" Text="—" FontSize="9"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Opacity="0.75"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Disk group: read + write -->
      <Border Grid.Column="6" Style="{StaticResource CardStyle}" Padding="10,8">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="1"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" HorizontalAlignment="Center">
            <TextBlock Text="Read" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtLiveDiskRead" Text="—" FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource ChartAmberBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtTotalDiskRead" Text="—" FontSize="9"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Opacity="0.75"/>
          </StackPanel>
          <Border Grid.Column="1" Background="{DynamicResource BorderBrush2}" Width="1" Margin="0,4"/>
          <StackPanel Grid.Column="2" HorizontalAlignment="Center">
            <TextBlock Text="Write" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtLiveDisk" Text="—" FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource ChartOrangeBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtTotalDiskWrite" Text="—" FontSize="9"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Opacity="0.75"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- Charts: 2x2 grid -->
    <Grid Grid.Row="2" Margin="0,0,0,6">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="6"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- CPU Chart -->
      <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12,10">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,4">
            <TextBlock Text="⚡ CPU %" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock x:Name="TxtCpuChartRange" Text="Last 60s" FontSize="9"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          </Grid>
          <Canvas x:Name="CpuChart" Grid.Row="1" MinHeight="80" ClipToBounds="True" Background="Transparent"/>
        </Grid>
      </Border>

      <!-- RAM Chart -->
      <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12,10">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,4">
            <TextBlock Text="🧠 RAM (MB)" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}"/>
            <TextBlock x:Name="TxtRamChartRange" Text="Last 60s" FontSize="9"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          </Grid>
          <Canvas x:Name="RamChart" Grid.Row="1" MinHeight="80" ClipToBounds="True" Background="Transparent"/>
        </Grid>
      </Border>

      <!-- Network Chart -->
      <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12,10">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="🌐 Network" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
              <Border Background="{DynamicResource AccentBrush}" Width="8" Height="2" VerticalAlignment="Center" Margin="6,0,2,0" CornerRadius="1"/>
              <TextBlock Text="↑" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              <Border Background="{StaticResource GreenBrush}" Width="8" Height="2" VerticalAlignment="Center" Margin="6,0,2,0" CornerRadius="1"/>
              <TextBlock Text="↓" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="TxtNetTotal" Text="" FontSize="9"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          </Grid>
          <Canvas x:Name="NetChart" Grid.Row="1" MinHeight="80" ClipToBounds="True" Background="Transparent"/>
        </Grid>
      </Border>

      <!-- Disk I/O Chart -->
      <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12,10">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="💿 Disk I/O" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ChartAmberBrush}"/>
              <Border Background="{DynamicResource ChartAmberBrush}" Width="8" Height="2" VerticalAlignment="Center" Margin="6,0,2,0" CornerRadius="1"/>
              <TextBlock Text="R" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              <Border Background="{DynamicResource ChartOrangeBrush}" Width="8" Height="2" VerticalAlignment="Center" Margin="6,0,2,0" CornerRadius="1"/>
              <TextBlock Text="W" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="TxtDiskTotal" Text="" FontSize="9"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          </Grid>
          <Canvas x:Name="DiskChart" Grid.Row="1" MinHeight="80" ClipToBounds="True" Background="Transparent"/>
        </Grid>
      </Border>
    </Grid>

    <!-- Loading bubble overlay -->
    <Border x:Name="LoadingOverlay" Visibility="Visible"
            Grid.Row="0" Grid.RowSpan="4"
            Panel.ZIndex="10"
            Background="{DynamicResource BgOverlayBrush}"
            CornerRadius="12">
      <Border HorizontalAlignment="Center" VerticalAlignment="Center"
              Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
              CornerRadius="16" Padding="24,16">
        <Border.Effect>
          <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.35" Color="#000000"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <ProgressBar IsIndeterminate="True" Width="18" Height="18" Margin="0,0,12,0"
                       Style="{StaticResource AnimatedProgressBarStyle}"/>
          <TextBlock Text="⏳  Collecting performance data…" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
        </StackPanel>
      </Border>
    </Border>

    <!-- Footer -->
    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="8"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock x:Name="TxtSampleCount" Text="Samples: 0 / 60  •  Interval: 1s" FontSize="11"
                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
      <Button x:Name="BtnPinAsWidget" Content="📌  Pin as Widget" Grid.Column="1"
              Style="{StaticResource OutlineButtonStyle}"
              Click="PinAsWidget_Click"
              ToolTip="Open a floating widget that monitors only this process"/>
      <Button Content="✖  Close" Grid.Column="3" Click="CloseBtn_Click"
              Style="{StaticResource OutlineButtonStyle}"/>
    </Grid>
  </Grid>
</Window>
