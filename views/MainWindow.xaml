<Window x:Class="SMDWin.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SMD Win — System &amp; Monitoring Data"
        Icon="/Assets/windiag.ico"
        Height="960" Width="1600" MinWidth="900" MinHeight="600"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        WindowState="Maximized"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Background="{DynamicResource BgDarkBrush}">
    <!-- WindowChrome: GlassFrameThickness="-1,-1,-1,-1" extinde DWM frame doar pe titlu
         (cat CaptionHeight) — butoanele de minimize/maximize/close raman vizibile.
         Transparenta Mica pe zona client vine din DwmExtendFrameIntoClientArea din cod. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="-1,-1,-1,-1"
                            CaptionHeight="32"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="True"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
      <BooleanToVisibilityConverter x:Key="BoolToVisConv"/>
      <!-- Stil buton caption (minimize/maximize/close) -->
      <Style x:Key="CaptionBtnStyle" TargetType="Button">
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Bd" Background="{TemplateBinding Background}">
                <!-- TextBlock explicit cu FontFamily si TextOptions pentru rendering corect -->
                <TextBlock Text="{TemplateBinding Content}"
                           FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol"
                           FontSize="10"
                           Foreground="{TemplateBinding Foreground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextOptions.TextFormattingMode="Ideal"
                           TextOptions.TextRenderingMode="Grayscale"
                           UseLayoutRounding="True"
                           SnapsToDevicePixels="True"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavActiveBrush}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="CaptionCloseBtnStyle" TargetType="Button" BasedOn="{StaticResource CaptionBtnStyle}">
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{StaticResource CloseHoverBrush}"/>
            <Setter Property="Foreground" Value="White"/>
          </Trigger>
          <Trigger Property="IsPressed" Value="True">
            <Setter Property="Background" Value="{StaticResource ClosePressedBrush}"/>
            <Setter Property="Foreground" Value="White"/>
          </Trigger>
        </Style.Triggers>
      </Style>
    </Window.Resources>

    <!-- Root grid: row 0 = title bar 32px, row 1 = continut -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="32"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- ══════════ TITLE BAR ══════════
           Afisat DOAR cand Mica e dezactivat — ThemeManager il face Visible/Collapsed.
           Cand Mica e activ, DWM deseneaza butoanele native in title bar transparent. -->
      <Grid x:Name="CustomTitleBar" Grid.Row="0" Background="Transparent" Visibility="Collapsed">
        <!-- Metrici live în centru / stânga title bar -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center"
                    Margin="14,0,0,0" IsHitTestVisible="False">
          <!-- App name pill -->
          <TextBlock Text="SMD Win" FontSize="11" FontWeight="SemiBold"
                     FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center" Opacity="0.75" Margin="0,0,14,0"/>
          <!-- Separator -->
          <Border Width="1" Height="12" Background="{DynamicResource BorderBrush2}"
                  VerticalAlignment="Center" Margin="0,0,14,0" Opacity="0.5"/>
          <!-- CPU metric -->
          <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
            <TextBlock Text="CPU" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.6"/>
            <TextBlock x:Name="TxtTitleCpu" Text="—%" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <!-- RAM metric -->
          <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
            <TextBlock Text="RAM" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.6"/>
            <TextBlock x:Name="TxtTitleRam" Text="— GB" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <!-- GPU metric -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="GPU" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.6"/>
            <TextBlock x:Name="TxtTitleGpu" Text="—%" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource ChartOrangeBrush}" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
        <!-- Butoane caption — aliniate la dreapta -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
          <Button x:Name="BtnCaptionMin"
                  Style="{StaticResource CaptionBtnStyle}"
                  ToolTip="Minimize"
                  Click="BtnCaptionMin_Click">
                    <Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5,12 H19"/></Canvas></Viewbox>
                    </Button>
          <Button x:Name="BtnCaptionMax"
                  Style="{StaticResource CaptionBtnStyle}"
                  ToolTip="Maximize"
                  Click="BtnCaptionMax_Click">
                    <Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3,3 H21 V21 H3 Z M3,8 H21"/></Canvas></Viewbox>
                    </Button>
          <Button x:Name="BtnCaptionClose"
                  Style="{StaticResource CaptionCloseBtnStyle}"
                  ToolTip="Close"
                  Click="BtnCaptionClose_Click">
                    <Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M18,6 L6,18 M6,6 L18,18"/></Canvas></Viewbox>
                    </Button>
        </StackPanel>
      </Grid>

      <!-- ══════════ CONTINUT PRINCIPAL ══════════ -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

      <!-- ══════════════════════ SIDEBAR ══════════════════════ -->
      <!-- Outer container: transparent so inner card truly floats on page background -->
      <Border Grid.Column="0" x:Name="SidebarBorder" Background="Transparent" VerticalAlignment="Stretch"
              Width="232"
              Margin="8,4,0,10">
        <!-- Glass Border card: slightly narrower, border on right from ThemeManager -->
        <Border x:Name="SidebarInnerCard" Margin="0,0,8,0" CornerRadius="12"
                VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0"
                Background="{DynamicResource SidebarBrush}">
          <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="2" Direction="270"
                              Color="#000000" Opacity="0.42" RenderingBias="Performance"/>
          </Border.Effect>
        <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Logo -->
            <RowDefinition Height="Auto"/>  <!-- Hamburger + Search -->
            <RowDefinition Height="*"/>     <!-- Nav -->
            <RowDefinition Height="Auto"/>  <!-- Bottom (widget toggle) -->
          </Grid.RowDefinitions>
          <!-- Subtle accent glow overlay — horizontal gradient tinted by theme accent -->
          <Border x:Name="SidebarAccentGlow" CornerRadius="12" Grid.RowSpan="4"
                  IsHitTestVisible="False" Panel.ZIndex="0"
                  Background="{DynamicResource _SidebarAccentGlowBrush}"/>

            <!-- ── Row 0: Logo centered ── -->
            <Button x:Name="BtnAbout" Grid.Row="0" Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Padding="0" HorizontalAlignment="Center"
                    Margin="0,8,0,4" IsTabStop="False"
                    FocusVisualStyle="{x:Null}"
                    Click="BtnAbout_Click">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="ABd" Background="Transparent" CornerRadius="8" Padding="8,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Image x:Name="ImgSidebarLogo" Width="24" Height="24"
                             VerticalAlignment="Center" Margin="0,0,8,0"
                             RenderOptions.BitmapScalingMode="HighQuality"/>
                      <TextBlock x:Name="TxtSidebarTitle" Text="SMD Win" FontSize="14" FontWeight="Bold"
                                 Foreground="{DynamicResource SidebarTextPrimaryBrush}"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="ABd" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>

            <!-- Admin LED indicator: green=admin, amber=user -->
            <Ellipse x:Name="AdminLed" Grid.Row="0" Width="7" Height="7"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,12,12,0" Fill="{DynamicResource StatusWarningBrush}" Cursor="Hand"
                     MouseLeftButtonUp="AdminModeBadge_Click">
              <Ellipse.Effect>
                <DropShadowEffect Color="{StaticResource WarnAmberColor}" BlurRadius="5" ShadowDepth="0"
                                  Opacity="0.6" RenderingBias="Performance"/>
              </Ellipse.Effect>
              <Ellipse.ToolTip>
                <ToolTip>
                  <StackPanel>
                    <TextBlock x:Name="TxtAdminLedTitle" Text="User Mode" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" MaxWidth="220" FontSize="10">
                      <Run x:Name="RunAdminLedDesc" Text="Some features require Administrator privileges:"/>
                      <LineBreak/>
                      <Run Text="• CPU/GPU sensor temperatures" Foreground="{DynamicResource StatusErrorBrush}"/>
                      <LineBreak/>
                      <Run Text="• SMART disk health details" Foreground="{DynamicResource StatusErrorBrush}"/>
                      <LineBreak/>
                      <Run Text="• Hardware performance counters" Foreground="{DynamicResource StatusErrorBrush}"/>
                      <LineBreak/><LineBreak/>
                      <Run Text="Click to restart as Administrator →" Foreground="{DynamicResource StatusInfoBrush}"/>
                    </TextBlock>
                  </StackPanel>
                </ToolTip>
              </Ellipse.ToolTip>
            </Ellipse>

            <!-- ── Row 1: hamburger + search ── -->
            <Border Grid.Row="1" Padding="0,4,0,4">
              <Grid Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Hamburger button — always visible, first column -->
                <Button x:Name="BtnSidebarCollapse" Grid.Column="0"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="36" Height="36" Margin="0,0,6,0"
                        Click="BtnSidebarCollapse_Click"
                        ToolTip="Toggle icons-only mode">
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Width="36" Height="36">
                        <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                          <Canvas Width="24" Height="24">
                            <Path x:Name="CollapseIcon" Stroke="{DynamicResource SidebarTextBrush}"
                                  StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent" Data="M3,6 H21 M3,12 H21 M3,18 H21"/>
                          </Canvas>
                        </Viewbox>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                          <Setter TargetName="Bd" Property="Opacity" Value="0.6"/>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                </Button>
                <!-- Search box (hidden when collapsed) -->
                <Border x:Name="SidebarSearchBox" Grid.Column="1" Height="32"
                        CornerRadius="8" Background="{DynamicResource BgInputBrush}"
                        BorderThickness="1">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="True">
                          <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Viewbox Width="10" Height="10" Margin="7,0,3,0" VerticalAlignment="Center" Opacity="0.4">
                      <Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M3,11 A8,8 0 1 1 19,11 A8,8 0 1 1 3,11 Z"/></Canvas>
                    </Viewbox>
                    <TextBox x:Name="TxtSidebarSearch" Grid.Column="1"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="11" Padding="0,0" VerticalContentAlignment="Center"
                             FocusVisualStyle="{x:Null}"
                             TextChanged="SidebarSearch_TextChanged"/>
                    <TextBlock x:Name="SidebarSearchHint" Grid.Column="1" Text="Search…"
                               FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.4"
                               IsHitTestVisible="False"/>
                    <Button x:Name="BtnSidebarSearchClear" Grid.Column="2"
                            Width="18" Height="18" Margin="0,0,3,0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Visibility="Collapsed"
                            Click="SidebarSearchClear_Click">
                      <TextBlock Text="✕" FontSize="8" VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                  </Grid>
                </Border>
              </Grid>
            </Border>

            <!-- Stub: SidebarHeaderExtra kept for code-behind compatibility -->
            <StackPanel x:Name="SidebarHeaderExtra" Visibility="Collapsed"/>

            <ScrollViewer x:Name="NavScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Hidden"
                          VerticalAlignment="Stretch">
              <StackPanel x:Name="NavStackPanel" Margin="10,0">
                <Grid Margin="10,3,10,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="NavCatPrincipal" Text="PRINCIPAL" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource NavCatFgBrush}" VerticalAlignment="Center"
                             Opacity="0.45" Margin="0,0,6,0"/>
                  <Border Grid.Column="1" Height="1" VerticalAlignment="Center"
                          Background="{DynamicResource NavCatFgBrush}" Opacity="0.15"/>
                </Grid>

                <!-- Dashboard -->
                <Button x:Name="BtnDashboard" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonActiveStyle}" Tag="Dashboard" Margin="0,0"
                        ToolTip="System overview: CPU, RAM, GPU, storage, health score">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoDashboard" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M4.5,3 H8.5 A1.5,1.5 0 0 1 10,4.5 V9.5 A1.5,1.5 0 0 1 8.5,11 H4.5 A1.5,1.5 0 0 1 3,9.5 V4.5 A1.5,1.5 0 0 1 4.5,3 Z M15.5,3 H19.5 A1.5,1.5 0 0 1 21,4.5 V6.5 A1.5,1.5 0 0 1 19.5,8 H15.5 A1.5,1.5 0 0 1 14,6.5 V4.5 A1.5,1.5 0 0 1 15.5,3 Z M15.5,12 H19.5 A1.5,1.5 0 0 1 21,13.5 V19.5 A1.5,1.5 0 0 1 19.5,21 H15.5 A1.5,1.5 0 0 1 14,19.5 V13.5 A1.5,1.5 0 0 1 15.5,12 Z M4.5,15 H8.5 A1.5,1.5 0 0 1 10,16.5 V19.5 A1.5,1.5 0 0 1 8.5,21 H4.5 A1.5,1.5 0 0 1 3,19.5 V16.5 A1.5,1.5 0 0 1 4.5,15 Z"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="System Summary" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <!-- Temp & Stress -->
                <Button x:Name="BtnStress" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Stress" Margin="0,0"
                        ToolTip="Real-time temperatures, stress test and CPU benchmark">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoStress" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M14,14.76 V3.5 A2.5,2.5 0 0 0 9,3.5 V14.76 A4.5,4.5 0 1 0 14,14.76 Z M11.5,7 L12.5,7 M11.5,10 L12.5,10"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Temp &amp; Stress" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Grid Margin="10,3,10,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="NavCatHw" Text="HARDWARE" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource NavCatFgBrush}" VerticalAlignment="Center"
                             Opacity="0.45" Margin="0,0,6,0"/>
                  <Border Grid.Column="1" Height="1" VerticalAlignment="Center"
                          Background="{DynamicResource NavCatFgBrush}" Opacity="0.15"/>
                </Grid>

                <!-- Storage -->
                <Button x:Name="BtnDisk" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Disk" Margin="0,0"
                        ToolTip="Disk health, SMART data, surface scan and benchmark">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoDisk" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M3,5 A9,3 0 1 1 21,5 A9,3 0 1 1 3,5 Z M21,12 C21,13.66 16.97,15 12,15 C7.03,15 3,13.66 3,12 M3,5 V19 C3,20.66 7.03,22 12,22 C16.97,22 21,20.66 21,19 V5"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Storage" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <!-- Status chip for BtnDisk -->
                <TextBlock x:Name="ChipStorage" Text=""
                           FontSize="9" Opacity="0.5" Margin="14,0,4,3"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="Collapsed"/>

                <!-- RAM -->
                <Button x:Name="BtnRam" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Ram" Margin="0,0"
                        ToolTip="RAM modules, slots, speed and bandwidth benchmark">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoRam" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M4,5 H20 A1,1 0 0 1 21,6 V18 A1,1 0 0 1 20,19 H4 A1,1 0 0 1 3,18 V6 A1,1 0 0 1 4,5 Z M7,8 V11 H9 V8 Z M11,8 V11 H13 V8 Z M15,8 V11 H17 V8 Z M10,19 V16 H14 V19"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="RAM Memory" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <!-- Status chip for BtnRam -->
                <TextBlock x:Name="ChipRam" Text=""
                           FontSize="9" Opacity="0.5" Margin="14,0,4,3"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="Collapsed"/>

                <!-- Battery -->
                <Button x:Name="BtnBattery" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Battery" Margin="0,0"
                        ToolTip="Battery health, charge cycles, capacity and live monitor">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoBattery" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M4,7 H18 A2,2 0 0 1 20,9 V15 A2,2 0 0 1 18,17 H4 A2,2 0 0 1 2,15 V9 A2,2 0 0 1 4,7 Z M22,11 V13 M7,11 V13 M11,11 V13"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Battery" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <!-- Status chip for BtnBattery -->
                <TextBlock x:Name="ChipBattery" Text=""
                           FontSize="9" Opacity="0.5" Margin="14,0,4,3"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="Collapsed"/>

                <Grid Margin="10,3,10,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="NavCatSys" Text="SISTEM" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource NavCatFgBrush}" VerticalAlignment="Center"
                             Opacity="0.45" Margin="0,0,6,0"/>
                  <Border Grid.Column="1" Height="1" VerticalAlignment="Center"
                          Background="{DynamicResource NavCatFgBrush}" Opacity="0.15"/>
                </Grid>

                <!-- Network -->
                <Button x:Name="BtnNetwork" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Network" Margin="0,0"
                        ToolTip="Network adapters, WiFi scanner, ping monitor, port scanner">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoNetwork" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M1.42,9 A16,16 0 0 1 22.58,9 M5,12.55 A11,11 0 0 1 19,12.55 M8.53,16.11 A6,6 0 0 1 15.47,16.11 M12,20 L12.01,20"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Network" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <!-- Status chip for BtnNetwork -->
                <TextBlock x:Name="ChipNetwork" Text=""
                           FontSize="9" Opacity="0.5" Margin="14,0,4,3"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="Collapsed"/>

                <!-- Applications -->
                <Button x:Name="BtnApps" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Apps" Margin="0,0"
                        ToolTip="Installed applications list with version and publisher">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoApps" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M4.5,3 H8.5 A1.5,1.5 0 0 1 10,4.5 V8.5 A1.5,1.5 0 0 1 8.5,10 H4.5 A1.5,1.5 0 0 1 3,8.5 V4.5 A1.5,1.5 0 0 1 4.5,3 Z M15.5,3 H19.5 A1.5,1.5 0 0 1 21,4.5 V8.5 A1.5,1.5 0 0 1 19.5,10 H15.5 A1.5,1.5 0 0 1 14,8.5 V4.5 A1.5,1.5 0 0 1 15.5,3 Z M4.5,14 H8.5 A1.5,1.5 0 0 1 10,15.5 V19.5 A1.5,1.5 0 0 1 8.5,21 H4.5 A1.5,1.5 0 0 1 3,19.5 V15.5 A1.5,1.5 0 0 1 4.5,14 Z M15.5,14 H19.5 A1.5,1.5 0 0 1 21,15.5 V19.5 A1.5,1.5 0 0 1 19.5,21 H15.5 A1.5,1.5 0 0 1 14,19.5 V15.5 A1.5,1.5 0 0 1 15.5,14 Z"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Applications" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <!-- Windows Services -->
                <Button x:Name="BtnServices" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Services" Margin="0,0"
                        ToolTip="Windows services status — start, stop, toggle key services">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoServices" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M12,2 L2,7 L12,12 L22,7 Z M2,17 L12,22 L22,17 M2,12 L12,17 L22,12"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Windows Services" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <!-- Process Monitor -->
                <Button x:Name="BtnProcesses" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Processes" Margin="0,0"
                        ToolTip="Live process monitor with CPU and RAM usage">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoProcesses" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M22,12 L18,12 L15,21 L9,3 L6,12 L2,12"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Process Monitor" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <!-- Startup Manager -->
                <Button x:Name="BtnStartup" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Startup" Margin="0,0"
                        ToolTip="Manage programs that run at Windows startup">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoStartup" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                              Data="M4.5,16.5 C3,18 3,21 3,21 C3,21 6,21 7.5,19.5 C8.33,18.67 8.33,17.33 7.5,16.5 C6.67,15.67 5.33,15.67 4.5,16.5 Z M12,15 L9,12 M14.5,4 L11,7.5 C11,7.5 9,13 9.5,13.5 C10,14 15.5,12 15.5,12 L19,8.5 C19,8.5 19,5.5 17,3.5 C15,1.5 12,2 12,2 Z"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Startup Manager" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <!-- Tools -->
                <Button x:Name="BtnShutdown" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Tools" Margin="0,0"
                        ToolTip="Tools: Shutdown Timer, PowerShell Runner">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoTools" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M14.7,6.3 A1,1 0 0 0 13,6 L4,16 L6,18 L16,9 A1,1 0 0 0 14.7,6.3 Z M18,2 L20,4 L14.7,6.3 M9,15 L3,21 M15,9 L19,13 L21,11 L17,7 Z"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Tools" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Grid Margin="10,3,10,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="NavCatDiag" Text="DIAGNOSTICARE" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource NavCatFgBrush}" VerticalAlignment="Center"
                             Opacity="0.45" Margin="0,0,6,0"/>
                  <Border Grid.Column="1" Height="1" VerticalAlignment="Center"
                          Background="{DynamicResource NavCatFgBrush}" Opacity="0.15"/>
                </Grid>

                <!-- Event Viewer -->
                <Button x:Name="BtnEvents" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Events" Margin="0,0"
                        ToolTip="Windows Event Log — errors, warnings and system events">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Icon with badge overlay -->
                    <Grid Grid.Column="0" Width="28" VerticalAlignment="Center" Margin="0,0,8,0">
                      <Viewbox x:Name="IcoEvents" Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                          <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                Data="M14,2 H6 A2,2 0 0 0 4,4 V20 A2,2 0 0 0 6,22 H18 A2,2 0 0 0 20,20 V8 Z M14,2 V8 H20 M8,13 H16 M8,17 H13"/>
                        </Canvas>
                      </Viewbox>
                      <!-- Badge overlay — top-right of icon -->
                      <Border x:Name="BadgeEvents" CornerRadius="6" Padding="4,1"
                              Background="{DynamicResource StatusErrorBgBrush}" BorderBrush="{DynamicResource StatusErrorBrush}" BorderThickness="1"
                              Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-6,0">
                        <TextBlock x:Name="TxtBadgeEvents" Text="0" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource StatusErrorBrush}" FontFamily="{StaticResource MonoFont}" LineHeight="10"/>
                      </Border>
                    </Grid>
                    <TextBlock Grid.Column="1" Text="Event Viewer" VerticalAlignment="Center"/>
                  </Grid>
                </Button>
                <!-- Status chip for BtnEvents -->
                <TextBlock x:Name="ChipEvents" Text=""
                           FontSize="9" Opacity="0.5" Margin="14,0,4,3"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="Collapsed"/>

                <!-- BSOD / Crash -->
                <Button x:Name="BtnCrash" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Crash" Margin="0,0"
                        ToolTip="Blue screen crash dumps — date, stop code, faulting module">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Icon with badge overlay -->
                    <Grid Grid.Column="0" Width="28" VerticalAlignment="Center" Margin="0,0,8,0">
                      <Viewbox x:Name="IcoCrash" Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                          <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                Data="M12,2 L2,22 L22,22 Z M12,9 V14"/>
                          <Path Fill="{DynamicResource SidebarTextPrimaryBrush}" Data="M11.2,18 A0.8,0.8 0 1 1 12.8,18 A0.8,0.8 0 1 1 11.2,18 Z"/>
                        </Canvas>
                      </Viewbox>
                      <Border x:Name="BadgeCrash" CornerRadius="6" Padding="4,1"
                              Background="{DynamicResource StatusErrorBgBrush}" BorderBrush="{DynamicResource StatusErrorBrush}" BorderThickness="1"
                              Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-6,0">
                        <TextBlock x:Name="TxtBadgeCrash" Text="0" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource StatusErrorBrush}" FontFamily="{StaticResource MonoFont}" LineHeight="10"/>
                      </Border>
                    </Grid>
                    <TextBlock Grid.Column="1" Text="BSOD / Crash" VerticalAlignment="Center"/>
                  </Grid>
                </Button>
                <!-- Status chip for BtnCrash -->
                <TextBlock x:Name="ChipCrash" Text=""
                           FontSize="9" Opacity="0.5" Margin="14,0,4,3"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="Collapsed"/>

                <!-- Drivers -->
                <Button x:Name="BtnDrivers" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Drivers" Margin="0,0"
                        ToolTip="Device drivers status — missing, outdated or problematic drivers">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Icon with warning badge overlay — works collapsed too -->
                    <Grid Grid.Column="0" Width="28" VerticalAlignment="Center" Margin="0,0,8,0">
                      <Viewbox x:Name="IcoDrivers" Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                          <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                  Data="M6,4 H18 A2,2 0 0 1 20,6 V18 A2,2 0 0 1 18,20 H6 A2,2 0 0 1 4,18 V6 A2,2 0 0 1 6,4 Z M9,4 V1 M15,4 V1 M9,20 V23 M15,20 V23 M4,9 H1 M4,15 H1 M20,9 H23 M20,15 H23 M9,9 H15 V15 H9 Z"/>
                        </Canvas>
                      </Viewbox>
                      <!-- Warning badge: solid red circle with count — visible on dark+light, collapsed+expanded -->
                      <Border x:Name="BadgeDrivers" CornerRadius="8" Padding="4,2"
                              Background="#E8192C" BorderThickness="1.5" BorderBrush="{DynamicResource SidebarBgBrush}"
                              Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Top"
                              Margin="0,-4,-6,0" MinWidth="16">
                        <TextBlock x:Name="TxtBadgeDrivers" Text="0" FontSize="8" FontWeight="Bold"
                                   Foreground="White" FontFamily="{StaticResource MonoFont}"
                                   HorizontalAlignment="Center" LineHeight="11"/>
                      </Border>
                    </Grid>
                    <TextBlock Grid.Column="1" Text="Drivers" VerticalAlignment="Center"/>
                  </Grid>
                </Button>
                <!-- Status chip for BtnDrivers -->
                <TextBlock x:Name="ChipDrivers" Text=""
                           FontSize="9" Opacity="0.5" Margin="14,0,4,3"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="Collapsed"/>

                <!-- PowerShell (hidden by default) -->
                <Button x:Name="BtnPowerShell" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="PowerShell" Margin="0,0"
                        ToolTip="Quick PowerShell commands for diagnostics and system management"
                        Visibility="Collapsed">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform"><Path Fill="{DynamicResource CyanAccentBrush}" Data="M16 7H5a3 3 0 0 0-3 3v4a3 3 0 0 0 3 3h11a3 3 0 0 0 3-3v-4a3 3 0 0 0-3-3zm1 7a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1h11a1 1 0 0 1 1 1zm3-6v6h1a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1zM7 9h5v6H7z"/></Viewbox>
                    <TextBlock Text="PowerShell" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Grid Margin="10,3,10,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="NavCatCfg" Text="CONFIGURARE" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource NavCatFgBrush}" VerticalAlignment="Center"
                             Opacity="0.45" Margin="0,0,6,0"/>
                  <Border Grid.Column="1" Height="1" VerticalAlignment="Center"
                          Background="{DynamicResource NavCatFgBrush}" Opacity="0.15"/>
                </Grid>

                <!-- Settings -->
                <Button x:Name="BtnSettings" Click="NavBtn_Click"
                        Style="{StaticResource NavButtonStyle}" Tag="Settings" Margin="0,0"
                        ToolTip="Theme, language, refresh intervals and temperature thresholds">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox x:Name="IcoSettings" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M12.22,2 H11.78 A2,2 0 0 0 9.78,4 V4.18 A2,2 0 0 1 8.78,5.91 L8.35,6.16 A2,2 0 0 1 6.35,6.16 L6.2,6.08 A2,2 0 0 0 3.47,6.81 L3.25,7.19 A2,2 0 0 0 3.98,9.92 L4.13,10.02 A2,2 0 0 1 5.13,11.74 V12.25 A2,2 0 0 1 4.13,13.99 L3.98,14.08 A2,2 0 0 0 3.25,16.81 L3.47,17.19 A2,2 0 0 0 6.2,17.92 L6.35,17.84 A2,2 0 0 1 8.35,17.84 L8.78,18.09 A2,2 0 0 1 9.78,19.82 V20 A2,2 0 0 0 11.78,22 H12.22 A2,2 0 0 0 14.22,20 V19.82 A2,2 0 0 1 15.22,18.09 L15.65,17.84 A2,2 0 0 1 17.65,17.84 L17.8,17.92 A2,2 0 0 0 20.53,17.19 L20.75,16.81 A2,2 0 0 0 20.02,14.08 L19.87,13.99 A2,2 0 0 1 18.87,12.25 V11.75 A2,2 0 0 1 19.87,10.01 L20.02,9.92 A2,2 0 0 0 20.75,7.19 L20.53,6.81 A2,2 0 0 0 17.8,6.08 L17.65,6.16 A2,2 0 0 1 15.65,6.16 L15.22,5.91 A2,2 0 0 1 14.22,4.18 V4 A2,2 0 0 0 12.22,2 Z M9,12 A3,3 0 1 1 15,12 A3,3 0 1 1 9,12 Z"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Settings" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

              </StackPanel>
            </ScrollViewer>

            <!-- ── Bottom info ── -->
            <StackPanel Grid.Row="3" Margin="12,0,12,8">
              <!-- Hidden elements kept for code-behind compatibility -->
              <Button x:Name="BtnBuildInfo" Visibility="Collapsed" Click="BtnBuildInfo_Click"/>
              <Button x:Name="BtnCheckUpdate" Visibility="Collapsed" Click="BtnCheckUpdate_Click"/>
              <TextBlock x:Name="TxtVersion" Visibility="Collapsed" Text="v0.1 Beta"/>
              <TextBlock x:Name="TxtBuildDate" Visibility="Collapsed"/>
              <TextBlock x:Name="TxtUpdateStatus" Visibility="Collapsed"/>
              <!-- TxtSubtitle kept hidden for code-behind compat -->
              <TextBlock x:Name="TxtSubtitle" Visibility="Collapsed" Text="System &amp; Monitoring Data"/>

              <!-- Admin badge — replaced by AdminLed next to logo -->
              <Border x:Name="AdminModeBadge" Visibility="Collapsed" CornerRadius="4" Padding="6,3"
                      Background="Transparent" BorderThickness="1"
                      BorderBrush="{DynamicResource CardBorderBrush}"
                      HorizontalAlignment="Left"
                      Cursor="Hand" MouseLeftButtonUp="AdminModeBadge_Click">
                <Border.ToolTip>
                  <ToolTip>
                    <StackPanel>
                      <TextBlock x:Name="TxtAdminTooltipTitle" Text="Running as Standard User"
                                 FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                      <TextBlock TextWrapping="Wrap" MaxWidth="220" FontSize="10">
                        <Run Text="Some features require Administrator privileges:"/>
                        <LineBreak/>
                        <Run Text="• CPU/GPU sensor temperatures" Foreground="{DynamicResource StatusErrorBrush}"/>
                        <LineBreak/>
                        <Run Text="• SMART disk health details" Foreground="{DynamicResource StatusErrorBrush}"/>
                        <LineBreak/>
                        <Run Text="• Hardware performance counters" Foreground="{DynamicResource StatusErrorBrush}"/>
                        <LineBreak/><LineBreak/>
                        <Run Text="Click to restart as Administrator →" Foreground="{DynamicResource StatusInfoBrush}"/>
                      </TextBlock>
                    </StackPanel>
                  </ToolTip>
                </Border.ToolTip>
                <Border.Style>
                  <Style TargetType="Border">
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                  <TextBlock x:Name="TxtAdminBadgeIcon" Text="" FontSize="9"
                             Margin="0,0,4,0" VerticalAlignment="Center"
                             Foreground="{DynamicResource StatusOkBrush}"/>
                  <TextBlock x:Name="TxtAdminBadgeText" Text="USER MODE"
                             FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource StatusOkBrush}" VerticalAlignment="Center"/>
                  <TextBlock x:Name="TxtAdminBadgeSub" Visibility="Collapsed"/>
                </StackPanel>
              </Border>

              <!-- Widget toggle button — same NavButtonStyle as all other nav items -->
              <Button x:Name="BtnToggleWidget" Click="BtnToggleWidget_Click"
                      Style="{StaticResource NavButtonStyle}" Tag="Widget"
                      Margin="0,0"
                      ToolTip="Open mini always-on-top widget with live stats">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox x:Name="WidgetIcon" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Canvas Width="24" Height="24">
                      <Path Stroke="{DynamicResource SidebarTextPrimaryBrush}" StrokeThickness="1.6"
                            StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                            Fill="Transparent"
                            Data="M2,3 H22 V17 H2 Z M8,21 H16 M12,17 V21 M7,7 H11 V13 H7 Z M13,7 H17 M13,10 H17 M13,13 H15"/>
                    </Canvas>
                  </Viewbox>
                  <TextBlock x:Name="Lbl" Text="Widget" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>
        </Border>
      </Border>

      <!-- ══════════════════════════ CONTENT AREA ══════════════════════════ -->
      <Grid Grid.Column="1" x:Name="MainContentBorder">
        <!-- Decorative top accent line on content area -->

        <!-- Breadcrumb hidden — compatibility stubs only -->
        <Border x:Name="BreadcrumbBar" Visibility="Collapsed" Height="0"/>
        <TextBlock x:Name="BreadcrumbPage" Visibility="Collapsed"/>
        <TextBlock x:Name="BreadcrumbSub"  Visibility="Collapsed"/>
        <TextBlock x:Name="BreadcrumbDesc" Visibility="Collapsed"/>

        <!-- ── DASHBOARD / SYSTEM SUMMARY ── -->
        <Grid x:Name="PanelDashboard" Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- diagnose progress bar -->
            <RowDefinition Height="Auto"/>  <!-- ROW 1 Live 4-col -->
            <RowDefinition Height="Auto"/>  <!-- ROW 2 Temp+Network -->
            <RowDefinition Height="Auto"/>  <!-- HARDWARE label -->
            <RowDefinition Height="Auto"/>  <!-- ROW 3 Specs -->
            <RowDefinition Height="Auto"/>  <!-- SYSTEM label -->
            <RowDefinition Height="Auto"/>  <!-- ROW 3b System Info -->
            <RowDefinition Height="Auto"/>  <!-- STORAGE label -->
            <RowDefinition Height="*"/>     <!-- ROW 4 Storage (expands) -->
            <RowDefinition Height="Auto"/>  <!-- Diagnose Button -->
          </Grid.RowDefinitions>
          <!-- Skeleton loading overlay -->
          <Grid x:Name="DashboardSkeleton" Visibility="Visible" Panel.ZIndex="5"
                Grid.RowSpan="11"
                Background="{DynamicResource BgPrimaryBrush}" Margin="0">
            <Grid.Resources>
              <!-- Shimmer sweep animation: a bright band scrolls left→right repeatedly -->
              <Storyboard x:Key="ShimmerAnim" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                                 Storyboard.TargetProperty="X"
                                 From="-300" To="800" Duration="0:0:1.4"
                                 BeginTime="0:0:0"/>
              </Storyboard>
            </Grid.Resources>
            <Grid.Triggers>
              <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource ShimmerAnim}"/>
              </EventTrigger>
            </Grid.Triggers>
            <StackPanel Margin="24" VerticalAlignment="Top">
              <!-- Title bar placeholder -->
              <Border Height="28" Width="180" CornerRadius="6" Margin="0,0,0,20" HorizontalAlignment="Left"
                      Background="{DynamicResource BgOverlayBrush}">
                <Border.OpacityMask>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#FF000000" Offset="0.3"/>
                    <GradientStop Color="#FF000000" Offset="0.7"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                  </LinearGradientBrush>
                </Border.OpacityMask>
              </Border>
              <!-- 4-card row -->
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="80" CornerRadius="10" Margin="0,0,8,0"  Background="{DynamicResource BgOverlayBrush}"/>
                <Border Grid.Column="1" Height="80" CornerRadius="10" Margin="4,0,4,0"  Background="{DynamicResource BgOverlayBrush}"/>
                <Border Grid.Column="2" Height="80" CornerRadius="10" Margin="4,0,4,0"  Background="{DynamicResource BgOverlayBrush}"/>
                <Border Grid.Column="3" Height="80" CornerRadius="10" Margin="8,0,0,0"  Background="{DynamicResource BgOverlayBrush}"/>
              </Grid>
              <!-- 2-card row -->
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="120" CornerRadius="10" Margin="0,0,8,0" Background="{DynamicResource BgOverlayBrush}"/>
                <Border Grid.Column="1" Height="120" CornerRadius="10" Margin="4,0,0,0" Background="{DynamicResource BgOverlayBrush}"/>
              </Grid>
              <!-- 3-card row -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="90" CornerRadius="10" Margin="0,0,8,0"  Background="{DynamicResource BgOverlayBrush}"/>
                <Border Grid.Column="1" Height="90" CornerRadius="10" Margin="4,0,4,0"  Background="{DynamicResource BgOverlayBrush}"/>
                <Border Grid.Column="2" Height="90" CornerRadius="10" Margin="8,0,0,0"  Background="{DynamicResource BgOverlayBrush}"/>
              </Grid>
            </StackPanel>
            <!-- Shimmer sweep overlay — translucent band scrolling across all cards -->
            <Canvas ClipToBounds="True" IsHitTestVisible="False">
              <Rectangle x:Name="ShimmerRect" Width="200" Height="600" Canvas.Top="0">
                <Rectangle.Fill>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                    <GradientStop Color="#18FFFFFF" Offset="0.4"/>
                    <GradientStop Color="#28FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#18FFFFFF" Offset="0.6"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                  </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                  <TranslateTransform x:Name="ShimmerTranslate" X="-300"/>
                </Rectangle.RenderTransform>
              </Rectangle>
            </Canvas>
          </Grid>
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                        Grid.Row="0" Grid.RowSpan="11">
          <StackPanel Margin="20,14,20,20">

            <!-- Header removed — hidden elements kept for code compat -->
            <TextBlock x:Name="TxtDashTitle" Visibility="Collapsed" Text="System Summary"/>
            <TextBlock x:Name="TxtDashSubtitle" Visibility="Collapsed" Text="Live overview"/>
            <TextBlock x:Name="TxtDashClock" Visibility="Collapsed" Text="--:--:--"/>
            <TextBlock x:Name="TxtDashDate" Visibility="Collapsed" Text=""/>

            <!-- Diagnose progress bar (shown during test) -->
            <Border x:Name="DiagnoseDurationBorder" Visibility="Collapsed"/>

            <!-- Admin mode info banner -->
            <Border x:Name="DashAdminBanner" Visibility="Collapsed"
                    CornerRadius="10" Padding="14,10" Margin="0,0,0,12"
                    BorderThickness="1">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Viewbox Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path x:Name="DashAdminIcon" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </Canvas>
                </Viewbox>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock x:Name="TxtDashAdminTitle" FontSize="12" FontWeight="SemiBold"/>
                  <TextBlock x:Name="TxtDashAdminSub" FontSize="10" Opacity="0.7" TextWrapping="Wrap"/>
                </StackPanel>
                <Button x:Name="BtnDashAdmin" Grid.Column="2"
                        Style="{StaticResource OutlineButtonStyle}"
                        Padding="12,5" Margin="10,0,0,0" VerticalAlignment="Center"
                        Click="AdminModeBadge_Click" Cursor="Hand">
                  <TextBlock x:Name="TxtDashAdminBtn" FontSize="11"/>
                </Button>
              </Grid>
            </Border>
            <Border x:Name="DiagnoseProgressBorder" Visibility="Collapsed"
                    Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="12,8">
              <StackPanel>
                <Grid Margin="0,0,0,4">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock x:Name="TxtDiagnoseStatus" Text="Running diagnostics…"
                             FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                  <TextBlock x:Name="TxtDiagnoseTimer" Text="60s" Grid.Column="1"
                             FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                </Grid>
                <Border Background="{DynamicResource BgInputBrush}" CornerRadius="4" Height="6">
                  <Border x:Name="DiagnoseProgressFill" Background="{DynamicResource AccentBrush}"
                          CornerRadius="4" Height="6" HorizontalAlignment="Left" Width="0"/>
                </Border>
              </StackPanel>
            </Border>


            <!-- ── LIVE section header ── -->
            <Grid Margin="2,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <!-- LIVE label (LED dot removed) -->
              <TextBlock Text="LIVE" FontSize="9" FontWeight="Bold"
                         Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Opacity="0.6"/>
              <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                      Background="{DynamicResource CardBorderBrush}" Opacity="0.5"/>
            </Grid>

                        <!-- ══════════════════════════════════════════════════════
                 ROW 1 — LIVE: CPU · GPU · RAM · Disk
                 Structura card: outer Border ClipToBounds=True
                   └─ Grid (3 rows): header | canvas | footer
                      └─ Border accent jos = Row 2 (Height=3, nu RowSpan)
                 ══════════════════════════════════════════════════════ -->
            <Grid Margin="0,0,0,8" Height="130">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- ── CPU ── -->
              <Border x:Name="DashCpuCard" Grid.Column="0"
                      Style="{StaticResource DashClickCardStyle}"
                      MouseLeftButtonUp="DashCpu_Click" ToolTip="Open Temp &amp; Stress">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                  </Grid.RowDefinitions>
                  <!-- Header -->
                  <Grid Grid.Row="0" Margin="12,8,12,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="15" Height="15" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="Transparent" Data="M4 6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6zm2 1v8h12V7H6zm2 1h8v6H8V8zm1 1v4h6V9H9zM2 9h2v2H2V9zm18 0h2v2h-2V9zM2 13h2v2H2v-2zm18 0h2v2h-2v-2z"/></Canvas></Viewbox>
                      <TextBlock Text="CPU" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock x:Name="TxtCpuDash" Text="—" FontSize="10" Visibility="Collapsed"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                      <TextBlock x:Name="TxtDashCpuLabelInline" Text="" FontSize="8" Visibility="Collapsed"
                                 FontFamily="{StaticResource MonoFont}"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtDashCpuPct" Text="—%" Grid.Column="2"
                               FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="6,0"/>
                    <!-- TxtDashCpuTemp kept hidden for code-behind compat — temp shown in row 2 -->
                    <TextBlock x:Name="TxtDashCpuTemp" Text="" Visibility="Collapsed"/>
                  </Grid>
                  <!-- Sparkline (fills remaining space) -->
                  <Canvas x:Name="SparkCpu" Grid.Row="1" ClipToBounds="True"/>
                  <Border x:Name="DashCpuBar" Grid.Row="1" Visibility="Collapsed" Height="0" Width="0"/>
                  <TextBlock Grid.Row="2" x:Name="TxtDashCpuLabel" Text="— CPU" FontSize="9"
                             FontFamily="{StaticResource MonoFont}" Margin="14,2,14,4"
                             Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.55" Visibility="Collapsed"/>
                </Grid>
              </Border>

              <!-- ── GPU ── -->
              <Border x:Name="DashGpuCard" Grid.Column="2"
                      Style="{StaticResource DashClickCardStyle}"
                      MouseLeftButtonUp="DashCpu_Click" ToolTip="Open Temp &amp; Stress">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="12,7,12,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="15" Height="15" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Fill="{DynamicResource TextSecondaryBrush}" Data="M2 5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-6l1 2h2a1 1 0 0 1 0 2H7a1 1 0 0 1 0-2h2l1-2H4a2 2 0 0 1-2-2V5zm2 0v9h16V5H4zm3 2h10v5H7V7zm1 1v3h8V8H8z"/></Canvas></Viewbox>
                      <TextBlock Text="GPU" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock x:Name="TxtDashGpuSub" Text="—" FontSize="10" Visibility="Collapsed"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                      <TextBlock x:Name="TxtDashGpuLabelInline" Text="" FontSize="8" Visibility="Collapsed"
                                 FontFamily="{StaticResource MonoFont}"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtDashGpuPct" Text="—%" Grid.Column="2"
                               FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ChartOrangeBrush}" VerticalAlignment="Center" Margin="6,0"/>
                    <!-- TxtDashGpuTempInline kept hidden for code-behind compat — temp shown in row 2 -->
                    <TextBlock x:Name="TxtDashGpuTempInline" Text="" Visibility="Collapsed"/>
                  </Grid>
                  <Canvas x:Name="SparkGpu" Grid.Row="1" ClipToBounds="True"
                          SizeChanged="SparkGpu_SizeChanged" Loaded="SparkGpu_SizeChanged"/>
                  <Border x:Name="DashGpuBar" Grid.Row="1" Visibility="Collapsed" Height="0" Width="0"/>
                  <TextBlock Grid.Row="2" x:Name="TxtDashGpuLabel" Text="— GPU" FontSize="9"
                             FontFamily="{StaticResource MonoFont}" Margin="14,2,14,4"
                             Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.55" Visibility="Collapsed"/>
                </Grid>
              </Border>

              <!-- ── RAM ── -->
              <Border x:Name="DashRamCard" Grid.Column="4"
                      Style="{StaticResource DashClickCardStyle}"
                      MouseLeftButtonUp="DashRam_Click" ToolTip="Open RAM page">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="12,7,12,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal">
                        <Viewbox Width="15" Height="15" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Fill="{DynamicResource TextSecondaryBrush}" Data="M3 3a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1H3zm1 2h16v8H4V5zm2 1v2h2V6H6zm3 0v2h2V6H9zm3 0v2h2V6h-2zm3 0v2h2V6h-2z"/></Canvas></Viewbox>
                        <TextBlock Text="RAM" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                        <TextBlock x:Name="TxtDashRamUsed" Text="— / — GB" FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtRamDashSub" Text="" FontSize="10" Margin="6,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                      </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="TxtDashRamPct" Text="—%" Grid.Column="1"
                               FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center"/>
                  </Grid>
                  <Canvas x:Name="SparkRam" Grid.Row="1" ClipToBounds="True"/>
                  <Border x:Name="DashRamBar" Grid.Row="1" Visibility="Collapsed" Height="0" Width="0"/>
                  <Border Grid.Row="2" Height="0"/>
                </Grid>
              </Border>

              <!-- ── Disk Activity ── -->
              <Border Grid.Column="6"
                      Style="{StaticResource DashClickCardStyle}"
                      MouseLeftButtonUp="DashStorage_Click" ToolTip="Open Storage page">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="12,7,12,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,8,0">
                      <StackPanel Orientation="Horizontal">
                        <Viewbox Width="15" Height="15" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Fill="{DynamicResource TextSecondaryBrush}" Data="M7 2a4 4 0 0 0-4 4v12a4 4 0 0 0 4 4h10a4 4 0 0 0 4-4V6a4 4 0 0 0-4-4H7zm0 2h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm5 10a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM8 6v2h8V6H8z"/></Canvas></Viewbox>
                        <TextBlock Text="Disk" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                        <Border Width="7" Height="2" CornerRadius="1" Background="{StaticResource WarnAmberBrush}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="R" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.7"/>
                        <Border Width="7" Height="2" CornerRadius="1" Background="{DynamicResource ChartOrangeBrush}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="W" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Opacity="0.7"/>
                      </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="TxtDashDiskActivity" Text="Idle" Grid.Column="1" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TxtDashDiskPct" Text="" Grid.Column="2"
                               FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusWarningBrush}" VerticalAlignment="Center"/>
                  </Grid>
                  <Canvas x:Name="SparkDiskActivity" Grid.Row="1" ClipToBounds="True" Background="Transparent"
                          SizeChanged="SparkDiskActivity_SizeChanged"/>
                  <Border Grid.Row="2" Height="0"/>
                </Grid>
              </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 ROW 2 — CPU Temp · GPU Temp · Network · Ping
                 ══════════════════════════════════════════════════════ -->
            <Grid Margin="0,0,0,8" Height="130">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- ── CPU Temp ── -->
              <Border x:Name="DashCpuTempCard" Grid.Column="0"
                      Style="{StaticResource DashClickCardStyle}"
                      MouseLeftButtonUp="DashTemp_Click" ToolTip="Open Temp &amp; Stress">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="12,7,12,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12" Margin="0,0,6,0" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}"
                              Data="M12 3a2 2 0 0 0-2 2v7.2A4 4 0 1 0 14 12.2V5a2 2 0 0 0-2-2zm0 15a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/>
                        <TextBlock Text="CPU Temp" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <TextBlock x:Name="TxtDashCpuTempRange" Text="" FontSize="9"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7" Margin="0,1,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtDashCpuTempBig" Text="—°" Grid.Column="1"
                               FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                  </Grid>
                  <Canvas x:Name="DashCpuTempChart" Grid.Row="1" Background="Transparent"
                          SizeChanged="DashCpuTempChart_SizeChanged" ClipToBounds="True"/>
                  <Border Grid.Row="2" Height="0"/>
                </Grid>
              </Border>

              <!-- ── GPU Temp ── -->
              <Border x:Name="DashGpuTempCard" Grid.Column="2"
                      Style="{StaticResource DashClickCardStyle}"
                      MouseLeftButtonUp="DashTemp_Click" ToolTip="Open Temp &amp; Stress">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="12,7,12,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12" Margin="0,0,6,0" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}"
                              Data="M12 3a2 2 0 0 0-2 2v7.2A4 4 0 1 0 14 12.2V5a2 2 0 0 0-2-2zm0 15a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/>
                        <TextBlock Text="GPU Temp" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <TextBlock x:Name="TxtDashGpuTempRange" Text="" FontSize="9"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7" Margin="0,1,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtDashGpuTempBig" Text="—°" Grid.Column="1"
                               FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ChartOrangeBrush}" VerticalAlignment="Center"/>
                  </Grid>
                  <Canvas x:Name="DashGpuTempChart" Grid.Row="1" Background="Transparent"
                          SizeChanged="DashGpuTempChart_SizeChanged" ClipToBounds="True"/>
                  <Border Grid.Row="2" Height="0"/>
                </Grid>
              </Border>

              <!-- ── Network Activity ── -->
              <Border Grid.Column="4"
                      Style="{StaticResource DashClickCardStyle}"
                      MouseLeftButtonUp="DashNetwork_Click" ToolTip="Open Network page">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="12,7,12,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,8,0">
                      <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12" Margin="0,0,6,0" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}"
                              Data="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm0 0c-2.5 3-4 6.5-4 10s1.5 7 4 10m0-20c2.5 3 4 6.5 4 10s-1.5 7-4 10M2 12h20"/>
                        <TextBlock Text="Network" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                        <Border Width="7" Height="2" CornerRadius="1" Background="{DynamicResource ChartGreenBrush}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="D" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.7"/>
                        <Border Width="7" Height="2" CornerRadius="1" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="U" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Opacity="0.7"/>
                      </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="TxtDashNetAdapter" Text="" Grid.Column="1" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TxtDashNetDown" Text="↓ —" Grid.Column="2"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBlock x:Name="TxtDashNetUp" Text="↑ —" Grid.Column="3"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                  </Grid>
                  <Canvas x:Name="SparkNetActivity" Grid.Row="1" ClipToBounds="True" Background="Transparent"
                          SizeChanged="SparkNetActivity_SizeChanged"/>
                  <Border Grid.Row="2" Height="0"/>
                </Grid>
              </Border>

              <!-- ── Ping ── -->
              <Border x:Name="DashPingCard" Grid.Column="6"
                      Style="{StaticResource DashClickCardStyle}"
                      MouseLeftButtonUp="DashPingCard_Click" ToolTip="Open Ping Monitor">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                  </Grid.RowDefinitions>
                  <Grid Grid.Row="0" Margin="12,7,12,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12" Margin="0,0,6,0" Stretch="Uniform"
                              Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5" Fill="Transparent"
                              Data="M22 12h-4l-3 9L9 3l-3 9H2"/>
                        <TextBlock Text="Ping" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                        <TextBlock x:Name="TxtDashPingHost" Text="8.8.8.8" FontSize="9"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0" Opacity="0.7"/>
                        <TextBlock x:Name="TxtDashPingStatus" Text="" FontSize="9"
                                   Foreground="{DynamicResource StatusSuccessBrush}" Opacity="0.8"/>
                      </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="TxtDashPingMs" Text="— ms" Grid.Column="1"
                               FontSize="20" FontWeight="Bold" Foreground="{DynamicResource NavPageAccentBrush}" VerticalAlignment="Center"/>
                  </Grid>
                  <Canvas x:Name="DashPingChart" Grid.Row="1" Background="Transparent"
                          SizeChanged="DashPingChart_SizeChanged" ClipToBounds="True"/>
                  <Border Grid.Row="2" Height="0"/>
                </Grid>
              </Border>
            </Grid>
            <!-- ══════════════════════════════════════════════════════
                 ROW 3 — Hardware Specs
                 ══════════════════════════════════════════════════════ -->
            <Grid Margin="2,6,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="HARDWARE" FontSize="9" FontWeight="Bold" Opacity="0.45"
                         Foreground="{DynamicResource NavCatFgBrush}" VerticalAlignment="Center"
/>
              <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                      Background="{DynamicResource NavCatFgBrush}" Opacity="0.15"/>
            </Grid>
            <Grid Margin="0,0,0,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="7"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="7"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="7"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="7"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- CPU Spec -->
              <Border Grid.Column="0"
                      Style="{StaticResource SpecCardStyle}"
                      Cursor="Hand" MouseLeftButtonUp="DashCpu_Click" ToolTip="Open Temp &amp; Stress">
                
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <StackPanel Margin="12,8,12,7">
                    <TextBlock Text="PROCESSOR" FontSize="9" FontWeight="Bold" Opacity="0.45"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"
/>
                    <TextBlock x:Name="TxtCpuDashSpec" Text="—" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap" Cursor="Hand"
                               MouseLeftButtonUp="DashCpuSpec_Search" ToolTip="Click to search online"/>
                    <TextBlock x:Name="TxtCpuCores" Text="" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    <TextBlock x:Name="TxtCpuCache" Text="" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0" Opacity="0.7"/>
                    <TextBlock x:Name="TxtDashCpuMaxMhz" Text="" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0" Opacity="0.7"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- GPU Spec -->
              <Border Grid.Column="2"
                      Style="{StaticResource SpecCardStyle}"
                      Cursor="Hand" MouseLeftButtonUp="DashCpu_Click" ToolTip="Open Temp &amp; Stress">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <StackPanel Margin="12,8,12,7">
                    <TextBlock Text="GRAPHICS" FontSize="9" FontWeight="Bold" Opacity="0.45"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"
/>
                    <TextBlock x:Name="TxtGpuDash" Text="—" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource ChartOrangeBrush}" TextWrapping="Wrap" Cursor="Hand"
                               MouseLeftButtonUp="DashGpuSpec_Search" ToolTip="Click to search online"/>
                    <TextBlock x:Name="TxtGpuVramSpec" Text="" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- RAM Spec -->
              <Border Grid.Column="4"
                      Style="{StaticResource SpecCardStyle}"
                      Cursor="Hand" MouseLeftButtonUp="DashRam_Click" ToolTip="Open RAM page">
                
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <StackPanel Margin="12,8,12,7">
                    <TextBlock Text="MEMORY" FontSize="9" FontWeight="Bold" Opacity="0.45"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"
/>
                    <TextBlock x:Name="TxtRamDash" Text="—" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource StatusSuccessBrush}"/>
                    <TextBlock x:Name="TxtRamTypeLabel" Text="" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Storage Spec -->
              <Border Grid.Column="6"
                      Style="{StaticResource SpecCardStyle}"
                      Cursor="Hand" MouseLeftButtonUp="DashStorage_Click" ToolTip="Open Storage page">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <StackPanel Margin="12,8,12,7">
                    <TextBlock Text="STORAGE" FontSize="9" FontWeight="Bold" Opacity="0.45"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"
/>
                    <TextBlock x:Name="TxtStorageDash" Text="—" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource NavPageAccentBrush}"/>
                    <TextBlock x:Name="TxtStorageSub" Text="" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"
                               TextWrapping="Wrap" Opacity="0.8"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Battery with health — click → Battery -->
              <Border Grid.Column="8"
                      Style="{StaticResource SpecCardStyle}"
                      Cursor="Hand" MouseLeftButtonUp="DashBattery_Click" ToolTip="Open Battery page">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <StackPanel Margin="12,8,12,7">
                  <TextBlock x:Name="TxtDashBatNetLabel" Text="BATTERY" FontSize="10" FontWeight="Bold" Opacity="0.45"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                  <!-- Charge -->
                  <TextBlock x:Name="TxtDashBatNetMain" Text="—" FontSize="18" FontWeight="Bold" Foreground="{StaticResource WarnAmberLightBrush}"/>
                  <!-- Hidden compat -->
                  <TextBlock x:Name="TxtDashBatHealth" Visibility="Collapsed" Text="—"/>
                  <TextBlock x:Name="TxtDashBatNetSub" Text="" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0" TextWrapping="Wrap" Opacity="0.8"/>
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 ROW 3b — System Info
                 ══════════════════════════════════════════════════════ -->
            <Grid Margin="2,6,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="SYSTEM" FontSize="9" FontWeight="Bold" Opacity="0.45"
                         Foreground="{DynamicResource NavCatFgBrush}" VerticalAlignment="Center"
/>
              <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                      Background="{DynamicResource NavCatFgBrush}" Opacity="0.15"/>
            </Grid>
            <Grid Margin="0,0,0,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="7"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="7"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="7"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="7"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- OS — entire card is clickable -->
              <Border Grid.Column="0" Style="{StaticResource SpecCardStyle}"
                      Cursor="Hand" MouseLeftButtonUp="DashOs_Search"
                      ToolTip="Click for detailed Windows information">
                <Grid>
                  <Grid.RowDefinitions><RowDefinition Height="*"/></Grid.RowDefinitions>
                  <StackPanel Margin="12,8,12,7">
                  <TextBlock Text="OPERATING SYSTEM" FontSize="10" FontWeight="Bold" Opacity="0.45"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                  <TextBlock x:Name="TxtOs" Text="—" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                  <TextBlock x:Name="TxtOsBuild" Text="" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                  <TextBlock x:Name="TxtDashArch" Text="" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0" Opacity="0.8"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Machine -->
              <Border Grid.Column="2" Style="{StaticResource SpecCardStyle}">
                
                <Grid>
                  <Grid.RowDefinitions><RowDefinition Height="*"/></Grid.RowDefinitions>
                  <StackPanel Margin="12,8,12,7">
                  <TextBlock Text="MACHINE" FontSize="10" FontWeight="Bold" Opacity="0.45"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                  <TextBlock x:Name="TxtMachine" Text="—" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"
                             Cursor="Hand" MouseLeftButtonUp="DashMachine_Search" ToolTip="Click to search online"/>
                  <TextBlock x:Name="TxtDashComputer" Text="" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                  <TextBlock x:Name="TxtDashBios" Text="" FontSize="10" Opacity="0.75"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"
                             ToolTip="BIOS/UEFI Version"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Display -->
              <Border Grid.Column="4" Style="{StaticResource SpecCardStyle}">
                
                <Grid>
                  <Grid.RowDefinitions><RowDefinition Height="*"/></Grid.RowDefinitions>
                  <StackPanel Margin="12,8,12,7">
                  <TextBlock Text="DISPLAY" FontSize="10" FontWeight="Bold" Opacity="0.45"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                  <TextBlock x:Name="TxtDashDisplay" Text="—" FontSize="12" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap"/>
                  <TextBlock x:Name="TxtDashDisplaySub" Text="" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0" Opacity="0.8"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Uptime -->
              <Border Grid.Column="6" Style="{StaticResource SpecCardStyle}">
                
                <Grid>
                  <Grid.RowDefinitions><RowDefinition Height="*"/></Grid.RowDefinitions>
                  <StackPanel Margin="12,8,12,7">
                  <TextBlock Text="UPTIME" FontSize="10" FontWeight="Bold" Opacity="0.45"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                  <TextBlock x:Name="TxtUptime" Text="—" FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Network Devices — Ethernet / Wi-Fi / Bluetooth status dots -->
              <Border Grid.Column="8" Style="{StaticResource SpecCardStyle}">

                <Grid>
                  <Grid.RowDefinitions><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel Margin="12,8,12,7">
                  <TextBlock Text="NETWORK" FontSize="10" FontWeight="Bold" Opacity="0.45"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                  <!-- Ethernet row -->
                  <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Viewbox x:Name="IcoEthernet" Width="14" Height="14" VerticalAlignment="Center" Stretch="Uniform">
                      <Canvas Width="24" Height="24">
                        <Path Fill="{DynamicResource AccentBrush}" Data="M21,3 H3 A2,2 0 0 0 1,5 V15 A2,2 0 0 0 3,17 H10 V19 H8 V21 H16 V19 H14 V17 H21 A2,2 0 0 0 23,15 V5 A2,2 0 0 0 21,3 Z"/>
                        <Ellipse x:Name="DotEthernet" Canvas.Left="4" Canvas.Top="7" Width="4" Height="4" Fill="{DynamicResource TextSecondaryBrush}"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Ethernet" Grid.Column="1" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    <TextBlock x:Name="TxtDashEthernetIp" Grid.Column="2" Text="" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Opacity="0.7"/>
                  </Grid>
                  <!-- Wi-Fi row -->
                  <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Viewbox x:Name="IcoWifi" Width="14" Height="14" VerticalAlignment="Center" Stretch="Uniform">
                      <Canvas Width="24" Height="24">
                        <Path x:Name="DotWifi" Fill="{DynamicResource TextSecondaryBrush}" Data="M12 5C7.31 5 3.07 6.9 0 9.97l2 2.01C4.52 9.37 8.11 7.5 12 7.5c3.89 0 7.48 1.87 10 4.48l2-2.01C21.93 6.9 17.69 5 12 5zm0 5c-3.35 0-6.37 1.39-8.54 3.62l1.99 1.98C7.07 13.87 9.42 12.5 12 12.5c2.58 0 4.93 1.37 6.55 3.1l1.99-1.98C18.37 11.39 15.35 10 12 10zm0 5c-1.81 0-3.44.77-4.6 2l1.99 2C10.19 18.38 11.06 18 12 18s1.81.38 2.61 1l1.99-2C15.44 15.77 13.81 15 12 15zm0 4.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Wi-Fi" Grid.Column="1" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    <TextBlock x:Name="TxtDashWifiSsid" Grid.Column="2" Text="" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Opacity="0.7"
                               MaxWidth="60" TextTrimming="CharacterEllipsis"/>
                  </Grid>
                  <!-- Bluetooth row -->
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Viewbox x:Name="IcoBluetooth" Width="14" Height="14" VerticalAlignment="Center" Stretch="Uniform">
                      <Canvas Width="24" Height="24">
                        <Path x:Name="DotBluetooth" Fill="{DynamicResource TextSecondaryBrush}" Data="M14.29 5.71l-4 4V3l4 4-4 4v6l4-4-4-4V3l4 4-4 4 4 4-4 4v-6l4-4zm-4 0l4 4-4-4zm0 14l4-4-4 4z"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Bluetooth" Grid.Column="1" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    <TextBlock x:Name="TxtDashBtDevices" Grid.Column="2" Text="" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Opacity="0.7"/>
                  </Grid>
                </StackPanel>
                </Grid>
              </Border>

              <!-- Hidden compat — kept for CS code references -->
              <TextBlock x:Name="TxtHealthScore" Visibility="Collapsed" Text="—"/>
              <TextBlock x:Name="TxtHealthLabel" Visibility="Collapsed" Text=""/>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 HEALTH SCORE — System Health 0-100  [HIDDEN TEMPORARILY]
                 ══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="HealthSectionWrapper" Visibility="Collapsed">
            <Grid Margin="2,6,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="SYSTEM HEALTH" FontSize="9" FontWeight="Bold" Opacity="0.45"
                         Foreground="{DynamicResource NavCatFgBrush}" VerticalAlignment="Center"/>
              <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                      Background="{DynamicResource NavCatFgBrush}" Opacity="0.15"/>
            </Grid>

            <Border x:Name="HealthScoreCard" Margin="0,0,0,10" Padding="16,14" CornerRadius="12" BorderThickness="1"
                    BorderBrush="{DynamicResource CardBorderBrush}" Background="{DynamicResource BgCardBrush}"
                    Cursor="Hand" MouseLeftButtonUp="HealthCard_Click" ToolTip="Click to run full diagnostics">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="16"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Score Circle -->
                <Grid Width="90" Height="90">
                  <!-- SVG ring via Canvas -->
                  <Canvas Width="90" Height="90">
                    <!-- Track ring -->
                    <Ellipse Canvas.Left="7" Canvas.Top="7" Width="76" Height="76"
                             Stroke="{DynamicResource BorderBrush2}" StrokeThickness="7"
                             Fill="Transparent"/>
                    <!-- Progress arc — drawn via code -->
                    <Path x:Name="HealthScoreArc"
                          Stroke="{DynamicResource ChartGreenBrush}" StrokeThickness="7"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent"/>
                  </Canvas>
                  <!-- Center text -->
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtHealthScoreCircle" Text="—"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="/100" FontSize="9" Opacity="0.45"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                </Grid>

                <!-- Right: Label + sub-scores -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                  <!-- Status label row -->
                  <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock x:Name="TxtHealthLabelCircle" Text="—"
                                 FontSize="18" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                      <TextBlock x:Name="TxtHealthSubtitle" Text="Calculating…"
                                 FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                 Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" x:Name="HealthBadge"
                            CornerRadius="6" Padding="8,3"
                            Background="{DynamicResource StatusOkBgBrush}"
                            BorderBrush="{DynamicResource StatusOkBrush}" BorderThickness="1"
                            VerticalAlignment="Center">
                      <TextBlock x:Name="TxtHealthBadge" Text="OK"
                                 FontSize="10" FontWeight="Bold"
                                 Foreground="{DynamicResource StatusOkBrush}"/>
                    </Border>
                  </Grid>

                  <!-- Sub-score bars: 5 metrici -->
                  <Grid x:Name="HealthSubScoreGrid">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="5"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="5"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="5"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="5"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- CPU Temp -->
                    <Grid Grid.Row="0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="CPU Temp" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      <Border Grid.Column="1" Height="4" CornerRadius="2" Margin="0,0,6,0"
                              Background="{DynamicResource BgHoverBrush}" VerticalAlignment="Center">
                        <Border x:Name="BarCpuTemp" HorizontalAlignment="Left" Height="4"
                                CornerRadius="2" Width="0"
                                Background="{DynamicResource ChartGreenBrush}"/>
                      </Border>
                      <TextBlock x:Name="TxtSubCpuTemp" Grid.Column="2" Text="—"
                                 FontSize="10" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- RAM -->
                    <Grid Grid.Row="2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="RAM" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      <Border Grid.Column="1" Height="4" CornerRadius="2" Margin="0,0,6,0"
                              Background="{DynamicResource BgHoverBrush}" VerticalAlignment="Center">
                        <Border x:Name="BarRam" HorizontalAlignment="Left" Height="4"
                                CornerRadius="2" Width="0"
                                Background="{DynamicResource ChartGreenBrush}"/>
                      </Border>
                      <TextBlock x:Name="TxtSubRam" Grid.Column="2" Text="—"
                                 FontSize="10" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Disk Health -->
                    <Grid Grid.Row="4">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Disk" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      <Border Grid.Column="1" Height="4" CornerRadius="2" Margin="0,0,6,0"
                              Background="{DynamicResource BgHoverBrush}" VerticalAlignment="Center">
                        <Border x:Name="BarDisk" HorizontalAlignment="Left" Height="4"
                                CornerRadius="2" Width="0"
                                Background="{DynamicResource ChartGreenBrush}"/>
                      </Border>
                      <TextBlock x:Name="TxtSubDisk" Grid.Column="2" Text="—"
                                 FontSize="10" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Battery -->
                    <Grid Grid.Row="6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Battery" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      <Border Grid.Column="1" Height="4" CornerRadius="2" Margin="0,0,6,0"
                              Background="{DynamicResource BgHoverBrush}" VerticalAlignment="Center">
                        <Border x:Name="BarBattery" HorizontalAlignment="Left" Height="4"
                                CornerRadius="2" Width="0"
                                Background="{DynamicResource ChartGreenBrush}"/>
                      </Border>
                      <TextBlock x:Name="TxtSubBattery" Grid.Column="2" Text="—"
                                 FontSize="10" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Stability -->
                    <Grid Grid.Row="8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Stability" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      <Border Grid.Column="1" Height="4" CornerRadius="2" Margin="0,0,6,0"
                              Background="{DynamicResource BgHoverBrush}" VerticalAlignment="Center">
                        <Border x:Name="BarStability" HorizontalAlignment="Left" Height="4"
                                CornerRadius="2" Width="0"
                                Background="{DynamicResource ChartGreenBrush}"/>
                      </Border>
                      <TextBlock x:Name="TxtSubStability" Grid.Column="2" Text="—"
                                 FontSize="10" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                  </Grid>
                </StackPanel>
              </Grid>
            </Border>
            </StackPanel><!-- /HealthSectionWrapper -->

            <!-- ══════════════════════════════════════════════════════
                 ROW 4 — Storage
                 ══════════════════════════════════════════════════════ -->
            <Grid Margin="2,6,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="STORAGE DRIVES" FontSize="9" FontWeight="Bold" Opacity="0.45"
                         Foreground="{DynamicResource NavCatFgBrush}" VerticalAlignment="Center"
/>
              <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                      Background="{DynamicResource NavCatFgBrush}" Opacity="0.15"/>
            </Grid>
            <Border Margin="0,0,0,4" Padding="12,8" CornerRadius="12" BorderThickness="1"
                    BorderBrush="{DynamicResource CardBorderBrush}" Background="{DynamicResource BgCardBrush}"
                    Cursor="Hand" MouseLeftButtonUp="DashStorage_Click" ToolTip="Open Storage page">
              <StackPanel>
                <!-- Storage summary header -->
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform"><Path Fill="{DynamicResource TextSecondaryBrush}" Data="M6 2h12a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2zm6 14a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM8 5v2h8V5H8z"/></Viewbox>
                  <TextBlock x:Name="TxtDashStorageSummary" Text="—" Grid.Column="1"
                             FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock x:Name="TxtDashStorageTotalFree" Text="" Grid.Column="2"
                             FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                  <TextBlock Text="/" Grid.Column="3" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.5"/>
                  <TextBlock x:Name="TxtDashStorageTotalSize" Text="" Grid.Column="3"
                             FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center" Margin="20,0,0,0" Opacity="0.6"/>
                </Grid>
                <DataGrid x:Name="DashStorageGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          MaxHeight="280" BorderThickness="0" GridLinesVisibility="None"
                          RowHeight="28" ColumnHeaderHeight="28" FontSize="11"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          MouseDoubleClick="DashStorageGrid_MouseDoubleClick"
                          MouseLeftButtonUp="DashStorageGrid_MouseLeftButtonUp"
                          Cursor="Hand" ToolTip="Double-click drive to open in Explorer"
                          Loaded="DashStorageGrid_Loaded">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Drive" Binding="{Binding DriveLetter}" Width="50"/>
                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="120"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding DriveType}" Width="60"/>
                    <DataGridTemplateColumn Header="Used" Width="*">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Grid VerticalAlignment="Center" Margin="2,0">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="42"/>
                              <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Procentaj text -->
                            <TextBlock Grid.Column="0" Text="{Binding UsedPctDisplay}" FontWeight="SemiBold"
                                       Foreground="{Binding UsedColor}" VerticalAlignment="Center"/>
                            <!-- Track + fill: Rectangle cu ScaleTransform proportional -->
                            <Border Grid.Column="1" Margin="4,0,8,0" VerticalAlignment="Center"
                                    Height="5" CornerRadius="4" Background="{DynamicResource BgInputBrush}"
                                    x:Name="StorageTrack">
                              <Border.Clip>
                                <RectangleGeometry RadiusX="3" RadiusY="3"
                                                   Rect="0,0,2000,5"/>
                              </Border.Clip>
                              <Rectangle Height="5" HorizontalAlignment="Left"
                                         Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}">
                                <Rectangle.RenderTransform>
                                  <ScaleTransform ScaleX="{Binding UsedRatio}" ScaleY="1"
                                                  CenterX="0" CenterY="0"/>
                                </Rectangle.RenderTransform>
                                <Rectangle.Style>
                                  <Style TargetType="Rectangle">
                                    <Setter Property="Fill">
                                      <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                          <GradientStop Color="{DynamicResource ChartGreenColor}" Offset="0"/>
                                          <GradientStop Color="{DynamicResource ChartGreenDimColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                      </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                        <Setter Property="Fill">
                                          <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                              <GradientStop Color="{DynamicResource ChartOrangeColor}" Offset="0"/>
                                              <GradientStop Color="{DynamicResource ActionRedColor}" Offset="1"/>
                                            </LinearGradientBrush>
                                          </Setter.Value>
                                        </Setter>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Rectangle.Style>
                              </Rectangle>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Free" Binding="{Binding FreeDisplay}" Width="70"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalDisplay}" Width="70"/>
                    <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="55"/>
                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="160"/>
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>

            <!-- Hidden compat labels -->
            <TextBlock x:Name="TxtQuickActionsLabel" Visibility="Collapsed"/>
            <TextBlock x:Name="TxtDashNetStatus" Visibility="Collapsed"/>
            <TextBlock x:Name="TxtDashNetIp" Visibility="Collapsed"/>

            <!-- Diagnostic Button -->
            <Border Margin="0,8,0,0" Padding="16,12" CornerRadius="12"
                    BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                    Background="{DynamicResource BgCardBrush}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Left: title -->
                <StackPanel VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Path Width="15" Height="15" Margin="0,0,8,0" Stretch="Uniform"
                          Fill="{DynamicResource AccentBrush}"
                          Data="M19.4 13c0-.3.1-.6.1-1s0-.7-.1-1l2.1-1.7c.2-.2.3-.4.1-.7l-2-3.5c-.1-.2-.4-.3-.6-.2l-2.5 1c-.5-.4-1.1-.8-1.8-1L14.3 3c0-.3-.3-.5-.5-.5h-4c-.2 0-.5.2-.5.5L9 5.9c-.7.2-1.3.6-1.8 1l-2.5-1c-.2-.1-.5 0-.6.2l-2 3.5c-.1.3 0 .5.2.7L4.6 12c0 .3-.1.6-.1 1s0 .7.1 1L2.4 15.7c-.2.2-.3.4-.1.7l2 3.5c.1.2.4.3.6.2l2.5-1c.5.4 1.1.8 1.8 1l.4 2.9c0 .2.3.5.5.5h4c.2 0 .5-.2.5-.5l.4-2.9c.7-.2 1.3-.6 1.8-1l2.5 1c.2.1.5 0 .6-.2l2-3.5c.2-.3 0-.5-.2-.7L19.4 13zM12 15.5a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7z"/>
                    <TextBlock x:Name="TxtDiagSectionTitle" Text="System Diagnostic"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                  </StackPanel>
                  <TextBlock x:Name="TxtDiagSubtitle"
                             Text="CPU · RAM · Disk · Temperatures · Network"
                             FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.8"/>
                </StackPanel>
                <!-- Right: Quick + Extended buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                  <Button x:Name="BtnDiagnoseReport"
                        ToolTip="Quick diagnostic: CPU, RAM, Disk, Battery, Network — ~2 minutes"
                          Style="{StaticResource OutlineButtonStyle}"
                          FontSize="12" FontWeight="SemiBold"
                          Padding="14,8" Margin="0,0,8,0"
                          Click="DiagnoseAndReport_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="13" Height="13" Margin="0,0,7,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M5,3 L19,12 L5,21 Z"/></Canvas></Viewbox>
                      <TextBlock Text="Run Diagnostic" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="BtnDiagnoseExtended"
                        ToolTip="Extended diagnostic: 3 min CPU+GPU stress load, then full benchmark — temperatures without disclaimer"
                          Style="{StaticResource OutlineButtonStyle}"
                          FontSize="12" FontWeight="SemiBold"
                          Padding="14,8"
                          Click="DiagnoseExtended_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="14" Height="14" Margin="0,0,7,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M9,3 L15,3 M12,3 L12,5 M4.0,13.0 A8.0,8.0 0 1 1 20.0,13.0 A8.0,8.0 0 1 1 4.0,13.0 Z M12,9 L12,13 L15,13"/></Canvas></Viewbox>
                      <TextBlock Text="Extended (~5 min)" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Grid>
            </Border>

          </StackPanel>
          </ScrollViewer>
        </Grid>

        <!-- ── STRESS & BENCHMARK ── -->
        <Grid x:Name="PanelStress" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title bar + KPI tiles -->
            <RowDefinition Height="*" MinHeight="160"/>  <!-- Row 1: CPU Temp | GPU Temp -->
            <RowDefinition Height="*" MinHeight="160"/>  <!-- Row 2: CPU Freq | GPU Load — equal height -->
            <RowDefinition Height="Auto"/>  <!-- stress buttons at bottom -->
          </Grid.RowDefinitions>

          <!-- ── Row 0: Title + KPI strip ── -->
          <Grid Grid.Row="0" Margin="16,10,16,8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>  <!-- title bar -->
              <RowDefinition Height="Auto"/>  <!-- KPI tiles -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                  <TextBlock x:Name="TxtStressTitle" Text="Temperatures &amp; Stress Test"
                           FontSize="18" FontWeight="Bold" FontFamily="{StaticResource AppFontDisplay}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
              </StackPanel>
              <!-- Right: time range + reset -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Range:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.7"/>
                <Button x:Name="BtnChartRange1m" Tag="60" Click="ChartTimeRange_Click"
                        Style="{StaticResource SubTabButtonActiveStyle}" Margin="0,0,2,0" Padding="10,5" FontSize="11">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="1m" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="BtnChartRange5m" Tag="300" Click="ChartTimeRange_Click"
                        Style="{StaticResource SubTabButtonStyle}" Margin="0,0,2,0" Padding="10,5" FontSize="11">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="5m" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="BtnChartRange15m" Tag="900" Click="ChartTimeRange_Click"
                        Style="{StaticResource SubTabButtonStyle}" Margin="0,0,2,0" Padding="10,5" FontSize="11">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="15m" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="BtnChartRange1h" Tag="3600" Click="ChartTimeRange_Click"
                        Style="{StaticResource SubTabButtonStyle}" Margin="0,0,10,0" Padding="10,5" FontSize="11">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="1h" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="BtnResetChart" Style="{StaticResource OutlineButtonStyle}"
                        Click="ResetChart_Click" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8M3 3v5h5"/></Canvas></Viewbox>
                    <TextBlock Text="Reset" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </Grid>

            <!-- KPI tiles — compact 6-column strip -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                 <ColumnDefinition Width="*"/>
                 <ColumnDefinition Width="*"/>
                 <ColumnDefinition Width="*"/>
                 <ColumnDefinition Width="*"/>
                 <ColumnDefinition Width="*"/>
                 <ColumnDefinition Width="*"/>
                 <ColumnDefinition Width="1.4*"/>
               </Grid.ColumnDefinitions>

              <!-- CPU Temp -->
              <Border Style="{StaticResource CardStyle}" Grid.Column="0" Margin="0,0,5,0" Padding="12,8">
                <StackPanel>
                  <TextBlock x:Name="LblKpiCpuTemp" Text="CPU TEMP" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                  <TextBlock x:Name="TxtStressCpuTemp" Text="--" FontSize="24" FontWeight="Black"
                             Foreground="{DynamicResource ChartGreenBrush}" LineHeight="28"/>
                  <TextBlock x:Name="TxtStressCpuMM" Text="—" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
              </Border>

              <!-- CPU Clock -->
              <Border Style="{StaticResource CardStyle}" Grid.Column="1" Margin="5,0,5,0" Padding="12,8">
                <StackPanel>
                  <TextBlock Text="CPU CLOCK" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                  <TextBlock x:Name="TxtCpuFreq" Text="--" FontSize="20" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}" LineHeight="24"/>
                  <TextBlock x:Name="TxtCpuLoad" Text="--" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBlock x:Name="TxtCpuFreqMM" Text="" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                </StackPanel>
              </Border>

              <!-- CPU Power -->
              <Border Style="{StaticResource CardStyle}" Grid.Column="2" Margin="5,0,5,0" Padding="12,8">
                <StackPanel>
                  <TextBlock Text="CPU POWER" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                  <TextBlock x:Name="TxtCpuPower" Text="--" FontSize="20" FontWeight="Bold"
                             Foreground="{DynamicResource StatusSuccessBrush}" LineHeight="24"/>
                  <TextBlock Text="Package" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBlock x:Name="TxtCpuPowerMM" Text="" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                </StackPanel>
              </Border>

              <!-- CPU VCore -->
              <Border x:Name="VCoreCard" Style="{StaticResource CardStyle}" Grid.Column="3" Margin="5,0,5,0" Padding="12,8">
                <StackPanel>
                  <TextBlock Text="CPU VCORE" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                  <TextBlock x:Name="TxtVCore" Text="—" FontSize="20" FontWeight="Bold"
                             Foreground="{DynamicResource ChartGreenBrush}" LineHeight="24"/>
                  <TextBlock Text="Voltage" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
              </Border>

              <!-- GPU Load -->
              <Border Style="{StaticResource CardStyle}" Grid.Column="4" Margin="5,0,5,0" Padding="12,8">
                <StackPanel>
                  <TextBlock Text="GPU LOAD" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                  <TextBlock x:Name="TxtKpiGpuLoad" Text="—%" FontSize="24" FontWeight="Black"
                             Foreground="{DynamicResource ChartOrangeBrush}" LineHeight="28"/>
                  <TextBlock x:Name="TxtStressGpuMM" Text="—" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBlock x:Name="TxtStressGpuTemp" Text="" Visibility="Collapsed"/>
                  <TextBlock x:Name="LblKpiGpuTemp" Text="" Visibility="Collapsed"/>
                </StackPanel>
              </Border>

              <!-- GPU Clock -->
              <Border Style="{StaticResource CardStyle}" Grid.Column="5" Margin="5,0,5,0" Padding="12,8">
                <StackPanel>
                  <TextBlock Text="GPU CLOCK" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                  <TextBlock x:Name="TxtGpuFreq" Text="--" FontSize="20" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}" LineHeight="24"/>
                  <TextBlock x:Name="TxtGpuLoad" Text="--" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBlock x:Name="TxtGpuFreqMM" Text="" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                </StackPanel>
              </Border>

              <!-- VRAM -->
              <Border x:Name="FanSpeedCard" Style="{StaticResource CardStyle}" Grid.Column="6" Margin="5,0,0,0" Padding="12,8">
                <StackPanel>
                  <TextBlock Text="VRAM" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/><ColumnDefinition Width="52"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="4" CornerRadius="2" Background="{DynamicResource BgInputBrush}" Margin="0,0,4,0" VerticalAlignment="Center">
                      <Border x:Name="StressVramBar" Height="4" CornerRadius="2"
                              Background="{DynamicResource ChartOrangeBrush}" HorizontalAlignment="Left" Width="0"/>
                    </Border>
                    <TextBlock x:Name="TxtGpuMemFreq" Grid.Column="1" Text="-- MB" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource ChartOrangeBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                  </Grid>
                  <TextBlock x:Name="TxtGpuVram" Text="-- MB used" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                  <!-- Hidden compat elements -->
                  <Border x:Name="StressRamBar" Height="0" Width="0" Visibility="Collapsed"/>
                  <TextBlock x:Name="TxtStressRamUsage" Visibility="Collapsed"/>
                  <!-- Throttle banner + backend label kept hidden for compat -->
                  <Border x:Name="ThrottleBanner" Visibility="Collapsed" CornerRadius="4"
                          Background="{DynamicResource ThrottleBannerBgBrush}"
                          BorderBrush="{DynamicResource ThrottleBannerBorderBrush}" BorderThickness="1"
                          Padding="7,3" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="⚡" FontSize="9" Foreground="{DynamicResource ThrottleBannerFgBrush}"/>
                      <TextBlock x:Name="TxtThrottleInfo" FontSize="9" FontWeight="SemiBold"
                                 Foreground="{DynamicResource ThrottleBannerFgBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                  <TextBlock x:Name="TxtTempBackend" Text="" FontSize="8"
                             Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,3,0,0" Opacity="0.6"/>
                </StackPanel>
              </Border>
            </Grid>
          </Grid>

          <!-- ── Row 1: CPU Temp | GPU Temp — dominant charts ── -->
          <Grid Grid.Row="1" Margin="16,0,16,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="10"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU Temp Chart -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="0" Padding="12,10">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Text="CPU Temperature" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="■ " FontSize="8" Foreground="{DynamicResource StatusInfoBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="&lt;40°  " FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="■ " FontSize="8" Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="40–70°  " FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="■ " FontSize="8" Foreground="{DynamicResource ChartOrangeBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="70–90°  " FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="■ " FontSize="8" Foreground="{DynamicResource StatusErrorBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="&gt;90°" FontSize="8" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                  </StackPanel>
                </Grid>
                <Canvas x:Name="CpuTempChart" Grid.Row="1" MinHeight="120" Background="Transparent"
                        SizeChanged="CpuTempChart_SizeChanged"
                        MouseMove="CpuTempChart_MouseMove"
                        MouseLeave="CpuTempChart_MouseLeave"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                  <TextBlock Text="Min " FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"/>
                  <TextBlock x:Name="TxtCpuTempMin" Text="—°" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource StatusSuccessBrush}" Margin="0,0,12,0"/>
                  <TextBlock Text="Max " FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"/>
                  <TextBlock x:Name="TxtCpuTempMax" Text="—°" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource StatusErrorBrush}" Margin="0,0,12,0"/>
                  <TextBlock Text="Avg " FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"/>
                  <TextBlock x:Name="TxtCpuTempAvg" Text="—°" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource StatusInfoBrush}"/>
                </StackPanel>
              </Grid>
            </Border>

            <!-- GPU Temp Chart -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="2" Padding="12,10">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Text="GPU Temperature" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock Grid.Column="1" x:Name="TxtGpuVramChart" Text="-- MB VRAM" FontSize="9"
                             Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Canvas x:Name="GpuTempChart" Grid.Row="1" MinHeight="120" Background="Transparent"
                        SizeChanged="GpuTempChart_SizeChanged"
                        MouseMove="GpuTempChart_MouseMove"
                        MouseLeave="GpuTempChart_MouseLeave"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                  <TextBlock Text="Min " FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"/>
                  <TextBlock x:Name="TxtGpuTempMinChart" Text="—°" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource StatusSuccessBrush}" Margin="0,0,12,0"/>
                  <TextBlock Text="Max " FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"/>
                  <TextBlock x:Name="TxtGpuTempMaxChart" Text="—°" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource StatusErrorBrush}" Margin="0,0,12,0"/>
                  <TextBlock Text="Avg " FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"/>
                  <TextBlock x:Name="TxtGpuTempAvgChart" Text="—°" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource ChartOrangeBrush}"/>
                </StackPanel>
              </Grid>
            </Border>
          </Grid>

          <!-- ── Row 2: CPU Freq (left) | GPU Load (right) — equal width ── -->
          <Grid Grid.Row="2" Margin="16,0,16,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="10"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU Frequency + Utilization — clean, no per-core bars -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="0" Padding="12,10">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>   <!-- header -->
                  <RowDefinition Height="*"/>      <!-- freq chart — equal star -->
                  <RowDefinition Height="Auto"/>   <!-- utilization header -->
                  <RowDefinition Height="*"/>      <!-- utilization chart — equal star -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CPU Frequency" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text=" — " FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" Margin="8,0,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ThrottleLed" Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center"
                             Fill="{DynamicResource StatusSuccessBrush}" ToolTip="CPU throttling status"/>
                    <TextBlock x:Name="TxtThrottleLedLabel" Text="No throttle" FontSize="9"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               ToolTip="Green = running at full speed · Red = thermal throttling detected"/>
                  </StackPanel>
                </Grid>

                <Canvas x:Name="CpuFreqChart" Grid.Row="1" Background="Transparent"
                        SizeChanged="CpuFreqChart_SizeChanged"
                        MouseMove="CpuFreqChart_MouseMove"
                        MouseLeave="CpuFreqChart_MouseLeave"/>

                <!-- Hidden compat — CoreFreqList still referenced by code-behind -->
                <ItemsControl x:Name="CoreFreqList" Visibility="Collapsed"/>

                <Grid Grid.Row="2" Margin="0,8,0,4">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Text="CPU Utilization" FontSize="10" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock x:Name="TxtCpuUsageLive" Grid.Column="1" Text="--%  " FontSize="10" FontWeight="Bold"
                             Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Canvas x:Name="CpuUsageChart" Grid.Row="3" Background="Transparent"
                        SizeChanged="CpuUsageChart_SizeChanged"
                        MouseMove="CpuUsageChart_MouseMove"
                        MouseLeave="CpuUsageChart_MouseLeave"/>
              </Grid>
            </Border>


            <!-- GPU Load — full card, chart fills height -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="2" Padding="12,10">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>  <!-- header -->
                  <RowDefinition Height="*"/>     <!-- full chart, no bottom strip -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="GPU Load" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text=" — " FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource ChartOrangeBrush}" Margin="8,0,0,0"/>
                  </StackPanel>
                  <TextBlock x:Name="TxtGpuLiveLoad" Grid.Column="1" Text="— %" FontSize="11" FontWeight="Bold"
                             Foreground="{DynamicResource ChartOrangeBrush}" VerticalAlignment="Center"/>
                </Grid>

                <!-- GPU Load chart — takes all remaining space -->
                <Canvas x:Name="GpuLoadChart" Grid.Row="1" Background="Transparent"
                        SizeChanged="GpuLoadChart_SizeChanged"
                        MouseMove="GpuLoadChart_MouseMove"
                        MouseLeave="GpuLoadChart_MouseLeave"/>

                <!-- Hidden compat stubs for code-behind -->
                <TextBlock x:Name="TxtGpuLiveTemp"  Visibility="Collapsed"/>
                <TextBlock x:Name="TxtGpuTempMax"   Visibility="Collapsed"/>
                <TextBlock x:Name="TxtGpuTempAvg"   Visibility="Collapsed"/>
                <TextBlock x:Name="TxtGpuTempMin"   Visibility="Collapsed"/>
                <TextBlock x:Name="TxtGpuLiveVram"  Visibility="Collapsed"/>
                <Border    x:Name="GpuVramBar"       Visibility="Collapsed" Height="0"/>
                <TextBlock x:Name="TxtGpuPowerLive" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtGpuFanLive"   Visibility="Collapsed"/>
                <Border    x:Name="GpuLoadBar"       Visibility="Collapsed" Height="0"/>
                <Border    x:Name="GpuTempBar"       Visibility="Collapsed" Height="0"/>
              </Grid>
            </Border>
          </Grid>

          <!-- ── Row 3: Stress buttons + Benchmark result at bottom ── -->
          <Grid Grid.Row="3" Margin="16,0,16,12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Stress / Benchmark / Turbo buttons -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="10"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="10"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="10"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnStressCpu" Grid.Column="0"
                        Style="{StaticResource OutlineButtonStyle}"
                        HorizontalAlignment="Stretch" Click="ToggleCpuStress_Click"
                        ToolTip="Stress test CPU — all cores at 100%">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M5,3 L19,12 L5,21 Z"/></Canvas></Viewbox>
                    <TextBlock x:Name="TxtBtnStressCpu" Text="CPU Stress" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Button x:Name="BtnStressGpu" Grid.Column="2"
                        Style="{StaticResource OutlineButtonStyle}"
                        HorizontalAlignment="Stretch" Click="ToggleGpuStress_Click"
                        ToolTip="Stress test GPU cu D3D11 compute shaders">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M5,3 L19,12 L5,21 Z"/></Canvas></Viewbox>
                    <TextBlock x:Name="TxtBtnStressGpu" Text="GPU Stress" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Button x:Name="BtnBench" Grid.Column="4"
                        Style="{StaticResource OutlineButtonStyle}"
                        HorizontalAlignment="Stretch" Click="RunBench_Click"
                        ToolTip="Benchmark multi-thread: SHA-256 + Mandelbrot + FFT (~12s)">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M13,2 L3,14 H12 L11,22 L21,10 H12 Z"/></Canvas></Viewbox>
                    <TextBlock Text="Benchmark" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Button x:Name="BtnTurbo" Grid.Column="6"
                        Style="{StaticResource OutlineButtonStyle}"
                        HorizontalAlignment="Stretch" Click="ToggleTurbo_Click"
                        ToolTip="Toggle Intel Turbo Boost / AMD Boost">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M13,2 L3,14 H12 L11,22 L21,10 H12 Z"/></Canvas></Viewbox>
                    <TextBlock x:Name="TxtBtnTurbo" Text="Turbo: ON" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <TextBlock x:Name="TxtCpuStressLabel" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtGpuStressLabel" Visibility="Collapsed"/>
              </Grid>
            </Border>

            <!-- Stress active banner — shown while CPU or GPU stress is running -->
            <Border x:Name="StressActiveBanner" Grid.Row="2" Visibility="Collapsed"
                    CornerRadius="8" Padding="14,8" Margin="0,6,0,0"
                    Background="{DynamicResource BgOverlayBrush}"
                    BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="16"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- CPU status -->
                <StackPanel x:Name="CpuStressBannerPanel" Grid.Column="0"
                            Orientation="Horizontal" Visibility="Collapsed">
                  <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Fill><SolidColorBrush x:Name="CpuStressDot" Color="#E24B4A"/></Ellipse.Fill>
                    <Ellipse.Triggers>
                      <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                          <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="CpuStressDot"
                                             Storyboard.TargetProperty="(SolidColorBrush.Opacity)"
                                             From="1" To="0.2" Duration="0:0:0.7" AutoReverse="True"/>
                          </Storyboard>
                        </BeginStoryboard>
                      </EventTrigger>
                    </Ellipse.Triggers>
                  </Ellipse>
                  <TextBlock Text="CPU Stress în progres…"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="TxtCpuStressBannerStats" Grid.Column="1"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <!-- Separator -->
                <Border Grid.Column="2" Width="1" Background="{DynamicResource CardBorderBrush}" Margin="0,2"/>
                <!-- GPU status -->
                <StackPanel x:Name="GpuStressBannerPanel" Grid.Column="3"
                            Orientation="Horizontal" Visibility="Collapsed" Margin="16,0,0,0">
                  <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Fill><SolidColorBrush x:Name="GpuStressDot" Color="#EF9F27"/></Ellipse.Fill>
                    <Ellipse.Triggers>
                      <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                          <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="GpuStressDot"
                                             Storyboard.TargetProperty="(SolidColorBrush.Opacity)"
                                             From="1" To="0.2" Duration="0:0:0.7" AutoReverse="True"
                                             BeginTime="0:0:0.35"/>
                          </Storyboard>
                        </BeginStoryboard>
                      </EventTrigger>
                    </Ellipse.Triggers>
                  </Ellipse>
                  <TextBlock Text="GPU Stress în progres…"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="TxtGpuStressBannerStats" Grid.Column="4"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
              </Grid>
            </Border>
            <Border x:Name="BenchResultPanel" Grid.Row="1" Visibility="Collapsed"
                    Style="{StaticResource CardStyle}" Margin="0,8,0,0" Padding="16,12">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="8"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="10"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="CPU Benchmark Result" FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock x:Name="TxtBenchResult" Grid.Column="1"
                             FontSize="13" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}"
                             HorizontalAlignment="Right"/>
                </Grid>
                <Border Grid.Row="2" Height="8" CornerRadius="4"
                        Background="{DynamicResource BgInputBrush}">
                  <Border HorizontalAlignment="Left" CornerRadius="4" Height="8" MinWidth="4">
                    <Border x:Name="BenchScoreBar" CornerRadius="4" Height="8"
                            Background="{DynamicResource AccentBrush}" MinWidth="4"/>
                  </Border>
                </Border>
                <StackPanel Grid.Row="4" Orientation="Horizontal">
                  <TextBlock x:Name="TxtBenchPct"
                             FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                             Margin="0,0,12,0"/>
                  <TextBlock Text="Hover the score for technical details"
                             FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                             Opacity="0.6"/>
                </StackPanel>
              </Grid>
            </Border>
          </Grid>

          <!-- Hidden compat stubs for code-behind -->
          <StackPanel Visibility="Collapsed">
            <StackPanel x:Name="GpuStressRunPanel"/>
            <TextBlock x:Name="TxtGpuStressLoad"/>
            <TextBlock x:Name="TxtGpuStressTemp"/>
            <TextBlock x:Name="TxtGpuStressVram"/>
            <TextBlock x:Name="TxtGpuStressFps"/>
            <TextBlock x:Name="GpuStressIdlePlaceholder"/>
            <TextBlock x:Name="TxtGpuStressInfo"/>
            <TextBlock x:Name="TxtGpuStressStatus"/>
            <TextBlock x:Name="TxtGpuPower"/>
            <TextBlock x:Name="TxtGpuPowerMM"/>
            <TextBlock x:Name="TxtGpuPowerLabel"/>
            <Canvas x:Name="GpuStressChart" Height="0" SizeChanged="GpuStressChart_SizeChanged"/>
          </StackPanel>

        </Grid>

        <!-- ── EVENT VIEWER ── -->
        <Grid x:Name="PanelEvents" Visibility="Collapsed" Margin="24" Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="TxtEventsTitle" Grid.Row="0" Text="Event Viewer"
                     Style="{StaticResource SectionTitleStyle}"/>
          </StackPanel>
          <!-- Recent Events summary (moved from Dashboard) -->
          <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="0">
            <StackPanel>
              <TextBlock x:Name="TxtRecentEventsLabel" Text="Recent Events — Errors &amp; Warnings"
                         FontSize="13" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" Margin="12,10,12,6"/>
              <DataGrid x:Name="DashEventsGrid" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="110">
                <DataGrid.Columns>
                  <DataGridTextColumn x:Name="ColDashTime" Header="Time" Binding="{Binding TimeCreated, StringFormat=\{0:dd.MM HH:mm:ss\}}" Width="130"/>
                  <DataGridTemplateColumn x:Name="ColDashLevel" Header="Level" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Level}" Foreground="{Binding LevelColor}"
                                   FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn x:Name="ColDashSource" Header="Source" Binding="{Binding Source}" Width="180"/>
                  <DataGridTextColumn x:Name="ColDashEventId" Header="EventID" Binding="{Binding EventId}" Width="65"/>
                  <DataGridTextColumn x:Name="ColDashMsg" Header="Message" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
          <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14,10">
            <WrapPanel VerticalAlignment="Center">
              <!-- Quick time range buttons -->
              <Button x:Name="BtnEvt1h" Tag="1h" Click="EventTimeRange_Click"
                      Style="{StaticResource SubTabButtonStyle}" Margin="0,0,2,4" Padding="10,5"
                      ToolTip="Last 1 hour">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="1h" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnEvt6h" Tag="6h" Click="EventTimeRange_Click"
                      Style="{StaticResource SubTabButtonStyle}" Margin="0,0,2,4" Padding="10,5"
                      ToolTip="Last 6 hours">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="6h" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnEvt24h" Tag="24h" Click="EventTimeRange_Click"
                      Style="{StaticResource SubTabButtonActiveStyle}" Margin="0,0,2,4" Padding="10,5"
                      ToolTip="Last 24 hours">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="24h" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnEvt7d" Tag="7d" Click="EventTimeRange_Click"
                      Style="{StaticResource SubTabButtonStyle}" Margin="0,0,2,4" Padding="10,5"
                      ToolTip="Last 7 days">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="7d" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnEvt30d" Tag="30d" Click="EventTimeRange_Click"
                      Style="{StaticResource SubTabButtonStyle}" Margin="0,0,12,4" Padding="10,5"
                      ToolTip="Last 30 days">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="30d" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <!-- Level filter — toggle buttons (one click) -->
              <TextBlock x:Name="TxtLevelLabel" Text="Level:" VerticalAlignment="Center" Margin="0,0,6,0"
                         Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
              <Button x:Name="BtnLevelAll" Tag="All" Click="EventLevel_Click"
                      Style="{StaticResource SubTabButtonActiveStyle}" Margin="0,0,2,4" Padding="10,5"
                      ToolTip="Show all event levels">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M8,6 H21 M8,12 H21 M8,18 H21 M3,6 H3.01 M3,12 H3.01 M3,18 H3.01"/></Canvas></Viewbox><TextBlock Text="All" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnLevelCritical" Tag="Critical" Click="EventLevel_Click"
                      Style="{StaticResource SubTabButtonStyle}" Margin="0,0,2,4" Padding="10,5"
                      ToolTip="Show only Critical events">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,9 V11 M12,15 H12.01 M10.29,3.86 L1.82,18 A2,2 0 0 0 3.64,21 H20.36 A2,2 0 0 0 22.18,18 L13.71,3.86 A2,2 0 0 0 10.29,3.86 Z"/></Canvas></Viewbox><TextBlock Text="Critical" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnLevelError" Tag="Error" Click="EventLevel_Click"
                      Style="{StaticResource SubTabButtonStyle}" Margin="0,0,2,4" Padding="10,5"
                      ToolTip="Show only Error events">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M18,6 L6,18 M6,6 L18,18"/></Canvas></Viewbox><TextBlock Text="Error" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnLevelWarning" Tag="Warning" Click="EventLevel_Click"
                      Style="{StaticResource SubTabButtonStyle}" Margin="0,0,2,4" Padding="10,5"
                      ToolTip="Show only Warning events">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,9 V11 M12,15 H12.01 M10.29,3.86 L1.82,18 A2,2 0 0 0 3.64,21 H20.36 A2,2 0 0 0 22.18,18 L13.71,3.86 A2,2 0 0 0 10.29,3.86 Z"/></Canvas></Viewbox><TextBlock Text="Warning" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnLevelErrWarn" Tag="Errors &amp; Warnings" Click="EventLevel_Click"
                      Style="{StaticResource SubTabButtonStyle}" Margin="0,0,10,4" Padding="10,5"
                      ToolTip="Show Errors and Warnings">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,3 H2 L10,12.46 V19 L14,21 V12.46 Z"/></Canvas></Viewbox><TextBlock Text="Err+Warn" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <TextBox x:Name="TxtSearch" Width="160" Margin="0,0,10,0" VerticalAlignment="Center"
                       ToolTip="Filter by keyword"/>
              <Button x:Name="BtnScanEvents"
                      Style="{StaticResource OutlineButtonStyle}" Click="ScanEvents_Click" Margin="0,0,6,4"
                      ToolTip="Scan the Windows Event Log with the current filters and time range">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M3,11 A8,8 0 1 1 19,11 A8,8 0 1 1 3,11 Z"/></Canvas></Viewbox>
                  <TextBlock Text="Scan" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="BtnExportEvents"
                      Style="{StaticResource OutlineButtonStyle}" Click="ExportEvents_Click"
                      ToolTip="Export filtered events to a CSV file">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M12,15 L12,3 M7,10 L12,15 L17,10"/></Canvas></Viewbox>
                  <TextBlock Text="Export CSV" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </WrapPanel>
          </Border>
          <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="EventsGrid" CanUserResizeColumns="True" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserSortColumns="True" SelectionChanged="EventsGrid_SelectionChanged">
              <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColEvTime" Header="Data / Ora"
                                    Binding="{Binding TimeCreated, StringFormat=\{0:dd.MM.yyyy HH:mm:ss\}}" Width="155"/>
                <DataGridTemplateColumn x:Name="ColEvLevel" Header="Nivel" Width="90">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Level}" Foreground="{Binding LevelColor}"
                                 FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn x:Name="ColEvLog" Header="Log" Binding="{Binding LogName}" Width="80"/>
                <DataGridTextColumn x:Name="ColEvSource" Header="Source" Binding="{Binding Source}" Width="170"/>
                <DataGridTextColumn x:Name="ColEvId" Header="EventID" Binding="{Binding EventId}" Width="70"/>
                <DataGridTextColumn x:Name="ColEvMsg" Header="Mesaj" Binding="{Binding Message}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
          <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,8,0,0" MaxHeight="175"
                  x:Name="EventDetailPanel" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <TextBlock x:Name="TxtEventDetail" FontSize="11" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
            </ScrollViewer>
          </Border>
        </Grid>

        <!-- ── CRASH / BSOD ── -->
        <Grid x:Name="PanelCrash" Visibility="Collapsed" Margin="24" Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock x:Name="TxtCrashTitle" Grid.Row="0" Text="BSOD / Crash Dumps"
                     Style="{StaticResource SectionTitleStyle}"/>
          <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <Button x:Name="BtnReloadCrashes"
                    Style="{StaticResource OutlineButtonStyle}" Click="LoadCrashes_Click" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></Canvas></Viewbox>
                <TextBlock Text="Reload" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="BtnOpenMiniDump"
                    Style="{StaticResource OutlineButtonStyle}" 
                    Click="OpenMiniDumpFolder_Click" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></Canvas></Viewbox>
                <TextBlock Text="Open Minidump Folder" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="BtnWinDbg"
                    Style="{StaticResource OutlineButtonStyle}" Click="OpenWinDbg_Click">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></Canvas></Viewbox>
                <TextBlock Text="Analyze with WinDbg" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </WrapPanel>
          <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="CrashGrid" CanUserResizeColumns="True" AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Data Crash"
                                    Binding="{Binding CrashTime, StringFormat=\{0:dd.MM.yyyy HH:mm:ss\}}" Width="160"/>
                <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="160"/>
                <DataGridTextColumn Header="Stop Code" Binding="{Binding StopCode}" Width="160"/>
                <DataGridTextColumn Header="Modul / Detalii" Binding="{Binding FaultingModule}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </Grid>

        <!-- ── DRIVERS ── -->
        <Grid x:Name="PanelDrivers" Visibility="Collapsed" Margin="24"
              Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: titlu + butoane acțiune -->
            <RowDefinition Height="Auto"/>   <!-- 1: bara protecție auto-update -->
            <RowDefinition Height="Auto"/>   <!-- 2: toolbar filtre + căutare -->
            <RowDefinition Height="*"/>      <!-- 3: conținut principal (listă + card) -->
          </Grid.RowDefinitions>

          <!-- ═══ ROW 0 – Titlu + butoane principale ═══════════════════════════════ -->
          <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TxtDriversTitle" Grid.Column="0"
                       Text="Drivers" Style="{StaticResource SectionTitleStyle}"/>

            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
              <!-- Modul simplu / avansat — UnderlineChipStyle RadioButton -->
              <RadioButton x:Name="BtnDriverModeBasic"
                      GroupName="DriverModeGroup"
                      Style="{StaticResource UnderlineChipStyle}"
                      Checked="DriverMode_Click" Tag="Basic"
                      Margin="0,0,4,0" IsChecked="True"
                      ToolTip="Vizualizare simplificată pe categorii">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3,5 A1,1 0 0 1 4,4 H20 A1,1 0 0 1 21,5 V10 A1,1 0 0 1 20,11 H4 A1,1 0 0 1 3,10 Z M3,15 A1,1 0 0 1 4,14 H20 A1,1 0 0 1 21,15 V20 A1,1 0 0 1 20,21 H4 A1,1 0 0 1 3,20 Z"/></Canvas></Viewbox>
                  <TextBlock Text="Basic" VerticalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
              <RadioButton x:Name="BtnDriverModeAdvanced"
                      GroupName="DriverModeGroup"
                      Style="{StaticResource UnderlineChipStyle}"
                      Checked="DriverMode_Click" Tag="Advanced"
                      Margin="0,0,6,0"
                      ToolTip="Toate fișierele .sys instalate">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M14,2 H6 A2,2 0 0 0 4,4 V20 A2,2 0 0 0 6,22 H18 A2,2 0 0 0 20,20 V8 Z M14,2 V8 H20"/></Canvas></Viewbox>
                  <TextBlock Text="Advanced" VerticalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
              <Button x:Name="BtnDeviceManager" 
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="OpenDeviceManager_Click"
                      Margin="0,0,6,0" Padding="12,5" Height="30"
                      ToolTip="Deschide Windows Device Manager">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M4,6 A2,2 0 0 1 6,4 H18 A2,2 0 0 1 20,6 V18 A2,2 0 0 1 18,20 H6 A2,2 0 0 1 4,18 Z M8,7 H16 M8,12 H16 M8,17 H13"/></Canvas></Viewbox><TextBlock Text="⊞ DevMgr" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnDriverScan" 
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="DriverScan_Click"
                      Margin="0,0,6,0" Padding="12,5" Height="30"
                      ToolTip="Rescansează toate dispozitivele și driverele">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M3,11 A8,8 0 1 1 19,11 A8,8 0 1 1 3,11 Z"/></Canvas></Viewbox><TextBlock Text="Scan" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnDriverExportCsv" 
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="ExportDriversCsv_Click"
                      Margin="0,0,0,0" Padding="12,5" Height="30"
                      ToolTip="Export driver list to CSV (Ctrl+E)">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,15 V19 A2,2 0 0 1 19,21 H5 A2,2 0 0 1 3,19 V15 M17,8 L12,3 L7,8 M12,3 V15"/></Canvas></Viewbox><TextBlock Text="CSV" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            </WrapPanel>
          </Grid>

          <!-- ═══ ROW 1 – Bara protecție auto-update (păstrată din original) ═══════ -->
          <Border Grid.Row="1" Style="{StaticResource CardStyle}"
                  Padding="10,8" Margin="0,0,0,10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Ellipse x:Name="LedBlockStatus" Width="10" Height="10" Fill="{DynamicResource StatusSuccessBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse.Effect>
                  <DropShadowEffect Color="{DynamicResource ChartGreenColor}" BlurRadius="6" ShadowDepth="0"
                                    Opacity="0.7" RenderingBias="Performance"/>
                </Ellipse.Effect>
              </Ellipse>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Driver Protection: " FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtGlobalBlockStatus" Text="Auto-update ON" FontSize="11"
                           FontWeight="SemiBold" Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center"/>
                <TextBlock Text=" · " FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock x:Name="TxtBlockedCount" Text="0 devices blocate" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <Button x:Name="BtnBlockGpuDriver" Grid.Column="2" 
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="BlockGpuDriver_Click" Margin="0,0,6,0" Padding="10,4" Height="30"
                      ToolTip="Blochează driverul GPU curent de la Windows Update">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,22 C12,22 3,18 3,12 V5 L12,2 L21,5 V12 C21,18 12,22 12,22 Z M9,9 L15,15 M15,9 L9,15"/></Canvas></Viewbox><TextBlock Text="GPU" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnBlockCustomDriver" Grid.Column="3" 
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="BlockCustomDriver_Click" Margin="0,0,6,0" Padding="10,4" Height="30"
                      ToolTip="Alege un device specific de protejat">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,22 C12,22 3,18 3,12 V5 L12,2 L21,5 V12 C21,18 12,22 12,22 Z M12,8 V12 M12,16 H12.01"/></Canvas></Viewbox><TextBlock Text="+ Blochează Device" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnToggleGlobalBlock" Grid.Column="4"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="ToggleGlobalDriverBlock_Click" Padding="10,4" Height="30"
                      ToolTip="Blochează global Windows Update de la instalarea driverelor"/>
            </Grid>
          </Border>

          <!-- Blocked devices list (collapsed by default) -->
          <Border x:Name="BlockedDevicesCard" Grid.Row="1" Style="{StaticResource CardStyle}"
                  Padding="10,8" Margin="0,-6,0,10" Visibility="Collapsed">
            <StackPanel>
              <ItemsControl x:Name="BlockedDevicesList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource BgInputBrush}" CornerRadius="8"
                            Padding="10,6" Margin="0,2">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="" FontSize="11" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                          <TextBlock Text="{Binding DeviceName}" FontSize="11" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                          <TextBlock Text="{Binding HardwareId}" FontSize="9"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Style="{StaticResource OutlineButtonStyle}"
                                Tag="{Binding Index}"
                                Click="UnblockDriver_Click"
                                Padding="8,4" Height="26" FontSize="10"
                                ToolTip="Permite din nou auto-update">
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="11" Height="11" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M8 11V7a4 4 0 0 1 8 0v4M5 11h14a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2z"/></Canvas></Viewbox>
                            <TextBlock Text="Unblock" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock x:Name="TxtNoBlockedDrivers"
                         Text="Niciun driver blocat momentan."
                         FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                         Opacity="0.6" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>

          <!-- ═══ ROW 2 – Toolbar filtre + căutare ═══════════════════════════════════ -->
          <!-- Basic mode toolbar -->
          <Grid x:Name="DriversBasicToolbar" Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filtre rapide -->
            <Button x:Name="BtnDriverBasicAll" Grid.Column="0" 
                    Style="{StaticResource SubTabButtonActiveStyle}"
                    Click="DriverBasicFilter_Click" Tag="All"
                    Margin="0,0,6,0" Padding="12,5" Height="30">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M8,6 H21 M8,12 H21 M8,18 H21 M3,6 H3.01 M3,12 H3.01 M3,18 H3.01"/></Canvas></Viewbox><TextBlock Text="Toate" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            <Button x:Name="BtnDriverBasicMissing" Grid.Column="1" 
                    Style="{StaticResource OutlineButtonStyle}"
                    Click="DriverBasicFilter_Click" Tag="Missing"
                    Margin="0,0,6,0" Padding="12,5" Height="30"
                    ToolTip="Drivere cu erori sau nesemnate">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,3 H2 L10,12.46 V19 L14,21 V12.46 Z"/></Canvas></Viewbox><TextBlock Text="Probleme" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            <Button x:Name="BtnDriverBasicOld" Grid.Column="2" 
                    Style="{StaticResource OutlineButtonStyle}"
                    Click="DriverBasicFilter_Click" Tag="NotInstalled"
                    Margin="0,0,6,0" Padding="12,5" Height="30"
                    ToolTip="Dispozitive fără driver instalat">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,3 H2 L10,12.46 V19 L14,21 V12.46 Z"/></Canvas></Viewbox><TextBlock Text="Neinstalate" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            <Button x:Name="BtnDriverBasicUnsigned" Grid.Column="3" 
                    Style="{StaticResource OutlineButtonStyle}"
                    Click="DriverBasicFilter_Click" Tag="Unsigned"
                    Margin="0,0,6,0" Padding="12,5" Height="30"
                    ToolTip="Drivere fără semnătură digitală">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,22 C12,22 3,18 3,12 V5 L12,2 L21,5 V12 C21,18 12,22 12,22 Z M9,9 L15,15 M15,9 L9,15"/></Canvas></Viewbox><TextBlock Text="Nesemnate" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            <Button x:Name="BtnDriverBasicImportant" Grid.Column="4" 
                    Style="{StaticResource OutlineButtonStyle}"
                    Click="DriverBasicFilter_Click" Tag="Important"
                    Margin="0,0,12,0" Padding="12,5" Height="30"
                    ToolTip="Grafică, Audio, Rețea, Bluetooth">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,3 H2 L10,12.46 V19 L14,21 V12.46 Z"/></Canvas></Viewbox><TextBlock Text="Importante" VerticalAlignment="Center"/></StackPanel>
                    </Button>

            <!-- Căutare cu placeholder real -->
            <Grid Grid.Column="5" HorizontalAlignment="Stretch">
              <TextBox x:Name="TxtDriverSearch"
                       Height="30" Padding="28,0,8,0" VerticalContentAlignment="Center"
                       FontSize="12" MinWidth="200" HorizontalAlignment="Stretch"
                       TextChanged="DriverSearch_TextChanged"
                       ToolTip="Caută după nume, furnizor sau Device ID"/>
              <TextBlock IsHitTestVisible="False" Text="Caută driver..."
                         VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Text, ElementName=TxtDriverSearch}" Value="">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Grid>

            <!-- Contor rezultate -->
            <TextBlock x:Name="TxtDriverCount" Grid.Column="6"
                       VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="10,0,0,0"/>
          </Grid>

          <!-- Advanced mode toolbar (păstrat din original) -->
          <WrapPanel x:Name="DriversAdvancedToolbar" Grid.Row="2"
                     Margin="0,0,0,10" Visibility="Collapsed">
            <Button x:Name="BtnAllDrivers" 
                    Style="{StaticResource SubTabButtonActiveStyle}"
                    Click="LoadAllDrivers_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M8,6 H21 M8,12 H21 M8,18 H21 M3,6 H3.01 M3,12 H3.01 M3,18 H3.01"/></Canvas></Viewbox><TextBlock Text="Toate Driverele" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            <Button x:Name="BtnUnsignedDrivers" 
                    Style="{StaticResource OutlineButtonStyle}"
                    Click="LoadUnsignedDrivers_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,3 H2 L10,12.46 V19 L14,21 V12.46 Z"/></Canvas></Viewbox><TextBlock Text="Nesemnate" VerticalAlignment="Center"/></StackPanel>
                    </Button>
          </WrapPanel>

          <!-- ═══ ROW 3 – Conținut principal ══════════════════════════════════════════ -->
          <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
              <!-- Stânga: lista de drivere -->
              <ColumnDefinition Width="*" MinWidth="320"/>
              <!-- Dreapta: card detalii (ascuns implicit) -->
              <ColumnDefinition x:Name="DriverDetailColumn" Width="0" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- ── BASIC VIEW: Lista simplificată pe categorii ──────────────────────── -->
            <Border x:Name="DriversBasicPanel" Grid.Column="0"
                    Style="{StaticResource CardStyle}" Padding="0">
              <ScrollViewer VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="DriversBasicList"/>
              </ScrollViewer>
            </Border>

            <!-- ── ADVANCED VIEW: DataGrid original ────────────────────────────────── -->
            <Border x:Name="DriversAdvancedPanel" Grid.Column="0"
                    Style="{StaticResource CardStyle}" Padding="0"
                    Visibility="Collapsed">
              <DataGrid x:Name="DriversGrid" CanUserResizeColumns="True" AutoGenerateColumns="False"
                        IsReadOnly="True" CanUserSortColumns="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Device" Binding="{Binding DisplayName}" Width="*"/>
                  <DataGridTextColumn Header="Versiune" Binding="{Binding Version}" Width="110"/>
                  <DataGridTextColumn Header="Furnizor" Binding="{Binding Provider}" Width="150"/>
                  <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="95"/>
                  <DataGridTemplateColumn Header="Semnat" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding SignedText}"
                                   Foreground="{Binding SignedColor}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Border>

            <!-- ── CARD DETALII DRIVER (dreapta, apare la selectare) ─────────────── -->
            <Border x:Name="DriverDetailCard" Grid.Column="1"
                    Style="{StaticResource CardStyle}"
                    Margin="12,0,0,0" Padding="0"
                    Visibility="Collapsed">
              <ScrollViewer VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16">

                  <!-- Header card: icon + nume + buton închide -->
                  <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon categorie -->
                    <Border Grid.Column="0"
                            Width="44" Height="44" CornerRadius="10"
                            Background="{DynamicResource BgInputBrush}"
                            Margin="0,0,10,0">
                      <TextBlock x:Name="TxtDetailIcon"
                                 Text="" FontSize="22"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>

                    <!-- Nume device -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock x:Name="TxtDetailName"
                                 Text="—" FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextWrapping="Wrap"/>
                      <TextBlock x:Name="TxtDetailCategory"
                                 Text="—" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Buton închide -->
                    <Button Grid.Column="2"
                            Content="" Width="26" Height="26"
                            Style="{StaticResource OutlineButtonStyle}"
                            FontSize="11" Padding="0"
                            Click="DriverDetailClose_Click"
                            ToolTip="Închide panoul de detalii"
                            VerticalAlignment="Top"/>
                  </Grid>

                  <!-- ── LED Status (roșu/galben/verde după vârstă + stare) ── -->
                  <Border CornerRadius="8" Padding="10,8" Margin="0,0,0,14"
                          x:Name="DetailStatusBanner"
                          Background="{DynamicResource BgInputBrush}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Ellipse x:Name="DetailLed"
                               Width="12" Height="12" Fill="{DynamicResource StatusSuccessBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Effect>
                          <DropShadowEffect x:Name="DetailLedGlow"
                                            Color="{DynamicResource ChartGreenColor}" BlurRadius="8"
                                            ShadowDepth="0" Opacity="0.8"
                                            RenderingBias="Performance"/>
                        </Ellipse.Effect>
                      </Ellipse>
                      <TextBlock x:Name="TxtDetailStatusMsg"
                                 Grid.Column="1"
                                 Text="Driver OK" FontSize="11" FontWeight="SemiBold"
                                 Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center"/>
                    </Grid>
                  </Border>

                  <!-- ── Informații principale ── -->
                  <TextBlock Text="INFORMAȚII" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             Margin="0,0,0,6"/>

                  <!-- Versiune -->
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Versiune" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDetailVersion" Grid.Column="1"
                               Text="—" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                  </Grid>

                  <!-- Furnizor -->
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Furnizor" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDetailProvider" Grid.Column="1"
                               Text="—" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                  </Grid>

                  <!-- Data driverului -->
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Data driver" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="TxtDetailDate"
                                 Text="—" FontSize="11"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalAlignment="Center"/>
                      <!-- Vârsta driverului în zile -->
                      <Border x:Name="DetailAgeBadge"
                              CornerRadius="4" Padding="5,1"
                              Margin="6,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtDetailAge"
                                   Text="" FontSize="9" FontWeight="SemiBold"/>
                      </Border>
                    </StackPanel>
                  </Grid>

                  <!-- Status -->
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Status" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDetailStatus" Grid.Column="1"
                               Text="—" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                  </Grid>

                  <!-- Semnat digital -->
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Semnat digital" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDetailSigned" Grid.Column="1"
                               Text="—" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                  </Grid>

                  <!-- Device ID + buton Copy -->
                  <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Device ID" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDetailHwId" Grid.Column="1"
                               Text="—" FontSize="9"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="2"
                            Content="" Width="26" Height="26"
                            Style="{StaticResource OutlineButtonStyle}"
                            FontSize="11" Padding="0"
                            Click="CopyDeviceId_Click"
                            ToolTip="Copiază Device ID în clipboard"
                            Margin="4,0,0,0" VerticalAlignment="Top"/>
                  </Grid>

                  <!-- Separator -->
                  <Border Height="1"
                          Background="{DynamicResource BorderBrush2}"
                          Margin="0,12,0,12" Opacity="0.4"/>

                  <!-- ── Profil energie + consum estimat ── -->
                  <TextBlock Text="ENERGIE" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             Margin="0,0,0,8"/>

                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Profil energie" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDetailPowerProfile" Grid.Column="1"
                               Text="Normal" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                  </Grid>

                  <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Consum estimat" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDetailPowerEst" Grid.Column="1"
                               Text="—" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                  </Grid>

                  <!-- Separator -->
                  <Border Height="1"
                          Background="{DynamicResource BorderBrush2}"
                          Margin="0,0,0,12" Opacity="0.4"/>

                  <!-- ── Acțiuni rapide ── -->
                  <TextBlock Text="ACȚIUNI" FontSize="9" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             Margin="0,0,0,10"/>

                  <!-- Backup + Repair -->
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="6"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnDetailBackup" Grid.Column="0"
                            Style="{StaticResource OutlineButtonStyle}"
                            Height="32" FontSize="11"
                            Click="DetailBackup_Click"
                            ToolTip="Exportă driverul curent ca backup">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,15 V19 A2,2 0 0 1 19,21 H5 A2,2 0 0 1 3,19 V15 M17,8 L12,3 L7,8 M12,3 V15"/></Canvas></Viewbox><TextBlock Text="Backup" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="BtnDetailRepair" Grid.Column="2"
                            Style="{StaticResource OutlineButtonStyle}"
                            Height="32" FontSize="11"
                            Click="DetailRepair_Click"
                            ToolTip="Deschide Device Manager pentru reinstalare driver">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M14.7,6.3 A1,1 0 0 0 13,6 A4,4 0 0 0 8.07,9.77 L3,15 A2,2 0 0 0 5,19 A2,2 0 0 0 9,17 L15,11 A4,4 0 0 0 17.7,6.3 Z"/></Canvas></Viewbox><TextBlock Text="Repară" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  </Grid>

                  <!-- Caută online -->
                  <Button x:Name="BtnDetailSearchOnline"
                          Style="{StaticResource OutlineButtonStyle}"
                          Height="32" FontSize="11"
                          HorizontalAlignment="Stretch"
                          Click="DetailSearchOnline_Click"
                          Margin="0,0,0,8"
                          ToolTip="Caută driverul pe DRP.su sau Google (configurat în Setări)">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M2,12 H22 M12,2 C9.5,7 9.5,17 12,22 C14.5,17 14.5,7 12,2 Z"/></Canvas></Viewbox><TextBlock Text="Caută Driver Online" VerticalAlignment="Center"/></StackPanel>
                    </Button>

                  <!-- Blochează auto-update -->
                  <Button x:Name="BtnDetailBlockDriver"
                          Style="{StaticResource OutlineButtonStyle}"
                          Height="32" FontSize="11"
                          HorizontalAlignment="Stretch"
                          Click="DetailBlockDriver_Click"
                          Margin="0,0,0,0"
                          ToolTip="Împiedică Windows Update să suprascrie acest driver">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,22 C12,22 3,18 3,12 V5 L12,2 L21,5 V12 C21,18 12,22 12,22 Z M9,9 L15,15 M15,9 L9,15"/></Canvas></Viewbox><TextBlock Text="Blochează Auto-Update" VerticalAlignment="Center"/></StackPanel>
                    </Button>

                </StackPanel>
              </ScrollViewer>
            </Border>

          </Grid>
          <!-- END Grid Row 3 -->

        </Grid>


        <!-- ── DISK / SSD ── -->
        <Grid x:Name="PanelDisk" Visibility="Collapsed" Margin="24" Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Title -->
          <TextBlock x:Name="TxtDiskTitle" Grid.Row="0"
                     Text="Storage — Health, SMART, Surface Scan &amp; Benchmark"
                     Style="{StaticResource SectionTitleStyle}"/>

          <!-- Tab bar -->
          <Grid Grid.Row="1" Margin="0,0,0,10">
            <WrapPanel>
              <Button x:Name="BtnStorageTabOverview" 
                      Style="{StaticResource SubTabButtonActiveStyle}"
                      Click="StorageTab_Click" Tag="Overview" Margin="0,0,6,0"
                      ToolTip="Disk health and general info">
                <StackPanel Orientation="Horizontal"><Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3,5 A9,3 0 1 1 21,5 A9,3 0 1 1 3,5 Z M21,12 C21,13.66 16.97,15 12,15 C7.03,15 3,13.66 3,12 M3,5 V19 C3,20.66 7.03,22 12,22 C16.97,22 21,20.66 21,19 V5"/></Canvas></Viewbox><TextBlock Text="Overview" VerticalAlignment="Center"/></StackPanel>
              </Button>
              <Button x:Name="BtnStorageTabSmart"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="StorageTab_Click" Tag="Smart" Margin="0,0,6,0"
                      ToolTip="SMART health attributes">
                <StackPanel Orientation="Horizontal"><Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z M9,12 L11,14 L15,10"/></Canvas></Viewbox><TextBlock Text="SMART" VerticalAlignment="Center"/></StackPanel>
              </Button>
              <Button x:Name="BtnStorageTabSurface"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="StorageTab_Click" Tag="Surface" Margin="0,0,6,0"
                      ToolTip="Scan disk surface for bad sectors">
                <StackPanel Orientation="Horizontal"><Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M3.0,11.0 A8.0,8.0 0 1 1 19.0,11.0 A8.0,8.0 0 1 1 3.0,11.0 Z"/></Canvas></Viewbox><TextBlock Text="Surface Scan" VerticalAlignment="Center"/></StackPanel>
              </Button>
              <Button x:Name="BtnStorageTabBench"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="StorageTab_Click" Tag="Bench" Margin="0,0,6,0"
                      ToolTip="Disk read/write speed benchmark">
                <StackPanel Orientation="Horizontal"><Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M13,2 L3,14 L12,14 L11,22 L21,10 L12,10 Z"/></Canvas></Viewbox><TextBlock Text="Benchmark" VerticalAlignment="Center"/></StackPanel>
              </Button>
              <Button x:Name="BtnStorageTabFiles"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="StorageTab_Click" Tag="Files"
                      ToolTip="Find large files and top folders">
                <StackPanel Orientation="Horizontal"><Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></Canvas></Viewbox><TextBlock Text="Large Files" VerticalAlignment="Center"/></StackPanel>
              </Button>
            </WrapPanel>
            <!-- Disk Management — dreapta sus -->
            <Button x:Name="BtnStorageDevMgr"
                    Style="{StaticResource OutlineButtonStyle}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="BtnStorageDevMgr_Click"
                    ToolTip="Open Disk Management — create, delete and resize partitions">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.75"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent" Data="M3 5h18M3 10h18M3 15h18M3 20h18M8 5v15M16 5v15"/>
                  </Canvas>
                </Viewbox>
                <TextBlock Text="Disk Management" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Grid>

          <!-- ── Tab: Overview ── -->
          <ScrollViewer x:Name="StorageTabOverview" Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="DiskPanel"/>
          </ScrollViewer>

          <!-- ── Tab: SMART ── -->
          <Grid x:Name="StorageTabSmart" Grid.Row="2" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Disk selector -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14,10">
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtSmartDiskLabel" Text="Drive:" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                <ComboBox x:Name="CbSmartDisk" Width="340" SelectionChanged="SmartDisk_Changed"/>
                <TextBlock x:Name="TxtSmartHealthBadge" Text="100%" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center" Margin="18,0,0,0"/>
                <TextBlock x:Name="TxtSmartHealthLabel" Text=" Health" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtSmartDiskType" Text="" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="18,0,0,0"/>
              </StackPanel>
            </Border>
            <!-- SMART attributes grid -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
              <DataGrid x:Name="SmartGrid" CanUserResizeColumns="True" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.RowStyle>
                  <Style TargetType="DataGridRow">
                    <Setter Property="ToolTip" Value="{Binding AttributeTooltip}"/>
                    <Setter Property="ToolTipService.ShowDuration" Value="12000"/>
                  </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                  <DataGridTextColumn Header="ID" Binding="{Binding IdHex}" Width="48"/>
                  <DataGridTextColumn Header="Attribute" Binding="{Binding Name}" Width="*"/>
                  <DataGridTextColumn Header="Current" Binding="{Binding CurrentValue}" Width="60"/>
                  <DataGridTextColumn Header="Worst" Binding="{Binding WorstValue}" Width="60"/>
                  <DataGridTextColumn Header="Raw" Binding="{Binding RawValue}" Width="90"/>
                  <DataGridTemplateColumn Header="Status" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"
                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                </DataGrid.Columns>
              </DataGrid>
            </Border>
          </Grid>

          <!-- ── Tab: Surface Scan ── -->
          <Grid x:Name="StorageTabSurface" Grid.Row="2" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Controls -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14,10">
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtSurfaceDiskLabel" Text="Drive:" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                <ComboBox x:Name="CbSurfaceDisk" Width="280" Margin="0,0,14,0"/>
                <Button x:Name="BtnSurfaceStart" 
                      ToolTip="Start a disk surface scan — reads every sector to detect bad blocks. Click again to stop."
                        Style="{StaticResource OutlineButtonStyle}"
                        Click="SurfaceScan_Start_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M3,11 A8,8 0 1 1 19,11 A8,8 0 1 1 3,11 Z"/></Canvas></Viewbox><TextBlock Text="Start Scan" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                <TextBlock x:Name="TxtSurfaceStatus" Text="Ready" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              </StackPanel>
            </Border>

            <!-- Progress bar + stats -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14,10">
              <StackPanel>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <ProgressBar x:Name="SurfaceProgressBar" Height="14" Value="0" Maximum="100"
                               Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource BgInputBrush}"
                               VerticalAlignment="Center"/>
                  <TextBlock x:Name="TxtSurfacePct" Grid.Column="1" Text="0%" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </Grid>
                <WrapPanel>
                  <Border Background="{DynamicResource BgInputBrush}" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                    <StackPanel>
                      <TextBlock Text="Bad Sectors" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="TxtSurfaceBad" Text="0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusErrorBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{DynamicResource BgInputBrush}" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                    <StackPanel>
                      <TextBlock Text="Slow Sectors" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="TxtSurfaceSlow" Text="0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource StatusWarningBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{DynamicResource BgInputBrush}" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                    <StackPanel>
                      <TextBlock Text="Speed" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="TxtSurfaceSpeed" Text="— MB/s" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{DynamicResource BgInputBrush}" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                    <StackPanel>
                      <TextBlock Text="ETA" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="TxtSurfaceEta" Text="—" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                  <Border Background="{DynamicResource BgInputBrush}" CornerRadius="8" Padding="10,5">
                    <StackPanel>
                      <TextBlock Text="Current LBA" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                      <TextBlock x:Name="TxtSurfaceLba" Text="—" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Visual sector map -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="10">
              <StackPanel>
                <TextBlock x:Name="TxtSurfaceMapLabel" Text="Sector map (green=OK, yellow=slow, orange=very slow, red=bad)"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <WrapPanel x:Name="SurfaceMapPanel" />
              </StackPanel>
            </Border>

            <!-- Bad sectors list -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="10" Margin="0,10,0,0" MaxHeight="150">
              <StackPanel>
                <TextBlock Text="Bad Sectors detectate:" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource StatusErrorBrush}" Margin="0,0,0,6"/>
                <ListBox x:Name="BadSectorList" MaxHeight="100" FontSize="11"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
            </Border>

            <!-- Repair panel — shown only when bad sectors found -->
            <Border x:Name="SurfaceRepairPanel" Grid.Row="4" Visibility="Collapsed"
                    CornerRadius="8" Padding="14,10" Margin="0,8,0,0"
                    BorderThickness="1" BorderBrush="{DynamicResource StatusWarningBrush}"
                    Background="{DynamicResource BgOverlayBrush}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource StatusWarningBrush}"
                             Text="Bad sectors detected — repair recommended"/>
                  <TextBlock x:Name="TxtSurfaceRepairInfo" FontSize="11" TextWrapping="Wrap"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"
                             Text="chkdsk /r will scan the drive and remap bad clusters. This may take 30–90 min. The drive will be checked on next reboot."/>
                </StackPanel>
                <Button x:Name="BtnSurfaceRepair" Grid.Column="1"
                        Style="{StaticResource OutlineButtonStyle}"
                        Click="SurfaceRepair_Click" Margin="16,0,0,0"
                        ToolTip="Run chkdsk /r — marks bad sectors as unusable so Windows never writes data to them again. Requires reboot.">
                  <StackPanel Orientation="Horizontal">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"
                              Data="M12 20h9 M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Repair (chkdsk /r)" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </Grid>
            </Border>
          </Grid>

          <!-- ── Tab: Benchmark ── -->
          <Grid x:Name="StorageTabBench" Grid.Row="2" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14,10">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                  <TextBlock x:Name="TxtBenchDriveLabel" Text="Drive:" VerticalAlignment="Center" Margin="0,0,10,0"
                             Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                  <ComboBox x:Name="CbBenchDrive" Width="100" Margin="0,0,8,0"/>
                  <Button x:Name="BtnSelectUsbDrive" 
                          Style="{StaticResource OutlineButtonStyle}" Padding="10,5"
                          ToolTip="Auto-select the first connected USB / removable drive"
                          Click="SelectUsbDrive_Click" Margin="0,0,14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M10,2 H14 V8 L15,9 V12 L14,13 V14 A1,1 0 0 1 13,15 H11 A1,1 0 0 1 10,14 V13 L9,12 V9 L10,8 Z"/></Canvas></Viewbox><TextBlock Text="USB / Removable" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  <Button x:Name="BtnRunFullBench" 
                      ToolTip="Run a sequential read/write benchmark on the selected disk — measures MB/s throughput"
                          Style="{StaticResource OutlineButtonStyle}"
                          Click="RunFullBench_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M13,2 L3,14 H12 L11,22 L21,10 H12 Z"/></Canvas></Viewbox><TextBlock Text="Start Benchmark" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock x:Name="TxtBenchNote" FontSize="11" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Full benchmark includes: Seq Read/Write, Random 4K IOPS, Latency P50/P95/P99. Duration ~60s per drive. Click 'USB / Removable' to auto-detect connected USB drives."/>

                <!-- HDD animation — visible only during benchmark -->
                <Grid x:Name="BenchHddAnim" Visibility="Collapsed" Margin="0,12,0,0" Height="54">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <!-- Spinning platter SVG -->
                  <Viewbox Width="48" Height="48" Margin="0,0,14,0">
                    <Canvas Width="48" Height="48">
                      <!-- Outer casing -->
                      <Rectangle Width="48" Height="36" Canvas.Top="6" RadiusX="5" RadiusY="5"
                                 Fill="{DynamicResource BgInputBrush}" Stroke="{DynamicResource CardBorderBrush}" StrokeThickness="1"/>
                      <!-- Spinning platter disc -->
                      <Ellipse x:Name="HddPlatter" Width="22" Height="22" Canvas.Left="13" Canvas.Top="13"
                               Fill="{DynamicResource BgOverlayBrush}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5">
                        <Ellipse.RenderTransform>
                          <RotateTransform x:Name="HddPlatterRot" CenterX="11" CenterY="11"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                          <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                              <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="HddPlatterRot"
                                                 Storyboard.TargetProperty="Angle"
                                                 From="0" To="360" Duration="0:0:0.8"/>
                              </Storyboard>
                            </BeginStoryboard>
                          </EventTrigger>
                        </Ellipse.Triggers>
                      </Ellipse>
                      <!-- Center hub -->
                      <Ellipse Width="6" Height="6" Canvas.Left="21" Canvas.Top="21"
                               Fill="{DynamicResource AccentBrush}"/>
                      <!-- Read arm — pivot outside platter (motor), tip sweeps platter surface -->
                      <Line x:Name="HddArm" X1="38" Y1="34" X2="22" Y2="19"
                            Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.8"
                            StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                        <Line.RenderTransform>
                          <RotateTransform x:Name="HddArmRot" CenterX="38" CenterY="34"/>
                        </Line.RenderTransform>
                        <Line.Triggers>
                          <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                              <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="HddArmRot"
                                                 Storyboard.TargetProperty="Angle"
                                                 From="-22" To="22" Duration="0:0:0.45"/>
                              </Storyboard>
                            </BeginStoryboard>
                          </EventTrigger>
                        </Line.Triggers>
                      </Line>
                      <!-- Arm pivot dot -->
                      <Ellipse Width="5" Height="5" Canvas.Left="35.5" Canvas.Top="31.5"
                               Fill="{DynamicResource AccentBrush}"/>
                    </Canvas>
                  </Viewbox>
                  <!-- Live text next to animation -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtBenchAnimPhase" Text="Preparing benchmark…"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                      <TextBlock x:Name="TxtBenchAnimSpeed" Text=""
                                 FontSize="22" FontWeight="Black"
                                 Foreground="{DynamicResource AccentBrush}"/>
                      <TextBlock x:Name="TxtBenchAnimUnit" Text=""
                                 FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                    </StackPanel>
                  </StackPanel>
                </Grid>

                <!-- Live progress bar — visible only during benchmark -->
                <Grid x:Name="BenchLiveProgressRow" Visibility="Collapsed" Margin="0,10,0,2">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <!-- Stage pills -->
                  <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,4,0"
                            Background="{DynamicResource BgInputBrush}">
                      <TextBlock Text="1 Small files" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                    <TextBlock Text="›" FontSize="10" Opacity="0.4"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,4,0"
                            Background="{DynamicResource BgInputBrush}">
                      <TextBlock Text="2 Sequential" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                    <TextBlock Text="›" FontSize="10" Opacity="0.4"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,4,0"
                            Background="{DynamicResource BgInputBrush}">
                      <TextBlock Text="3 Random 4K" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                    <TextBlock Text="›" FontSize="10" Opacity="0.4"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Border CornerRadius="4" Padding="8,3"
                            Background="{DynamicResource BgInputBrush}">
                      <TextBlock Text="4 Latency" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                  </StackPanel>
                  <!-- Phase label + speed -->
                  <Grid Grid.Row="1" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtBenchPhase" Text="Preparing..." FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="TxtBenchLiveSpeed" Text="" FontSize="12" FontWeight="Bold"
                                 Foreground="{DynamicResource AccentBrush}" Margin="0,0,4,0"/>
                      <TextBlock Text="MB/s" FontSize="11"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                    </StackPanel>
                  </Grid>
                  <!-- Progress track -->
                  <Border Grid.Row="2" CornerRadius="3" Background="{DynamicResource BgInputBrush}">
                    <Border x:Name="BenchLiveBar" HorizontalAlignment="Left" CornerRadius="3" Height="6" Width="0">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                          <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                          <GradientStop Color="{DynamicResource AccentColor}" Offset="1"/>
                        </LinearGradientBrush>
                      </Border.Background>
                    </Border>
                  </Border>
                  <!-- Speed reference scale -->
                  <Grid Grid.Row="3" Margin="0,3,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="USB 2.0 ~30" FontSize="9" Opacity="0.4"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                    <TextBlock Text="HDD ~120" Grid.Column="1" FontSize="9" Opacity="0.4"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="SATA SSD ~550" Grid.Column="2" FontSize="9" Opacity="0.4"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="NVMe ~3500" Grid.Column="3" FontSize="9" Opacity="0.4"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                  </Grid>
                </Grid>
              </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel x:Name="BenchResultsPanel">
                <!-- Results added dynamically -->
              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- ── Tab: Large Files Scanner ── -->
          <Grid x:Name="StorageTabFiles" Grid.Row="2" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Controls bar -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14,10">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Toggle Files/Folders -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                  <Button x:Name="BtnFilesSubLarge" Tag="LargeFiles"
                          Click="FilesSubTab_Click" Padding="10,5" Margin="0,0,4,0"
                          Style="{StaticResource SubTabButtonActiveStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M14,2 H6 A2,2 0 0 0 4,4 V20 A2,2 0 0 0 6,22 H18 A2,2 0 0 0 20,20 V8 Z M14,2 V8 H20"/></Canvas></Viewbox>
                      <TextBlock Text="Files" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button x:Name="BtnFilesSubFolders" Tag="TopFolders"
                          Click="FilesSubTab_Click" Padding="10,5"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,20 A2,2 0 0 1 20,22 H4 A2,2 0 0 1 2,20 V6 A2,2 0 0 1 4,4 H9 L11,7 H20 A2,2 0 0 1 22,9 Z M2,10 H22"/></Canvas></Viewbox>
                      <TextBlock Text="Folders" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </StackPanel>
                <!-- Path + size chips -->
                <TextBox x:Name="TxtFileScanPath" Grid.Column="1" Text="C:\" Padding="6,5"
                         Background="{DynamicResource BgInputBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                         VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                  <RadioButton x:Name="ChipFile10"  Content="10M"  GroupName="FileSizeFilter" Style="{StaticResource UnderlineChipStyle}" Margin="0,0,2,0" Checked="FileSizeChip_Checked" Tag="10"/>
                  <RadioButton x:Name="ChipFile50"  Content="50M"  GroupName="FileSizeFilter" Style="{StaticResource UnderlineChipStyle}" Margin="0,0,2,0" Checked="FileSizeChip_Checked" Tag="50"/>
                  <RadioButton x:Name="ChipFile100" Content="100M" GroupName="FileSizeFilter" Style="{StaticResource UnderlineChipStyle}" Margin="0,0,2,0" Checked="FileSizeChip_Checked" Tag="100" IsChecked="True"/>
                  <RadioButton x:Name="ChipFile500" Content="500M" GroupName="FileSizeFilter" Style="{StaticResource UnderlineChipStyle}" Margin="0,0,2,0" Checked="FileSizeChip_Checked" Tag="500"/>
                  <RadioButton x:Name="ChipFile1GB" Content="1GB"  GroupName="FileSizeFilter" Style="{StaticResource UnderlineChipStyle}" Margin="0,0,2,0" Checked="FileSizeChip_Checked" Tag="1024"/>
                </StackPanel>
                <Button x:Name="BtnBrowseScanPath" Grid.Column="3"
                        Style="{StaticResource OutlineButtonStyle}"
                        Click="BrowseFileScanPath_Click" Padding="10,5" Margin="0,0,6,0"
                        ToolTip="Browse folder">
                  <Viewbox Width="13" Height="13"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,19 A2,2 0 0 1 20,21 H4 A2,2 0 0 1 2,19 V5 A2,2 0 0 1 4,3 H9 L11,6 H20 A2,2 0 0 1 22,8 Z"/></Canvas></Viewbox>
                </Button>
                <Button x:Name="BtnStartFileScan" Grid.Column="4"
                        Style="{StaticResource OutlineButtonStyle}"
                        Click="StartFileScan_Click" Padding="14,5">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M3,11 A8,8 0 1 1 19,11 A8,8 0 1 1 3,11 Z"/></Canvas></Viewbox>
                    <TextBlock Text="Scan" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <!-- Hidden compat -->
                <Button x:Name="BtnFilesSubTreeMap" Grid.Column="6" Visibility="Collapsed" Tag="TreeMap" Click="FilesSubTab_Click"/>
              </Grid>
            </Border>

            <!-- Progress row -->
            <Grid x:Name="FileScanProgressRow" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <ProgressBar x:Name="PbFileScan" Height="5" IsIndeterminate="True" VerticalAlignment="Center"
                           Style="{StaticResource AnimatedProgressBarStyle}"/>
              <TextBlock x:Name="TxtFileScanStatus" Grid.Column="1" Text="Scanning..." FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </Grid>

            <!-- Split: List LEFT | TreeMap RIGHT -->
            <Grid Grid.Row="2">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
              </Grid.ColumnDefinitions>

              <!-- Left: Files/Folders list -->
              <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <!-- Summary bar -->
                  <Border Grid.Row="0" Background="{DynamicResource BgHoverBrush}" Padding="14,8" CornerRadius="10,10,0,0">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                      <TextBlock x:Name="TxtFileScanSummary" Text="Run a scan to find large files."
                                 FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      <Button x:Name="BtnOpenFileScanFolder" Grid.Column="1" Style="{StaticResource OutlineButtonStyle}"
                              Click="OpenFileScanFolder_Click" Padding="8,3" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <Viewbox Width="11" Height="11" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></Canvas></Viewbox>
                          <TextBlock Text="Open" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Button>
                    </Grid>
                  </Border>
                                    <!-- DataGrid -->
                  <DataGrid x:Name="LargeFilesGrid" CanUserResizeColumns="True" Grid.Row="1"
                            AutoGenerateColumns="False" IsReadOnly="True"
                            CanUserSortColumns="True"
                            GridLinesVisibility="None"
                            Background="{DynamicResource BgCardBrush}"
                            RowBackground="Transparent"
                            AlternatingRowBackground="{DynamicResource RowAltBrush}"
                            BorderThickness="0"
                            MouseDoubleClick="LargeFile_DoubleClick">
                    <DataGrid.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Reveal in Explorer" Click="LargeFile_OpenFolder"/>
                        <MenuItem Header="Copy Path"          Click="LargeFile_CopyPath"/>
                        <Separator/>
                        <MenuItem Header="&#x1F5D1;  Move to Recycle Bin" Click="LargeFile_MoveToRecycleBin"/>
                        <MenuItem Header="&#x26A0;  Delete Permanently"  Click="LargeFile_Delete" Foreground="{DynamicResource StatusCritBrush}"/>
                      </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Size"      Binding="{Binding SizeText}"     Width="80"  SortMemberPath="SizeBytes"/>
                      <DataGridTextColumn Header="Category" Binding="{Binding FileCategory}" Width="90"/>
                      <DataGridTextColumn Header="Fisier"    Binding="{Binding FileName}"     Width="*"/>
                      <DataGridTextColumn Header="Cale"      Binding="{Binding Directory}"    Width="2*"/>
                      <DataGridTextColumn Header="Modificat" Binding="{Binding Modified}"     Width="120"/>
                    </DataGrid.Columns>
                  </DataGrid>
                  <!-- TopFoldersGrid — code-behind compat, visibilty toggled by FilesSubTab_Click -->
                  <DataGrid x:Name="TopFoldersGrid" CanUserResizeColumns="True" Grid.Row="1" Visibility="Collapsed"
                            AutoGenerateColumns="False" IsReadOnly="True"
                             CanUserSortColumns="True"
                            GridLinesVisibility="None"
                            Background="{DynamicResource BgCardBrush}"
                            RowBackground="Transparent"
                            AlternatingRowBackground="{DynamicResource RowAltBrush}"
                            BorderThickness="0"
                            MouseDoubleClick="TopFolder_DoubleClick">
                    <DataGrid.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Open Folder"  Click="TopFolder_Open"/>
                        <MenuItem Header="Copy Path"    Click="TopFolder_CopyPath"/>
                      </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="90" SortMemberPath="SizeBytes"/>
                      <DataGridTextColumn Header="Folder" Binding="{Binding Path}" Width="*"/>
                      <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="90"/>
                      <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" Width="60"/>
                    </DataGrid.Columns>
                  </DataGrid>
                  <!-- Compat stubs — used by code-behind, not visible -->
                  <TextBlock x:Name="TxtFileScanTitle" Visibility="Collapsed"/>
                  <TextBlock x:Name="TxtSizeHint" Visibility="Collapsed"/>
                </Grid>
              </Border>

              <!-- Splitter -->
              <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                            Background="Transparent" Cursor="SizeWE"/>

              <!-- Right: TreeMap -->
              <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <!-- TreeMap header -->
                  <Border Grid.Row="0" Background="{DynamicResource BgHoverBrush}" Padding="14,8" CornerRadius="10,10,0,0">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                          <Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3,3 H14 V13 H3 Z M16,3 H21 V9 H16 Z M16,11 H21 V21 H16 Z M3,15 H14 V21 H3 Z"/></Canvas>
                        </Viewbox>
                        <TextBlock Text="TreeMap" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TxtTreeMapInfo" Text=" — run a scan to visualize"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                  <!-- TreeMap canvas -->
                  <Border x:Name="TreeMapPanel" Grid.Row="1" Background="{DynamicResource BgCardBrush}"
                          ClipToBounds="True" CornerRadius="0,0,10,10">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                      <Canvas x:Name="TreeMapCanvas" Width="900" Height="600"
                              Background="Transparent" MouseMove="TreeMap_MouseMove"
                              MouseLeftButtonDown="TreeMap_Click"/>
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Border>
            </Grid>
          </Grid>
          <WrapPanel Grid.Row="3" Margin="0,10,0,0">
            <Button x:Name="BtnReloadDisks"
                    Style="{StaticResource OutlineButtonStyle}" Click="LoadDisks_Click" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal"><Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></Canvas></Viewbox><TextBlock Text="Refresh" VerticalAlignment="Center"/></StackPanel>
            </Button>
          </WrapPanel>
        </Grid>

        <!-- ── RAM ── -->
        <Grid x:Name="PanelRam" Visibility="Collapsed" Margin="24" Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>  <!-- XMP badge -->
            <RowDefinition Height="Auto"/>  <!-- RAM Tests card -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Title -->
          <TextBlock x:Name="TxtRamTitle" Grid.Row="0" Text="RAM Memory Modules"
                     Style="{StaticResource SectionTitleStyle}"/>

          <!-- Toolbar — uniform buttons, same style -->
          <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <!-- BtnReloadRam kept as hidden stub for code compat -->
            <Button x:Name="BtnReloadRam" Visibility="Collapsed" Click="LoadRam_Click"/>
            <Button x:Name="BtnMemDiag"
                    Style="{StaticResource AppButtonStyle}" 
                    Click="OpenMemDiag_Click" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M4,8 H20 A2,2 0 0 1 22,10 V14 A2,2 0 0 1 20,16 H4 A2,2 0 0 1 2,14 V10 A2,2 0 0 1 4,8 Z M6,8 V16 M10,8 V16 M14,8 V16 M18,8 V16 M6,5 V8 M10,5 V8 M14,5 V8 M18,5 V8"/></Canvas></Viewbox>
                <TextBlock Text="Windows Memory Diagnostic" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </WrapPanel>

          <!-- Summary -->
          <TextBlock Grid.Row="2" x:Name="TxtRamTotal" FontSize="13"
                     Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

          <!-- XMP/EXPO Status Badge — always visible, color indicates state -->
          <StackPanel Grid.Row="3" Margin="0,0,0,0">
            <Border x:Name="XmpAlertBanner" Visibility="Collapsed"
                    CornerRadius="8" Padding="10,7" Margin="0,0,0,10"
                    Background="{StaticResource WarnAlpha10Brush}" BorderBrush="{StaticResource WarnAlpha37Brush}" BorderThickness="1">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Width="8" Height="8" Fill="{DynamicResource StatusWarningBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock x:Name="TxtXmpAlertTitle" Text="XMP/EXPO not enabled"
                             FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource StatusWarningBrush}"/>
                  <TextBlock x:Name="TxtXmpAlertSub" Text="" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,1,0,0"/>
                </StackPanel>
                <Border Grid.Column="2" CornerRadius="4" Background="{StaticResource WarnAlpha19Brush}" Padding="6,3" VerticalAlignment="Center" Margin="8,0,0,0">
                  <TextBlock Text="BIOS Fix" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource StatusWarningBrush}"/>
                </Border>
              </Grid>
            </Border>
            <!-- XMP LED — always visible, shows current state -->
            <Border x:Name="XmpStatusBadge" Visibility="Collapsed"
                    CornerRadius="6" Padding="8,5" Margin="0,0,0,10"
                    Background="{DynamicResource BgInputBrush}" BorderThickness="1">
              <Border.ToolTip>
                <ToolTip>
                  <StackPanel>
                    <TextBlock x:Name="TxtXmpTooltipTitle" Text="XMP/EXPO Status" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock x:Name="TxtXmpTooltipSub"   Text="" FontSize="11" Margin="0,3,0,0" Opacity="0.8"/>
                  </StackPanel>
                </ToolTip>
              </Border.ToolTip>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="XmpLedDot" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,7,0"/>
                <TextBlock x:Name="TxtXmpBadgeLabel" Text="XMP/EXPO" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtXmpBadgeState" Text="" FontSize="10" FontWeight="Bold"
                           Margin="5,0,0,0" VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- ══ Combined test card — Bandwidth + Integrity, both always visible ══ -->
          <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="0">
            <StackPanel>
              <!-- Card header -->
              <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="12,12,0,0" Padding="14,10">
                <TextBlock Text="RAM Tests" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
              </Border>

              <Grid Margin="14,12,14,14">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="16"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─ Bandwidth Benchmark ─ -->
                <StackPanel Grid.Column="0">
                  <TextBlock Text="Bandwidth Benchmark" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                  <TextBlock Text="Măsoară viteza de citire/scriere RAM (GB/s)" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>

                  <!-- Results (shown after run) -->
                  <Grid x:Name="BenchResultGrid" Visibility="Collapsed" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Read" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtRamReadSpeed" Text="—" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock Text=" GB/s" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                      </StackPanel>
                      <Border Background="{DynamicResource BgInputBrush}" CornerRadius="4" Height="5" Margin="0,4,8,0">
                        <Border x:Name="RamReadBar" Background="{DynamicResource AccentBrush}"
                                CornerRadius="4" Height="5" HorizontalAlignment="Left" Width="0"/>
                      </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="Write" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtRamWriteSpeed" Text="—" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource GreenBrush}"/>
                        <TextBlock Text=" GB/s" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                      </StackPanel>
                      <Border Background="{DynamicResource BgInputBrush}" CornerRadius="4" Height="5" Margin="0,4,0,0">
                        <Border x:Name="RamWriteBar" Background="{StaticResource GreenBrush}"
                                CornerRadius="4" Height="5" HorizontalAlignment="Left" Width="0"/>
                      </Border>
                    </StackPanel>
                  </Grid>
                  <TextBlock x:Name="TxtRamBenchRating" Text="" FontSize="12" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,2"/>
                  <TextBlock x:Name="TxtRamBenchNote" Text="" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             TextWrapping="Wrap" Margin="0,0,0,8"/>

                  <!-- Run button — same style as Integrity -->
                  <Button x:Name="BtnRamBench" 
                      ToolTip="Measure RAM bandwidth (read/write/copy speed in GB/s) using a synthetic memory workload"
                          Style="{StaticResource OutlineButtonStyle}"
                          Click="RunRamBench_Click" HorizontalAlignment="Left" Padding="14,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M13,2 L3,14 H12 L11,22 L21,10 H12 Z"/></Canvas></Viewbox><TextBlock Text="Run Benchmark" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </StackPanel>

                <!-- Divider -->
                <Border Grid.Column="1" Width="1" Background="{DynamicResource BorderBrush2}"
                        VerticalAlignment="Stretch" Margin="0,4,0,4"/>

                <!-- ─ Integrity Test ─ -->
                <StackPanel Grid.Column="2">
                  <TextBlock Text="Integrity Test" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                  <TextBlock Text="Testează RAM cu 6 tipare de biți. Nu necesită restart." FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>

                  <!-- Progress bar -->
                  <ProgressBar x:Name="PbRamTest" Height="5" Minimum="0" Maximum="100" Value="0"
                               Background="{DynamicResource BgInputBrush}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,6" Visibility="Collapsed"/>

                  <!-- Status line -->
                  <TextBlock x:Name="TxtRamTestStatus" Text=""
                             FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                             Margin="0,0,0,4" TextWrapping="Wrap"/>

                  <!-- Hidden detail log (accessed via popup) -->
                  <ItemsControl x:Name="RamTestResultsList" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="11" Margin="0,1"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <!-- Compact result banner — click for details popup -->
                  <Border x:Name="RamTestResultBanner" Visibility="Collapsed"
                          CornerRadius="8" Padding="10,8" Margin="0,0,0,8"
                          Cursor="Hand" MouseLeftButtonUp="RamTestBanner_Click"
                          ToolTip="Click pentru detalii / Click for details">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock x:Name="TxtRamTestFinalIcon" Grid.Column="0" Text="" FontSize="18"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                      <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TxtRamTestFinalTitle" Text="RAM Test Passed"
                                   FontSize="13" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtRamTestFinalSub" Text=""
                                   FontSize="10" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="ⓘ" FontSize="14"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                  </Border>

                  <!-- Test size + Run -->
                  <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="CbRamTestSize" Width="80" Margin="0,0,8,0" SelectedIndex="1"
                              VerticalAlignment="Center">
                      <ComboBoxItem Content="64 MB"/>
                      <ComboBoxItem Content="256 MB"/>
                      <ComboBoxItem Content="512 MB"/>
                    </ComboBox>
                    <Button x:Name="BtnStartRamTest" 
                      ToolTip="Test RAM integrity by writing and reading back patterns — detects memory errors"
                            Style="{StaticResource OutlineButtonStyle}"
                            Click="StartRamTest_Click" Padding="14,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,22 C12,22 3,18 3,12 V5 L12,2 L21,5 V12 C21,18 12,22 12,22 Z M9,12 L11,14 L15,10"/></Canvas></Viewbox><TextBlock Text="Run Integrity Test" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <!-- ══ DIMM Slots — interactive + animated ══ -->
          <Border Grid.Row="5" Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="20,16">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M7,9 L7,16 M10,9 L10,16 M13,9 L13,16 M16,9 L16,16 M7,6 L7,9 M10,6 L10,9 M13,6 L13,9 M16,6 L16,9 M4.0,9.0 H20.0 A1.0,1.0 0 0 1 21.0,10.0 V15.0 A1.0,1.0 0 0 1 20.0,16.0 H4.0 A1.0,1.0 0 0 1 3.0,15.0 V10.0 A1.0,1.0 0 0 1 4.0,9.0 Z"/></Canvas></Viewbox>
                <TextBlock x:Name="TxtRamSlotLabel" Text="DIMM Slots"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,14"/>
              </StackPanel>
              <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MinHeight="190">
                <WrapPanel x:Name="RamSlotsPanel" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Grid>
              <TextBlock x:Name="TxtRamSlotInfo" Text="" FontSize="12" TextWrapping="Wrap"
                         Margin="0,14,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Module detail table -->
          <Border Grid.Row="6" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="RamGrid" CanUserResizeColumns="True" AutoGenerateColumns="False" IsReadOnly="True">
              <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                      <Setter Property="Opacity" Value="0.45"/>
                      <Setter Property="FontStyle" Value="Italic"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </DataGrid.RowStyle>
              <DataGrid.Columns>
                <DataGridTextColumn Header="Slot" Binding="{Binding SlotLabel}" Width="130"/>
                <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="140"/>
                <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" Width="220"/>
                <DataGridTextColumn Header="Capacity" Binding="{Binding Capacity}" Width="95"/>
                <DataGridTextColumn Header="Speed" Binding="{Binding Speed}" Width="95"/>
                <DataGridTextColumn Header="Tip" Binding="{Binding MemoryType}" Width="70"/>
                <DataGridTextColumn Header="Form Factor" Binding="{Binding FormFactor}" Width="90"/>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </Grid>

        <!-- ── NETWORK (redesigned — compact, clean layout) ── -->
        <Grid x:Name="PanelNetwork" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- ── Row 0: Title + action buttons ── -->
          <Grid Grid.Row="0" Margin="20,16,20,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
              <TextBlock x:Name="TxtNetworkTitle" Text="Network"
                         FontSize="20" FontWeight="Bold"
                         FontFamily="{StaticResource AppFontDisplay}" Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Text="Adapters • Speed test • Diagnostics • Firewall"
                         FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                         Margin="0,2,0,0" Opacity="0.6"/>
            </StackPanel>
            <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
              <Button x:Name="BtnNetSettings" Style="{StaticResource NetToolButtonStyle}"
                      Click="OpenNetworkSettings_Click" Margin="0,0,6,0"
                      ToolTip="Open Windows Network Settings">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.75" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2zM12 15a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></Canvas></Viewbox>
                  <TextBlock Text="Network Settings" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="BtnNetAdapters" Style="{StaticResource NetToolButtonStyle}"
                      Click="OpenNetAdapters_Click" Margin="0,0,6,0"
                      ToolTip="Open Network Adapter Settings">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.75" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/></Canvas></Viewbox>
                  <TextBlock Text="Adapters" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="BtnOpenRouter" Style="{StaticResource NetToolButtonStyle}"
                      ToolTip="Open gateway IP in default browser"
                      Click="OpenRouterPage_Click" Margin="0,0,6,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.75" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10"/></Canvas></Viewbox>
                  <TextBlock Text="Router Admin" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource NetToolButtonStyle}"
                      Click="FlushDns_Click" Margin="0,0,6,0"
                      ToolTip="ipconfig /flushdns — clears DNS cache">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.75" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></Canvas></Viewbox>
                  <TextBlock Text="Flush DNS" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource NetToolButtonStyle}"
                      Click="ReleaseRenewIp_Click" Margin="0,0,6,0"
                      ToolTip="ipconfig /release then /renew — requests new IP from DHCP">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.75" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8M3 3v5h5"/></Canvas></Viewbox>
                  <TextBlock Text="Release/Renew" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource NetToolButtonStyle}"
                      Click="ResetWinsock_Click" Margin="0,0,6,0"
                      ToolTip="netsh winsock reset — fixes corrupted network stack. Requires restart.">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.75" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></Canvas></Viewbox>
                  <TextBlock Text="Winsock Reset" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource NetToolButtonStyle}"
                      Click="TestMtu_Click"
                      ToolTip="Find optimal MTU by pinging gateway with varying packet sizes">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.75" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v10M3 9h18M3 13h18"/></Canvas></Viewbox>
                  <TextBlock Text="MTU Test" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </WrapPanel>
          </Grid>

          <!-- ── Row 1: Tab bar ── -->
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,0,8">
            <Button x:Name="BtnNetTabOverview" 
                    Tag="NetOverview" Click="NetTab_Click"
                    Style="{StaticResource SubTabButtonActiveStyle}"
                    Margin="0,0,4,0" ToolTip="Network adapter overview">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3,3 H10 V10 H3 Z M14,3 H21 V10 H14 Z M3,14 H10 V21 H3 Z M14,14 H21 V21 H14 Z"/></Canvas></Viewbox><TextBlock Text="Overview" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            <Button x:Name="BtnNetTabTools" 
                    Tag="NetTools" Click="NetTab_Click"
                    Style="{StaticResource OutlineButtonStyle}"
                    Margin="0,0,4,0" ToolTip="Speed test, diagnostics, scanners">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M14.7,6.3 A1,1 0 0 0 13,6 A4,4 0 0 0 8.07,9.77 L3,15 A2,2 0 0 0 5,19 A2,2 0 0 0 9,17 L15,11 A4,4 0 0 0 17.7,6.3 Z"/></Canvas></Viewbox><TextBlock Text="Tools" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            <Button x:Name="BtnNetTabSecurity" 
                    Tag="NetSecurity" Click="NetTab_Click"
                    Style="{StaticResource OutlineButtonStyle}"
                    ToolTip="Open ports and firewall info">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M16.5,10.5 V6.75 A4.5,4.5 0 0 0 7.5,6.75 V10.5 M5.25,10.5 H18.75 A2.25,2.25 0 0 1 21,12.75 V19.5 A2.25,2.25 0 0 1 18.75,21.75 H5.25 A2.25,2.25 0 0 1 3,19.5 V12.75 A2.25,2.25 0 0 1 5.25,10.5 Z"/></Canvas></Viewbox><TextBlock Text="Firewall" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            <Button x:Name="BtnNetTabApps"
                    Tag="NetApps" Click="NetTab_Click"
                    Style="{StaticResource OutlineButtonStyle}"
                    Margin="4,0,0,0"
                    ToolTip="Apps making network traffic — click for details, double-click to analyze">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,16 V8 A2,2 0 0 0 19,6 H5 A2,2 0 0 0 3,8 V16 A2,2 0 0 0 5,18 H19 A2,2 0 0 0 21,16 Z M8,6 V4 M16,6 V4 M3,10 H21"/></Canvas></Viewbox><TextBlock Text="Apps" VerticalAlignment="Center"/></StackPanel>
                    </Button>
          </StackPanel>

          <!-- ═══════════════════════════════════════════════════════
               TAB: OVERVIEW — Adapter cards (Ethernet / Wi-Fi / BT)
               ═══════════════════════════════════════════════════════ -->
          <ScrollViewer x:Name="NetTabOverview" Grid.Row="2"
                        VerticalScrollBarVisibility="Auto">
            <Grid>
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20,16,20,80">

              <!-- Section title -->
              <StackPanel Orientation="Horizontal">
                <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M5 12.55a11 11 0 0 1 14.08 0 M1.42 9a16 16 0 0 1 21.16 0 M8.53 16.11a6 6 0 0 1 6.95 0 M12,20 L12.01,20"/></Canvas></Viewbox>
                <TextBlock x:Name="TxtAdaptersLabel"
                         Text="Network Interfaces" FontSize="13" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,10" Opacity="0.7"/>
              </StackPanel>

              <!-- Adapter cards injected here by code-behind -->
              <ItemsControl x:Name="AdapterCardsPanel" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <!-- Card: min 420px, grows to fill row — hover accent border highlight -->
                    <Border Margin="0,0,14,14" Padding="22,20"
                            MinWidth="420" Cursor="Hand"
                            CornerRadius="14" BorderThickness="1"
                            Background="{DynamicResource BgCardBrush}">

                      <StackPanel>

                        <!-- ── Header: icon + name (LED below name, no overlap) ── -->
                        <Grid Margin="0,0,0,12">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>

                          <!-- Type icon in a coloured circle -->
                          <Border Width="52" Height="52" CornerRadius="26"
                                  Background="{Binding IconBg}" Margin="0,0,14,0">
                            <Viewbox Width="24" Height="24" Margin="0"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                              <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Fill="Transparent" Data="{Binding TypeIcon}"/>
                              </Canvas>
                            </Viewbox>
                          </Border>

                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Type}"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Opacity="0.6"/>
                            <!-- Status LED on its own line — no overlap -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                              <Border Width="8" Height="8" CornerRadius="4"
                                      Background="{Binding LedColor}" VerticalAlignment="Center" Margin="0,0,5,0">
                                <Border.Effect>
                                  <DropShadowEffect BlurRadius="5" ShadowDepth="0"
                                                    Color="{Binding LedGlowColor}"
                                                    Opacity="{Binding LedGlowOpacity}"
                                                    RenderingBias="Performance"/>
                                </Border.Effect>
                              </Border>
                              <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold"
                                         Foreground="{Binding PillFg}" VerticalAlignment="Center" Opacity="0.85"/>
                            </StackPanel>
                          </StackPanel>
                        </Grid>

                        <!-- ── Divider ── -->
                        <Border Height="1" Margin="0,0,0,12"
                                Background="{DynamicResource BorderBrush2}"/>

                        <!-- ── 2-column detail grid ── -->
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                          </Grid.RowDefinitions>

                          <!-- IP Address -->
                          <StackPanel Grid.Column="0" Grid.Row="0">
                            <TextBlock Text="IP Address" FontSize="10" Opacity="0.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding IpAddress}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"/>
                          </StackPanel>

                          <!-- MAC Address -->
                          <StackPanel Grid.Column="1" Grid.Row="0">
                            <TextBlock Text="MAC Address" FontSize="10" Opacity="0.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding MacAddress}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                          </StackPanel>

                          <!-- Gateway -->
                          <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="Gateway" FontSize="10" Opacity="0.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Gateway}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                          </StackPanel>

                          <!-- DNS -->
                          <StackPanel Grid.Column="1" Grid.Row="2">
                            <TextBlock Text="DNS" FontSize="10" Opacity="0.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Dns}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                          </StackPanel>

                          <!-- Link Speed -->
                          <StackPanel Grid.Column="0" Grid.Row="4">
                            <TextBlock Text="Link Speed" FontSize="10" Opacity="0.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Speed}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                          </StackPanel>

                          <!-- Extra (Signal for Wi-Fi, blank otherwise) -->
                          <StackPanel Grid.Column="1" Grid.Row="4">
                            <TextBlock Text="{Binding ExtraLabel}" FontSize="9" Opacity="0.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding ExtraValue}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                          </StackPanel>
                        </Grid>

                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- ── Public Network Info Card — full width, horizontal layout ── -->
              <Border x:Name="CardPublicIp" Margin="0,8,0,14" Padding="16,14"
                      CornerRadius="14" BorderThickness="1"
                      Background="{DynamicResource BgCardBrush}" HorizontalAlignment="Stretch"
                      Cursor="Hand">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                    <Setter Property="Effect">
                      <Setter.Value>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.15" RenderingBias="Performance"/>
                      </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="Effect">
                          <Setter.Value>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.22" RenderingBias="Performance"/>
                          </Setter.Value>
                        </Setter>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <!-- Full-width horizontal layout: icon+title | IP | ISP | Location | Timezone | VPN badge -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <!-- Icon + Title -->
                  <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                      <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Public Network" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="External IP info" FontSize="9"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"/>
                      </StackPanel>
                    </StackPanel>
                  </StackPanel>

                  <!-- Vertical dividers -->
                  <Border Grid.Column="1" Width="1" Background="{DynamicResource BorderBrush2}" Margin="0,2,0,2"/>
                  <Border Grid.Column="3" Width="1" Background="{DynamicResource BorderBrush2}" Margin="0,2,0,2"/>
                  <Border Grid.Column="5" Width="1" Background="{DynamicResource BorderBrush2}" Margin="0,2,0,2"/>
                  <Border Grid.Column="7" Width="1" Background="{DynamicResource BorderBrush2}" Margin="0,2,0,2"/>

                  <!-- Public IP -->
                  <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="PUBLIC IP" FontSize="9" FontWeight="SemiBold" Opacity="0.5"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock x:Name="TxtPublicIp" Text="—" FontSize="15" FontWeight="Bold"
                                 Foreground="{DynamicResource AccentBrush}"/>
                      <Button x:Name="BtnCopyPublicIp" Style="{StaticResource OutlineButtonStyle}"
                              Height="22" Width="22" Padding="2" Margin="6,0,0,0"
                              Click="CopyPublicIp_Click" ToolTip="Copy IP">
                        <Viewbox Width="11" Height="11"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M20,9 H11 A2,2 0 0 0 9,11 V20 A2,2 0 0 0 11,22 H20 A2,2 0 0 0 22,20 V11 A2,2 0 0 0 20,9 Z M5,15 H4 A2,2 0 0 1 2,13 V4 A2,2 0 0 1 4,2 H13 A2,2 0 0 1 15,4 V5"/></Canvas></Viewbox>
                      </Button>
                    </StackPanel>
                    <TextBlock x:Name="TxtPublicAsn" Text="" FontSize="9" Opacity="0.5"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>

                  <!-- ISP -->
                  <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="ISP" FontSize="9" FontWeight="SemiBold" Opacity="0.5"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtPublicIsp" Text="—" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                  </StackPanel>

                  <!-- Location -->
                  <StackPanel Grid.Column="6" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="LOCATION" FontSize="9" FontWeight="SemiBold" Opacity="0.5"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtPublicLocation" Text="—" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>

                  <!-- Timezone + Status -->
                  <StackPanel Grid.Column="8" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="TIMEZONE" FontSize="9" FontWeight="SemiBold" Opacity="0.5"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtPublicTimezone" Text="—" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="TxtPublicStatus" Text="" FontSize="9"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Opacity="0.5" Margin="0,2,0,0"/>
                  </StackPanel>

                  <!-- VPN Badge -->
                  <Border x:Name="PubIpVpnBadge" Grid.Column="9" CornerRadius="12" Padding="10,4" Margin="12,0,0,0"
                          Background="{StaticResource WarnBannerBgDarkBrush}" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="TxtPubIpVpnLabel" Text="VPN/Proxy"
                               FontSize="10" FontWeight="Bold" Foreground="{StaticResource WarnAmberSubtleBrush}"/>
                  </Border>
                </Grid>
                <!-- Hidden elements kept for code compat -->
                <Border.Resources>
                  <Style x:Key="HiddenStyle" TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </Style>
                </Border.Resources>
              </Border>
              <!-- Hidden compat elements -->
              <TextBlock x:Name="TxtPublicIpv6" Text="" Visibility="Collapsed"/>
              <Button x:Name="BtnRefreshPublicIp" Visibility="Collapsed" Click="RefreshPublicIp_Click"/>

              <!-- compat hidden grids still referenced in code -->
              <DataGrid x:Name="NetGrid" CanUserResizeColumns="True" Visibility="Collapsed"
                        AutoGenerateColumns="False" IsReadOnly="True" Height="0">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Adapter" Binding="{Binding Name}" Width="*"/>
                  <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="60"/>
                  <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="115"/>
                  <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="120"/>
                  <DataGridTextColumn Header="Link Speed" Binding="{Binding Speed}" Width="100"/>
                </DataGrid.Columns>
              </DataGrid>
              <DataGrid x:Name="TrafficGrid" Visibility="Collapsed"
                        AutoGenerateColumns="False" IsReadOnly="True" Height="0">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Adapter" Binding="{Binding Name}" Width="*"/>
                  <DataGridTextColumn Header="Sent" Binding="{Binding SendDisplay}" Width="110"/>
                  <DataGridTextColumn Header="Recv" Binding="{Binding RecvDisplay}" Width="110"/>
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
            </Grid>
          </ScrollViewer>

          <!-- TAB: TOOLS — Speed + Ping + DNS + Port + LAN + WiFi -->
          <ScrollViewer x:Name="NetTabTools" Grid.Row="2" Visibility="Collapsed"
                        VerticalScrollBarVisibility="Auto">
            <Grid Margin="20,10,20,20">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <!-- ── Sub-nav pills: Speed / Diagnose / Scanners ── -->
              <Border Grid.Row="0" Margin="0,0,0,14"
                      Background="{DynamicResource BgInputBrush}"
                      BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                      CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                  <Button x:Name="BtnNetSubSpeed" Tag="Speed"
                          Click="NetSubTab_Click"
                          Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonActiveStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 0 1 21.9,12 M12,12 L16,8"/></Canvas></Viewbox><TextBlock Text="Speed" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  <Button x:Name="BtnNetSubDiagnose" Tag="Diagnose"
                          Click="NetSubTab_Click"
                          Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1,4 V10 H7 M23,20 V14 H17 M20.49,9 A9,9 0 0 0 5.64,5.64 L1,10 M23,14 L18.36,18.36 A9,9 0 0 1 3.51,15"/></Canvas></Viewbox><TextBlock Text="Diagnose" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  <Button x:Name="BtnNetSubScanners" Tag="Scanners"
                          Click="NetSubTab_Click"
                          Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5,14 H3 A2,2 0 0 1 1,12 V8 A2,2 0 0 1 3,6 H21 A2,2 0 0 1 23,8 V12 A2,2 0 0 1 21,14 H19 M8,14 V20 M16,14 V20 M8,20 H16"/></Canvas></Viewbox><TextBlock Text="Scanners" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  <Button x:Name="BtnNetSubWifi" Tag="Wifi"
                          Click="NetSubTab_Click"
                          Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,20 H12.01 M5,12.55 A11,11 0 0 1 19,12.55 M1.42,9 A16,16 0 0 1 22.58,9 M8.53,16.11 A6,6 0 0 1 15.47,16.11"/></Canvas></Viewbox><TextBlock Text="WiFi" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </StackPanel>
              </Border>

              <!-- ════════════════════════════════════════════════
                   SUB-TAB: SPEED
                   ════════════════════════════════════════════════ -->
              <Grid x:Name="NetPaneSpeed" Grid.Row="1">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="10"/>
                  <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Speed Test card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16,14" VerticalAlignment="Stretch">
                  <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <StackPanel Orientation="Horizontal">
                          <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4 M8.0,12.0 A4.0,4.0 0 1 1 16.0,12.0 A4.0,4.0 0 1 1 8.0,12.0 Z"/></Canvas></Viewbox>
                          <TextBlock x:Name="TxtSpeedLabel" Text="Internet Speed Test"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtSpeedStatus" Text="Press Start to begin" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                      </StackPanel>
                      <Button x:Name="BtnSpeedtest" Grid.Column="1"
                              Style="{StaticResource OutlineButtonStyle}"
                              Click="RunSpeedtest_Click" VerticalAlignment="Top"
                              ToolTip="Start an internet speed test — measures download, upload, ping and jitter">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5,3 L19,12 L5,21 Z"/></Canvas></Viewbox><TextBlock Text="Start" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    </Grid>

                    <!-- Packet animation — visible only during test -->
                    <Border x:Name="SpeedAnimBorder" Margin="0,4,0,8" Visibility="Collapsed"
                            Background="Transparent" Height="64">
                      <Grid>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                          <!-- DL track -->
                          <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="60"/>
                              <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Download" FontSize="9" Opacity="0.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Height="4" CornerRadius="2"
                                    Background="{DynamicResource BgInputBrush}"
                                    VerticalAlignment="Center">
                              <Canvas ClipToBounds="True">
                                <Border x:Name="SpeedPktDL1" Width="16" Height="10" CornerRadius="4"
                                        Canvas.Top="-3" Canvas.Left="-20">
                                  <Border.Background><SolidColorBrush Color="{DynamicResource ChartGreenDimColor}"/></Border.Background>
                                  <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                      <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                          <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)"
                                                           From="-20" To="900" Duration="0:0:1.8"/>
                                        </Storyboard>
                                      </BeginStoryboard>
                                    </EventTrigger>
                                  </Border.Triggers>
                                </Border>
                                <Border x:Name="SpeedPktDL2" Width="16" Height="10" CornerRadius="4"
                                        Canvas.Top="-3" Canvas.Left="-20">
                                  <Border.Background><SolidColorBrush Color="{DynamicResource ChartGreenDark2Color}"/></Border.Background>
                                  <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                      <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.45">
                                          <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)"
                                                           From="-20" To="900" Duration="0:0:1.8"/>
                                        </Storyboard>
                                      </BeginStoryboard>
                                    </EventTrigger>
                                  </Border.Triggers>
                                </Border>
                                <Border x:Name="SpeedPktDL3" Width="16" Height="10" CornerRadius="4"
                                        Canvas.Top="-3" Canvas.Left="-20">
                                  <Border.Background><SolidColorBrush Color="{DynamicResource ChartGreenDark2Color}"/></Border.Background>
                                  <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                      <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.9">
                                          <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)"
                                                           From="-20" To="900" Duration="0:0:1.8"/>
                                        </Storyboard>
                                      </BeginStoryboard>
                                    </EventTrigger>
                                  </Border.Triggers>
                                </Border>
                              </Canvas>
                            </Border>
                          </Grid>
                          <!-- UL track -->
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="60"/>
                              <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Upload" FontSize="9" Opacity="0.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Height="4" CornerRadius="2"
                                    Background="{DynamicResource BgInputBrush}"
                                    VerticalAlignment="Center">
                              <Canvas ClipToBounds="True">
                                <Border x:Name="SpeedPktUL1" Width="16" Height="10" CornerRadius="4"
                                        Canvas.Top="-3" Canvas.Left="500">
                                  <Border.Background><SolidColorBrush Color="{DynamicResource RamCyanColor}"/></Border.Background>
                                  <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                      <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                          <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)"
                                                           From="900" To="-20" Duration="0:0:1.8"/>
                                        </Storyboard>
                                      </BeginStoryboard>
                                    </EventTrigger>
                                  </Border.Triggers>
                                </Border>
                                <Border x:Name="SpeedPktUL2" Width="16" Height="10" CornerRadius="4"
                                        Canvas.Top="-3" Canvas.Left="500">
                                  <Border.Background><SolidColorBrush Color="{DynamicResource RamCyanColor}"/></Border.Background>
                                  <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                      <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.6">
                                          <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)"
                                                           From="900" To="-20" Duration="0:0:1.8"/>
                                        </Storyboard>
                                      </BeginStoryboard>
                                    </EventTrigger>
                                  </Border.Triggers>
                                </Border>
                                <Border x:Name="SpeedPktUL3" Width="16" Height="10" CornerRadius="4"
                                        Canvas.Top="-3" Canvas.Left="500">
                                  <Border.Background><SolidColorBrush Color="{DynamicResource RamCyanColor}"/></Border.Background>
                                  <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                      <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:1.2">
                                          <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)"
                                                           From="900" To="-20" Duration="0:0:1.8"/>
                                        </Storyboard>
                                      </BeginStoryboard>
                                    </EventTrigger>
                                  </Border.Triggers>
                                </Border>
                              </Canvas>
                            </Border>
                          </Grid>
                        </StackPanel>
                      </Grid>
                    </Border>

                    <!-- Metric tiles -->
                    <Grid Margin="0,0,0,12">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Border Grid.Column="0" Background="{DynamicResource BgInputBrush}"
                              CornerRadius="8" Padding="10,10" Margin="0,0,6,0"
                              ToolTip="Download speed — higher is better">
                        <StackPanel HorizontalAlignment="Center" Margin="0,-2,0,-2">
                          <TextBlock Text="Download" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                          <TextBlock x:Name="TxtSpeedDownload" Text="—" FontSize="22" FontWeight="Black"
                                     Foreground="{StaticResource GreenBrush}" TextAlignment="Center"/>
                          <TextBlock Text="Mbps" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="1" Background="{DynamicResource BgInputBrush}"
                              CornerRadius="8" Padding="10,10" Margin="0,0,6,0"
                              ToolTip="Upload speed">
                        <StackPanel HorizontalAlignment="Center" Margin="0,-2,0,-2">
                          <TextBlock Text="Upload" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                          <TextBlock x:Name="TxtSpeedUpload" Text="—" FontSize="22" FontWeight="Black"
                                     Foreground="{DynamicResource AccentBrush}" TextAlignment="Center"/>
                          <TextBlock Text="Mbps" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="2" Background="{DynamicResource BgInputBrush}"
                              CornerRadius="8" Padding="10,10" Margin="0,0,6,0"
                              ToolTip="Ping — latency in ms, lower is better">
                        <StackPanel HorizontalAlignment="Center" Margin="0,-2,0,-2">
                          <TextBlock Text="Ping" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                          <TextBlock x:Name="TxtSpeedPing" Text="—" FontSize="22" FontWeight="Black"
                                     Foreground="{DynamicResource AccentBrush}" TextAlignment="Center"/>
                          <TextBlock Text="ms" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="3" Background="{DynamicResource BgInputBrush}"
                              CornerRadius="8" Padding="10,10"
                              ToolTip="Jitter — ping variation, under 5ms = stable">
                        <StackPanel HorizontalAlignment="Center" Margin="0,-2,0,-2">
                          <TextBlock Text="〰 Jitter" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                          <TextBlock x:Name="TxtSpeedJitter" Text="—" FontSize="22" FontWeight="Black"
                                     Foreground="{StaticResource YellowBrush}" TextAlignment="Center"/>
                          <TextBlock Text="ms" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                      </Border>
                    </Grid>

                    <!-- Rating + server -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                      <TextBlock x:Name="TxtSpeedRating" Text="" FontSize="13" FontWeight="Bold"
                                 Foreground="{StaticResource GreenBrush}" VerticalAlignment="Center"/>
                      <TextBlock x:Name="TxtSpeedServer" Text="" FontSize="11" Margin="12,0,0,0"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- Right: Speed History -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="14,12" VerticalAlignment="Stretch">
                  <StackPanel>
                    <TextBlock Text="History" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <!-- History chart -->
                    <Border x:Name="SpeedHistoryPanel" Visibility="Visible"
                            Background="{DynamicResource BgHoverBrush}" CornerRadius="8" Padding="8,6">
                      <StackPanel>
                        <Canvas x:Name="SpeedHistoryCanvas" Height="80" Background="Transparent"
                                SizeChanged="SpeedHistoryCanvas_SizeChanged"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                          <Ellipse Width="7" Height="7" Fill="{StaticResource GreenBrush}" Margin="0,0,4,0"
                                   VerticalAlignment="Center"/>
                          <TextBlock Text="DL" FontSize="9" Margin="0,0,10,0"
                                     Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                          <Ellipse Width="7" Height="7" Fill="{DynamicResource AccentBrush}" Margin="0,0,4,0"
                                   VerticalAlignment="Center"/>
                          <TextBlock Text="UL" FontSize="9"
                                     Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                      </StackPanel>
                    </Border>
                    <!-- History list (last 5) -->
                    <StackPanel x:Name="SpeedHistoryList" Margin="0,8,0,0"/>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- ════════════════════════════════════════════════
                   SUB-TAB: DIAGNOSE
                   ════════════════════════════════════════════════ -->
<Grid x:Name="NetPaneDiagnose" Grid.Row="1" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab bar: Ping Monitor | Traceroute -->
                <Border Grid.Row="0" Margin="0,0,0,12"
                        Background="{DynamicResource BgInputBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                  <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnDiagSubPing" Tag="Ping"
                            Click="DiagSubTab_Click"
                            Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonActiveStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1,12 C1,12 5,6 12,6 C19,6 23,12 23,12 C23,12 19,18 12,18 C5,18 1,12 1,12 Z M12,15 A3,3 0 1 1 12,9 A3,3 0 1 1 12,15 Z"/></Canvas></Viewbox><TextBlock Text="Ping Monitor" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="BtnDiagSubTrace" Tag="Trace"
                            Click="DiagSubTab_Click"
                            Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1,4 V10 H7 M23,20 V14 H17 M20.49,9 A9,9 0 0 0 5.64,5.64 L1,10 M23,14 L18.36,18.36 A9,9 0 0 1 3.51,15"/></Canvas></Viewbox><TextBlock Text="Traceroute" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="BtnDiagSubDns" Tag="DNS"
                            Click="DiagSubTab_Click"
                            Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M2,12 H22 M12,2 C9.5,7 9.5,17 12,22 C14.5,17 14.5,7 12,2 Z"/></Canvas></Viewbox><TextBlock Text="DNS Lookup" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  </StackPanel>
                </Border>

                <!-- Tab content area -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="14,12">
                  <Grid>

                    <!-- ── PING MONITOR tab ── -->
                    <Grid x:Name="DiagPanePing">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      <!-- Header row -->
                      <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Ping Monitor" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <!-- Interval pills -->
                        <Border Grid.Column="1" Margin="0,0,8,0"
                                Background="{DynamicResource BgInputBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                          <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnPingInterval1m" Tag="1"
                                    Click="PingInterval_Click" Padding="8,4" FontSize="10" FontWeight="SemiBold" Cursor="Hand"
                                    ToolTip="Show last 1 minute"
                          Style="{StaticResource SubTabButtonActiveStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="1m" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                            <Button x:Name="BtnPingInterval5m" Tag="5"
                                    Click="PingInterval_Click" Padding="8,4" FontSize="10" FontWeight="SemiBold" Cursor="Hand"
                                    ToolTip="Show last 5 minutes"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="5m" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                            <Button x:Name="BtnPingInterval10m" Tag="10"
                                    Click="PingInterval_Click" Padding="8,4" FontSize="10" FontWeight="SemiBold" Cursor="Hand"
                                    ToolTip="Show last 10 minutes"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="10m" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                            <Button x:Name="BtnPingInterval1h" Tag="60"
                                    Click="PingInterval_Click" Padding="8,4" FontSize="10" FontWeight="SemiBold" Cursor="Hand"
                                    ToolTip="Show last 1 hour"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,6 V12 L15,15"/></Canvas></Viewbox><TextBlock Text="1h" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                          </StackPanel>
                        </Border>
                        <TextBox x:Name="TxtAutoPingHost" Grid.Column="2" Width="110" Text="8.8.8.8"
                                 Margin="0,0,6,0" Padding="5,4" FontSize="11" VerticalAlignment="Center"/>
                        <Button x:Name="BtnAutoPingStart" Grid.Column="3" 
                                Style="{StaticResource OutlineButtonStyle}"
                                Click="StartAutoPing_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5,3 L19,12 L5,21 Z"/></Canvas></Viewbox><TextBlock Text="Start" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      </Grid>
                      <!-- Live ping value -->
                      <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtPingLive" Text="—" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource GreenBrush}"/>
                        <TextBlock Text=" ms" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                        <TextBlock x:Name="TxtPingLoss" Text="" FontSize="11"
                                   Foreground="{DynamicResource StatusErrorBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                      </StackPanel>
                      <!-- Chart -->
                      <Canvas x:Name="PingChartCanvas" Grid.Row="2" Background="Transparent"
                              MinHeight="200"
                              SizeChanged="PingChart_SizeChanged"/>
                      <!-- Stats row -->
                      <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock x:Name="TxtPingMin" Text="Min: —" FontSize="10" Margin="0,0,14,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtPingAvg" Text="Avg: —" FontSize="10" Margin="0,0,14,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtPingMax" Text="Max: —" FontSize="10" Margin="0,0,14,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </Grid>

                    <!-- ── TRACEROUTE tab ── -->
                    <StackPanel x:Name="DiagPaneTrace" Visibility="Collapsed">
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtTracerouteHost" Text="8.8.8.8" FontSize="12" Padding="6,5"/>
                        <Button x:Name="BtnRunTraceroute" Grid.Column="1" 
                                Style="{StaticResource OutlineButtonStyle}"
                                Click="RunTraceroute_Click" Margin="6,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1,4 V10 H7 M23,20 V14 H17 M20.49,9 A9,9 0 0 0 5.64,5.64 L1,10 M23,14 L18.36,18.36 A9,9 0 0 1 3.51,15"/></Canvas></Viewbox><TextBlock Text="Trace" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      </Grid>
                      <TextBlock x:Name="TxtTracerouteStatus" Text="" FontSize="11"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                      <DataGrid x:Name="TracerouteGrid" AutoGenerateColumns="False"
                                IsReadOnly="True" CanUserAddRows="False"
                                HeadersVisibility="Column" GridLinesVisibility="None"
                                RowHeaderWidth="0" BorderThickness="0" FontSize="11"
                                RowHeight="28" ColumnHeaderHeight="30" MaxHeight="400">
                        <DataGrid.Columns>
                          <DataGridTextColumn Header="#" Binding="{Binding Hop}" Width="40"/>
                          <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120"/>
                          <DataGridTextColumn Header="Host" Binding="{Binding Hostname}" Width="*"/>
                          <DataGridTemplateColumn Header="RTT" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding RttDisplay}" Foreground="{Binding RttColor}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0"/>
                              </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                          </DataGridTemplateColumn>
                        </DataGrid.Columns>
                      </DataGrid>
                    </StackPanel>

                    <!-- ── DNS LOOKUP tab ── -->
                    <StackPanel x:Name="DiagPaneDns" Visibility="Collapsed">
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtDnsHost" Text="google.com" FontSize="12" Padding="6,5"
                                 VerticalAlignment="Center"/>
                        <Button x:Name="BtnRunDns" Grid.Column="1" 
                                Style="{StaticResource SmallButtonStyle}"
                                Click="RunDnsLookup_Click" Margin="6,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M2,12 H22 M12,2 C9.5,7 9.5,17 12,22 C14.5,17 14.5,7 12,2 Z"/></Canvas></Viewbox><TextBlock Text="Lookup" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      </Grid>
                      <TextBlock x:Name="TxtDnsStatus" Text="" FontSize="11"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                      <Border x:Name="DnsResultBorder" Visibility="Collapsed"
                              Background="{DynamicResource BgInputBrush}" CornerRadius="10" Padding="14,12">
                        <StackPanel>
                          <TextBlock x:Name="TxtDnsHostResult" FontSize="15" FontWeight="Bold"
                                     Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"
                                     TextWrapping="Wrap"/>
                          <ItemsControl x:Name="DnsAddressList">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="6"
                                        Margin="0,3" Padding="12,8">
                                  <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}"
                                             Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding}" FontSize="14" FontFamily="Consolas"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                      <!-- Quick presets -->
                      <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Quick: " FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button Content="8.8.8.8" Style="{StaticResource SmallButtonStyle}" Margin="0,0,4,0"
                                Tag="8.8.8.8" Click="DnsPreset_Click"/>
                        <Button Content="1.1.1.1" Style="{StaticResource SmallButtonStyle}" Margin="0,0,4,0"
                                Tag="1.1.1.1" Click="DnsPreset_Click"/>
                        <Button Content="google.com" Style="{StaticResource SmallButtonStyle}" Margin="0,0,4,0"
                                Tag="google.com" Click="DnsPreset_Click"/>
                        <Button Content="cloudflare.com" Style="{StaticResource SmallButtonStyle}"
                                Tag="cloudflare.com" Click="DnsPreset_Click"/>
                      </StackPanel>
                    </StackPanel>

                  </Grid>
                </Border>
              </Grid>

                            <!-- ════════════════════════════════════════════════
                   SUB-TAB: SCANNERS
                   ════════════════════════════════════════════════ -->
              <StackPanel x:Name="NetPaneScanners" Grid.Row="1" Visibility="Collapsed">

                <!-- Sub-tab pills: Port / LAN / WiFi / LAN Speed -->
                <Border Margin="0,0,0,12"
                        Background="{DynamicResource BgInputBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                  <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnScanSubPorts" Tag="Ports"
                            Click="ScanSubTab_Click" Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonActiveStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5,14 H3 A2,2 0 0 1 1,12 V8 A2,2 0 0 1 3,6 H21 A2,2 0 0 1 23,8 V12 A2,2 0 0 1 21,14 H19 M8,14 V20 M16,14 V20 M8,20 H16"/></Canvas></Viewbox><TextBlock Text="Port Scanner" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="BtnScanSubLan" Tag="Lan"
                            Click="ScanSubTab_Click" Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M9,17 V18 A3,3 0 0 1 3,18 V17 H9 Z M21,17 V18 A3,3 0 0 1 15,18 V17 H21 Z M12,7 V17 M6,17 H18 M2,7 H22 A2,2 0 0 0 22,5 H2 Z"/></Canvas></Viewbox><TextBlock Text="LAN Scanner" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="BtnScanSubWifi" Tag="Wifi"
                            Click="ScanSubTab_Click" Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,20 H12.01 M5,12.55 A11,11 0 0 1 19,12.55 M1.42,9 A16,16 0 0 1 22.58,9 M8.53,16.11 A6,6 0 0 1 15.47,16.11"/></Canvas></Viewbox><TextBlock Text="WiFi" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="BtnScanSubLanSpeed" Tag="LanSpeed"
                            Click="ScanSubTab_Click" Padding="14,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 0 1 21.9,12 M12,12 L16,8"/></Canvas></Viewbox><TextBlock Text="LAN Speed Test" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  </StackPanel>
                </Border>

                <!-- Port Scanner pane -->
                <Border x:Name="ScanPanePorts" Style="{StaticResource CardStyle}" Padding="14,12"
                        Margin="0,0,0,10">
                  <StackPanel>
                    <WrapPanel Margin="0,0,0,8">
                      <TextBlock Text="Host" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,4"/>
                      <TextBox x:Name="TxtPortScanHost" Width="110" Padding="5,4" Margin="0,0,12,4"
                               Text="127.0.0.1" FontSize="11" VerticalAlignment="Center"/>
                      <TextBlock Text="Ports" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,4"/>
                      <TextBox x:Name="TxtPortStart" Width="48" Text="1" Margin="0,0,4,4" Padding="5,4"
                               FontSize="11" VerticalAlignment="Center"/>
                      <TextBlock Text="–" VerticalAlignment="Center" Margin="0,0,4,4"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBox x:Name="TxtPortStop" Width="48" Text="1024" Margin="0,0,10,4" Padding="5,4"
                               FontSize="11" VerticalAlignment="Center"/>
                      <Button x:Name="BtnRunPortScan" 
                              Style="{StaticResource OutlineButtonStyle}"
                              Click="RunPortScan_Click" Margin="0,0,10,4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5,14 H3 A2,2 0 0 1 1,12 V8 A2,2 0 0 1 3,6 H21 A2,2 0 0 1 23,8 V12 A2,2 0 0 1 21,14 H19 M8,14 V20 M16,14 V20 M8,20 H16"/></Canvas></Viewbox><TextBlock Text="Scan" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      <TextBlock x:Name="TxtPortScanStatus" Text="" FontSize="11"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </WrapPanel>
                    <DataGrid x:Name="PortScanGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="None"
                              RowHeaderWidth="0" BorderThickness="0" FontSize="11"
                              RowHeight="28" ColumnHeaderHeight="30" MaxHeight="260">
                      <DataGrid.Columns>
                        <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="55"/>
                        <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="50"/>
                        <DataGridTemplateColumn Header="State" Width="80">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding State}" Foreground="{Binding StateColor}"
                                         FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="90"/>
                        <DataGridTextColumn Header="Risk" Binding="{Binding Risk}" Width="*"/>
                      </DataGrid.Columns>
                    </DataGrid>
                  </StackPanel>
                </Border>

                <!-- LAN Scanner pane -->
                <Border x:Name="ScanPaneLan" Style="{StaticResource CardStyle}" Padding="14,12"
                        Margin="0,0,0,10" Visibility="Collapsed">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                      <TextBlock Text="Subnet" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,4"/>
                      <Grid Width="110" Margin="0,0,10,4" VerticalAlignment="Center">
                        <TextBox x:Name="TxtLanScanSubnet" Padding="5,4" FontSize="11"/>
                        <TextBlock Text="auto-detect" FontSize="11" Padding="7,4" IsHitTestVisible="False"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"
                                   VerticalAlignment="Center">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Visibility" Value="Collapsed"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtLanScanSubnet}" Value="">
                                  <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Grid>
                      <Button x:Name="BtnRunLanScan" 
                      ToolTip="Scan your local network for active devices — shows IP, MAC address and hostname"
                              Style="{StaticResource OutlineButtonStyle}"
                              Click="RunLanScan_Click" Margin="0,0,6,4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M9,17 V18 A3,3 0 0 1 3,18 V17 H9 Z M21,17 V18 A3,3 0 0 1 15,18 V17 H21 Z M12,7 V17 M6,17 H18 M2,7 H22 A2,2 0 0 0 22,5 H2 Z"/></Canvas></Viewbox><TextBlock Text="Scan" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      <TextBlock x:Name="TxtLanScanStatus" Text="" FontSize="11"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </WrapPanel>
                    <ProgressBar Grid.Row="1" x:Name="PbLanScan" Height="3" Margin="0,0,0,8"
                                 Minimum="0" Maximum="100" Value="0" IsIndeterminate="False"/>
                    <DataGrid Grid.Row="2" x:Name="LanScanGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="None"
                              RowHeaderWidth="0" BorderThickness="0" FontSize="11"
                              RowHeight="28" ColumnHeaderHeight="30">
                      <DataGrid.Columns>
                        <DataGridTemplateColumn Header="●" Width="32">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" VerticalAlignment="Center"/>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="115"/>
                        <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="*"/>
                        <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="100"/>
                        <DataGridTextColumn Header="Ping" Binding="{Binding PingMs}" Width="60"/>
                      </DataGrid.Columns>
                    </DataGrid>
                  </Grid>
                </Border>

                <!-- WiFi Analyzer pane -->
                <Border x:Name="ScanPaneWifi" Style="{StaticResource CardStyle}" Padding="14,12"
                        Margin="0,0,0,10" Visibility="Collapsed">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Button x:Name="BtnScanWifi" Grid.Column="0"
                              Style="{StaticResource SmallButtonStyle}"
                              Background="{DynamicResource AccentBrush}" Foreground="White"
                              Click="ScanWifi_Click" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/></Canvas></Viewbox>
                          <TextBlock Text="Scan" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Button>
                      <TextBlock x:Name="TxtWifiStatus" Grid.Column="1" Text="Press Scan to detect networks."
                                 FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center"/>
                    </Grid>
                    <!-- WiFi DataGrid — fills available space, scrolls only when needed -->
                    <DataGrid Grid.Row="1" x:Name="WifiGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="None"
                              RowHeaderWidth="0" BorderThickness="0" FontSize="11"
                              RowHeight="28" ColumnHeaderHeight="30"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                      <DataGrid.Columns>
                        <DataGridTextColumn Header="SSID" Binding="{Binding Ssid}" Width="*" MinWidth="120"/>
                        <DataGridTextColumn Header="Band" Binding="{Binding Band}" Width="Auto" MinWidth="50"/>
                        <DataGridTextColumn Header="Ch" Binding="{Binding Channel}" Width="Auto" MinWidth="35"/>
                        <DataGridTextColumn Header="Security" Binding="{Binding Security}" Width="Auto" MinWidth="80"/>
                        <DataGridTextColumn Header="Signal %" Binding="{Binding SignalPct}" Width="Auto" MinWidth="60">
                          <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{Binding SignalColor}"/>
                              <Setter Property="FontWeight" Value="SemiBold"/>
                              <Setter Property="VerticalAlignment" Value="Center"/>
                              <Setter Property="Margin" Value="4,0"/>
                            </Style>
                          </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- 5-bar signal strength column -->
                        <DataGridTemplateColumn Header="Signal" Width="70">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <Grid Width="54" Height="20" Margin="2,0" VerticalAlignment="Center">
                                <Rectangle Width="6" Height="4" Fill="{Binding Bar1Color}" HorizontalAlignment="Left" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1" Margin="0,0,0,0"/>
                                <Rectangle Width="6" Height="8" Fill="{Binding Bar2Color}" HorizontalAlignment="Left" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1" Margin="12,0,0,0"/>
                                <Rectangle Width="6" Height="12" Fill="{Binding Bar3Color}" HorizontalAlignment="Left" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1" Margin="24,0,0,0"/>
                                <Rectangle Width="6" Height="16" Fill="{Binding Bar4Color}" HorizontalAlignment="Left" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1" Margin="36,0,0,0"/>
                                <Rectangle Width="6" Height="20" Fill="{Binding Bar5Color}" HorizontalAlignment="Left" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1" Margin="48,0,0,0"/>
                              </Grid>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                      </DataGrid.Columns>
                    </DataGrid>
                    <!-- Show More / Show Less -->
                    <Button x:Name="BtnWifiShowMore" Grid.Row="2"
                            Style="{StaticResource OutlineButtonStyle}"
                            Padding="10,5" FontSize="10" Margin="0,6,0,0"
                            HorizontalAlignment="Center" Visibility="Collapsed"
                            Click="BtnWifiShowMore_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,20 H12.01 M5,12.55 A11,11 0 0 1 19,12.55 M1.42,9 A16,16 0 0 1 22.58,9 M8.53,16.11 A6,6 0 0 1 15.47,16.11"/></Canvas></Viewbox><TextBlock Text="Show all networks" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  </Grid>
                </Border>

                <!-- LAN Speed Test pane -->
                <Border x:Name="ScanPaneLanSpeed" Style="{StaticResource CardStyle}" Padding="14,12"
                        Margin="0,0,0,10" Visibility="Collapsed">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal">
                      <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4 M8.0,12.0 A4.0,4.0 0 1 1 16.0,12.0 A4.0,4.0 0 1 1 8.0,12.0 Z"/></Canvas></Viewbox>
                      <TextBlock Text="LAN Speed Test" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    </StackPanel>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10">
                      <Run Text="On PC-B: press "/>
                      <Run Text="Start Server" FontWeight="SemiBold"/>
                      <Run Text=". On PC-A: press "/>
                      <Run Text="Find Server" FontWeight="SemiBold"/>
                      <Run Text=" to discover automatically, or type the IP manually."/>
                    </TextBlock>
                    <!-- Row 1: Server + Discovery -->
                    <WrapPanel Margin="0,0,0,8">
                      <Button x:Name="BtnLanSpeedServer" 
                              Style="{StaticResource SmallButtonStyle}"
                              Click="ToggleLanSpeedServer_Click" Margin="0,0,8,4"
                              ToolTip="Start a TCP server on this PC so the other PC can connect.">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,6 A2,2 0 0 1 19,8 H5 A2,2 0 0 1 3,6 V4 A2,2 0 0 1 5,2 H19 A2,2 0 0 1 21,4 Z M3,10 H21 M3,18 H21 A2,2 0 0 0 21,16 H3 A2,2 0 0 0 3,18 Z M7,5.5 H7.01 M7,13.5 H7.01"/></Canvas></Viewbox><TextBlock Text="Start Server" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      <Button x:Name="BtnLanSpeedDiscover" 
                              Style="{StaticResource SmallButtonStyle}"
                              Click="DiscoverLanSpeedServer_Click" Margin="0,0,8,4"
                              ToolTip="Scan the local network for a PC running SMDWin server mode.">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M15,10 A5,5 0 1 1 5,10 A5,5 0 1 1 15,10 Z"/></Canvas></Viewbox><TextBlock Text="Find Server" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      <TextBlock x:Name="TxtLanSpeedDiscoverStatus" Text="" FontSize="11"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" Margin="0,0,0,4"/>
                    </WrapPanel>
                    <!-- Row 2: IP + Duration + Run/Stop -->
                    <WrapPanel Margin="0,0,0,8">
                      <TextBlock Text="Target IP" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,4"/>
                      <Grid Width="130" Margin="0,0,10,4" VerticalAlignment="Center">
                        <TextBox x:Name="TxtLanSpeedIp" Padding="5,4" FontSize="11"/>
                        <TextBlock Text="auto-discover or type IP" FontSize="10" Padding="7,4" IsHitTestVisible="False"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"
                                   VerticalAlignment="Center">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Visibility" Value="Collapsed"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtLanSpeedIp}" Value="">
                                  <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Grid>
                      <TextBlock Text="Duration" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,4"/>
                      <TextBox x:Name="TxtLanSpeedDuration" Width="40" Text="5" Padding="5,4" FontSize="11"
                               Margin="0,0,4,4" VerticalAlignment="Center"/>
                      <TextBlock Text="s" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" Margin="0,0,12,4"/>
                      <Button x:Name="BtnLanSpeedRun" 
                              Style="{StaticResource OutlineButtonStyle}"
                              Click="RunLanSpeedTest_Click" Margin="0,0,10,4"
                              ToolTip="Connect to the server PC and measure TCP throughput.">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 0 1 21.9,12 M12,12 L16,8"/></Canvas></Viewbox><TextBlock Text="Run Test" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    </WrapPanel>
                    <!-- Progress -->
                    <Border Height="2" CornerRadius="1" Background="{DynamicResource BgInputBrush}" Margin="0,0,0,6">
                      <Border x:Name="LanSpeedProgressBar" Height="2" CornerRadius="1"
                              Background="{DynamicResource AccentBrush}" HorizontalAlignment="Left" Width="0"/>
                    </Border>
                    <TextBlock x:Name="TxtLanSpeedStatus" Text="Start a server on PC-B, then Find Server or enter IP."
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"
                               FontFamily="Consolas"/>
                    <!-- Result tiles -->
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Border Grid.Column="0" Background="{DynamicResource BgInputBrush}"
                              CornerRadius="8" Padding="12,10" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                          <TextBlock Text="Download" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                          <TextBlock x:Name="TxtLanSpeedDown" Text="—" FontSize="26" FontWeight="Black"
                                     Foreground="{StaticResource GreenBrush}" TextAlignment="Center"/>
                          <TextBlock Text="Mbps" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="1" Background="{DynamicResource BgInputBrush}"
                              CornerRadius="8" Padding="12,10" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                          <TextBlock Text="Upload" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                          <TextBlock x:Name="TxtLanSpeedUp" Text="—" FontSize="26" FontWeight="Black"
                                     Foreground="{DynamicResource AccentBrush}" TextAlignment="Center"/>
                          <TextBlock Text="Mbps" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="2" Background="{DynamicResource BgInputBrush}"
                              CornerRadius="8" Padding="12,10">
                        <StackPanel HorizontalAlignment="Center">
                          <TextBlock Text="Ping" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                          <TextBlock x:Name="TxtLanSpeedPing" Text="—" FontSize="26" FontWeight="Black"
                                     Foreground="{StaticResource YellowBrush}" TextAlignment="Center"/>
                          <TextBlock Text="ms" FontSize="9" TextAlignment="Center"
                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                      </Border>
                    </Grid>
                    <!-- Log -->
                    <TextBlock Text="Log" FontSize="10" FontWeight="SemiBold" Opacity="0.5"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtLanSpeedLog" IsReadOnly="True" TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="10" Height="80"
                             Background="{DynamicResource BgDarkBrush}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                             Padding="8" VerticalScrollBarVisibility="Auto"/>
                  </StackPanel>
                </Border>

              </StackPanel><!-- /NetPaneScanners -->

              <!-- ════════ SUB-TAB: WIFI PASSWORDS ════════ -->
              <StackPanel x:Name="NetPaneWifiPasswords" Grid.Row="1" Visibility="Collapsed">
                <Border Style="{StaticResource CardStyle}" Padding="0">
                  <StackPanel>
                    <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="12,12,0,0" Padding="16,10">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M5 12.55a11 11 0 0 1 14.08 0 M1.42 9a16 16 0 0 1 21.16 0 M8.53 16.11a6 6 0 0 1 6.95 0 M12,20 L12.01,20"/></Canvas></Viewbox>
                            <TextBlock Text="WiFi Saved Networks" FontSize="13" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                          </StackPanel>
                          <TextBlock Text="Saved WiFi networks on this PC, with passwords"
                                     FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button x:Name="BtnWifiExportCsv" Grid.Column="1"
                                Style="{StaticResource OutlineButtonStyle}"
                                Padding="10,5" Height="28" Margin="0,0,8,0"
                                Click="WifiExportCsv_Click"
                                ToolTip="Export list to CSV file"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M12,15 L12,3 M7,10 L12,15 L17,10"/></Canvas></Viewbox><TextBlock Text="Export CSV" VerticalAlignment="Center"/></StackPanel></Button>
                        <Button x:Name="BtnWifiScan" Grid.Column="2"
                                Style="{StaticResource AppButtonStyle}"
                                Padding="12,5" Height="28"
                                Click="WifiScan_Click"
                                ToolTip="Read saved WiFi networks (requires Admin)"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/></Canvas></Viewbox><TextBlock Text="Scan" VerticalAlignment="Center"/></StackPanel></Button>
                      </Grid>
                    </Border>
                    <Border Background="{DynamicResource BgHoverBrush}" Padding="12,6" Margin="0,1,0,0">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" MinWidth="120"/>
                          <ColumnDefinition Width="140"/>
                          <ColumnDefinition Width="100"/>
                          <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Network (SSID)" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Grid.Column="0"/>
                        <TextBlock Text="Password" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Grid.Column="1"/>
                        <TextBlock Text="Security" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Grid.Column="2"/>
                        <TextBlock Text="Actions" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Grid.Column="3"
                                   HorizontalAlignment="Center"/>
                      </Grid>
                    </Border>
                    <StackPanel x:Name="WifiPasswordsList" Margin="0"/>
                    <TextBlock x:Name="TxtWifiEmpty"
                               Text="Press Scan to view saved WiFi networks."
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="16,20,16,20" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </StackPanel><!-- /NetPaneWifiPasswords -->

              <!-- Hidden compat elements for code-behind -->
              <TextBlock x:Name="TxtMtuResult" Visibility="Collapsed"/>
              <TextBlock x:Name="TxtNetUtilStatus" Visibility="Collapsed"/>

            </Grid>
          </ScrollViewer>

                    <ScrollViewer x:Name="NetTabSecurity" Grid.Row="2" Visibility="Collapsed"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,10,20,20">
              <Border Style="{StaticResource CardStyle}" Padding="14,12">
                <StackPanel>
                  <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal">
                        <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z M9,12 L11,14 L15,10"/></Canvas></Viewbox>
                        <TextBlock Text="Firewall Rules" FontSize="14" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                      </StackPanel>
                      <TextBlock Text="Windows Defender Firewall — inbound &amp; outbound"
                                 FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                 Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0"
                                 Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                      <TextBox x:Name="TxtFirewallFilter" Width="200" Margin="0,0,10,0"
                               TextChanged="TxtFirewallFilter_TextChanged"
                               ToolTip="Filter by name, direction, action…"/>
                      <Button x:Name="BtnLoadFirewall" 
                              Style="{StaticResource AppButtonStyle}"
                              Click="LoadFirewallRules_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 L21,5 V12 C21,17 12,22 12,22 C12,22 3,17 3,12 V5 Z M9,12 L11,14 L15,9"/></Canvas></Viewbox><TextBlock Text="Load Rules" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    </StackPanel>
                  </Grid>
                  <TextBlock x:Name="TxtFirewallStatus"
                             Text="Press 'Load Rules' to view Windows Firewall rules."
                             FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                             Margin="0,0,0,8"/>
                  <Border x:Name="FirewallSectionContent" Visibility="Visible">
                    <DataGrid x:Name="FirewallGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" MaxHeight="520"
                              BorderThickness="0" GridLinesVisibility="None"
                              RowHeight="30" ColumnHeaderHeight="32" FontSize="11">
                      <DataGrid.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="✔ Allow this rule" Click="FirewallAllow_ContextClick"/>
                          <MenuItem Header="🚫 Block / Deny this rule" Click="FirewallDeny_ContextClick"/>
                          <Separator/>
                          <MenuItem Header="Reload rules" Click="LoadFirewallRules_Click"/>
                        </ContextMenu>
                      </DataGrid.ContextMenu>
                      <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Dir" Width="40">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding DirectionIcon}" FontSize="14"
                                         ToolTip="{Binding Direction}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Action" Width="70">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding Action}"
                                         Foreground="{Binding ActionColor}"
                                         FontWeight="SemiBold"
                                         VerticalAlignment="Center"/>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Rule Name"
                                            Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="App"
                                            Binding="{Binding AppName}" Width="120"/>
                        <DataGridTextColumn Header="Protocol"
                                            Binding="{Binding Protocol}" Width="70"/>
                        <DataGridTextColumn Header="Local Port"
                                            Binding="{Binding LocalPorts}" Width="90"/>
                        <DataGridTextColumn Header="Profile"
                                            Binding="{Binding Profile}" Width="90"/>
                        <DataGridTemplateColumn Header="On" Width="35">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding EnabledText}"
                                         Foreground="{Binding EnabledColor}"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="160">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0">
                                <Button Content="Allow" Tag="{Binding}"
                                        Click="FirewallAllow_Click"
                                        Padding="6,2" Margin="0,0,4,0" FontSize="10" Height="22"
                                        Cursor="Hand"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ActionGreenBrush}" BorderThickness="1" BorderBrush="{DynamicResource ActionGreenBrush}">
                                  <Button.Style>
                                    <Style TargetType="Button">
                                      <Setter Property="Template">
                                        <Setter.Value>
                                          <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                TextElement.Foreground="{TemplateBinding Foreground}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.82"/></Trigger>
                                              <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.65"/></Trigger>
                                            </ControlTemplate.Triggers>
                                          </ControlTemplate>
                                        </Setter.Value>
                                      </Setter>
                                    </Style>
                                  </Button.Style>
                                </Button>
                                <Button Content="Deny" Tag="{Binding}"
                                        Click="FirewallDeny_Click"
                                        Padding="6,2" FontSize="10" Height="22"
                                        Cursor="Hand"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ActionRedBrush}" BorderThickness="1" BorderBrush="{DynamicResource ActionRedBrush}">
                                  <Button.Style>
                                    <Style TargetType="Button">
                                      <Setter Property="Template">
                                        <Setter.Value>
                                          <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                TextElement.Foreground="{TemplateBinding Foreground}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.82"/></Trigger>
                                              <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.65"/></Trigger>
                                            </ControlTemplate.Triggers>
                                          </ControlTemplate>
                                        </Setter.Value>
                                      </Setter>
                                    </Style>
                                  </Button.Style>
                                </Button>
                              </StackPanel>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                      </DataGrid.Columns>
                      <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{x:Null}"/>
                      </DataGrid.InputBindings>
                    </DataGrid>
                  </Border>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <!-- Hidden compat stubs (referenced in old code-behind) -->
          <Button x:Name="BtnLanScan" Visibility="Collapsed" Click="OpenLanScan_Click"/>
          <Button x:Name="BtnLanSpeed" Visibility="Collapsed" Click="OpenLanSpeed_Click"/>
          <Button x:Name="BtnToggleFirewallSection" Visibility="Collapsed" Click="ToggleFirewallSection_Click"/>
          <Button x:Name="BtnTogglePingSection" Visibility="Collapsed" Click="TogglePingSection_Click"/>
          <Border x:Name="PingSectionContent" Visibility="Collapsed"/>
          <Button x:Name="BtnTogglePortScanSection" Visibility="Collapsed" Click="TogglePortScanSection_Click"/>
          <Border x:Name="PortScanSectionContent" Visibility="Collapsed"/>
          <TextBlock x:Name="TxtFirewallSectionArrow" Visibility="Collapsed"/>
          <TextBlock x:Name="TxtPingSectionArrow" Visibility="Collapsed"/>
          <TextBlock x:Name="TxtPortScanSectionArrow" Visibility="Collapsed"/>
          <TextBlock x:Name="TxtPingMonLabel" Visibility="Collapsed"/>
          <TextBlock x:Name="TxtPortScanLabel" Visibility="Collapsed"/>

          <!-- ── NETWORK APPS TAB ── -->
          <Grid x:Name="NetTabApps" Grid.Row="2" Visibility="Collapsed">
            <Grid Margin="20,10,20,20">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <!-- Header + refresh -->
              <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Network Apps" FontSize="16" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock Text="Applications with active network connections — double-click for details, right-click to analyze"
                             FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0" Opacity="0.7"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock x:Name="TxtNetAppsStatus" Text="" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                  <Button x:Name="BtnRefreshNetApps" Style="{StaticResource SmallButtonStyle}"
                          Click="RefreshNetApps_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></Canvas></Viewbox>
                      <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Grid>

              <!-- Apps DataGrid — umple toată înălțimea rămasă, fără spațiu gol -->
              <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid x:Name="NetAppsGrid" CanUserResizeColumns="True"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="None"
                          RowHeaderWidth="0" BorderThickness="0" FontSize="11"
                          RowHeight="30" ColumnHeaderHeight="32"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MouseDoubleClick="NetAppsGrid_DoubleClick"
                          PreviewMouseRightButtonUp="NetAppsGrid_RightClick">
                  <DataGrid.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Show connection details" Click="NetAppsDetails_Click">
                        <MenuItem.Icon>
                          <Viewbox Width="14" Height="14"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" Fill="Transparent" Data="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8zM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/></Canvas></Viewbox>
                        </MenuItem.Icon>
                      </MenuItem>
                      <MenuItem Header="Analyze process →" Click="NetAppsAnalyzeProcess_Click">
                        <MenuItem.Icon>
                          <Viewbox Width="14" Height="14"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" Fill="Transparent" Data="M2 20h.01M7 20v-4M12 20v-8M17 20V8M22 4v16"/></Canvas></Viewbox>
                        </MenuItem.Icon>
                      </MenuItem>
                      <Separator/>
                      <MenuItem Header="🚫  Block outbound traffic" Click="NetAppsBlock_Click">
                        <MenuItem.Icon>
                          <Viewbox Width="14" Height="14"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource StatusErrorBrush}" StrokeThickness="1.8" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M18.36 6.64a9 9 0 1 1-12.73 0M12 2v10"/></Canvas></Viewbox>
                        </MenuItem.Icon>
                      </MenuItem>
                      <MenuItem Header="✔  Unblock (remove rule)" Click="NetAppsUnblock_Click">
                        <MenuItem.Icon>
                          <Viewbox Width="14" Height="14"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource StatusSuccessBrush}" StrokeThickness="1.8" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4L12 14.01l-3-3"/></Canvas></Viewbox>
                        </MenuItem.Icon>
                      </MenuItem>
                    </ContextMenu>
                  </DataGrid.ContextMenu>
                  <DataGrid.Columns>
                    <DataGridTemplateColumn Header="●" Width="24">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- 5.5 Category icon+label -->
                    <DataGridTemplateColumn Header="Cat." Width="115" SortMemberPath="AppCategory">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                            <TextBlock Text="{Binding CategoryIcon}" FontSize="11" Margin="0,0,3,0"/>
                            <TextBlock Text="{Binding AppCategory}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding CategoryColor}"/>
                          </StackPanel>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="*" MinWidth="120" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="58"/>
                    <DataGridTemplateColumn Header="🚫" Width="30" ToolTipService.ToolTip="Firewall blocked">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding BlockedIcon}" FontSize="11" VerticalAlignment="Center"
                                     HorizontalAlignment="Center" ToolTip="{Binding BlockedDisplay}"/>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- 5.5 Quick Block/Unblock button -->
                    <DataGridTemplateColumn Header="Firewall" Width="88">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Button Tag="{Binding}" Click="NetAppsQuickBlock_Click"
                                  Padding="4,2" FontSize="10"
                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button.Style>
                              <Style TargetType="Button" BasedOn="{StaticResource AppButtonStyle}">
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                    <Setter Property="Content" Value="✔ Unblock"/>
                                  </DataTrigger>
                                  <DataTrigger Binding="{Binding IsBlocked}" Value="False">
                                    <Setter Property="Content" Value="🚫 Block"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Button.Style>
                          </Button>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="65"/>
                    <DataGridTextColumn Header="Conns"    Binding="{Binding ConnectionCount}" Width="48"/>
                    <DataGridTextColumn Header="Local"    Binding="{Binding LocalEndpoint}"   Width="160"/>
                    <DataGridTextColumn Header="Remote"   Binding="{Binding RemoteEndpoint}"  Width="160"/>
                    <DataGridTextColumn Header="State"    Binding="{Binding State}"           Width="105"/>
                    <DataGridTemplateColumn Header="↑ Send" Width="80" SortMemberPath="SendKBs">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding SendDisplay}" Foreground="{Binding SendColor}"
                                     FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="↓ Recv" Width="80" SortMemberPath="RecvKBs">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding RecvDisplay}" Foreground="{Binding RecvColor}"
                                     FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                </DataGrid>
              </Border>
            </Grid>
          </Grid>
        </Grid>
        <!-- ── APPS ── -->
        <Grid x:Name="PanelApps" Visibility="Collapsed" Margin="24" Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock x:Name="TxtAppsTitle" Grid.Row="0" Text="Installed Applications"
                     Style="{StaticResource SectionTitleStyle}"/>
          <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14,10">
            <WrapPanel>
              <TextBox x:Name="TxtAppSearch" Width="200" Margin="0,0,10,0"/>
              <Button x:Name="BtnSearchApps" 
                      Style="{StaticResource OutlineButtonStyle}" Click="SearchApps_Click" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M3,11 A8,8 0 1 1 19,11 A8,8 0 1 1 3,11 Z"/></Canvas></Viewbox><TextBlock Text="Search" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <TextBlock x:Name="TxtAppsCount" VerticalAlignment="Center" FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </WrapPanel>
          </Border>
          <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="AppsGrid" CanUserResizeColumns="True" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserSortColumns="True" RowHeight="30" ColumnHeaderHeight="32" FontSize="12"
                      GridLinesVisibility="None" BorderThickness="0">
              <DataGrid.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Uninstall" Click="UninstallApp_Click"/>
                  <MenuItem Header="Programs &amp; Features" Click="OpenAddRemovePrograms_Click"/>
                </ContextMenu>
              </DataGrid.ContextMenu>
              <DataGrid.Columns>
                <DataGridTextColumn Header="Application" Binding="{Binding Name}" Width="*" MinWidth="160"/>
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="115"/>
                <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="190"/>
                <DataGridTextColumn Header="Installed" Binding="{Binding InstallDate}" Width="100"/>
                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="80"/>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
          <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,8,0,0" Padding="10,7">
            <StackPanel Orientation="Horizontal">
              <Button x:Name="BtnReloadApps"
                      Style="{StaticResource OutlineButtonStyle}" Click="LoadApps_Click" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></Canvas></Viewbox>
                  <TextBlock Text="Reload" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="BtnUninstall"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="UninstallApp_Click" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6 M10 11v6 M14 11v6 M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2 M3,6 L5,6 L21,6"/></Canvas></Viewbox>
                  <TextBlock Text="Uninstall" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="BtnAddRemove"
                      Style="{StaticResource OutlineButtonStyle}" 
                      Click="OpenAddRemovePrograms_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M4.5,3 H8.5 A1.5,1.5 0 0 1 10,4.5 V8.5 A1.5,1.5 0 0 1 8.5,10 H4.5 A1.5,1.5 0 0 1 3,8.5 V4.5 A1.5,1.5 0 0 1 4.5,3 Z M15.5,3 H19.5 A1.5,1.5 0 0 1 21,4.5 V8.5 A1.5,1.5 0 0 1 19.5,10 H15.5 A1.5,1.5 0 0 1 14,8.5 V4.5 A1.5,1.5 0 0 1 15.5,3 Z M4.5,14 H8.5 A1.5,1.5 0 0 1 10,15.5 V19.5 A1.5,1.5 0 0 1 8.5,21 H4.5 A1.5,1.5 0 0 1 3,19.5 V15.5 A1.5,1.5 0 0 1 4.5,14 Z M15.5,14 H19.5 A1.5,1.5 0 0 1 21,15.5 V19.5 A1.5,1.5 0 0 1 19.5,21 H15.5 A1.5,1.5 0 0 1 14,19.5 V15.5 A1.5,1.5 0 0 1 15.5,14 Z"/></Canvas></Viewbox>
                  <TextBlock Text="Programs &amp; Features" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
        </Grid>

        <!-- ── SERVICES (Toggle buttons for Update/SysMain/Search) ── -->
        <Grid x:Name="PanelServices" Visibility="Collapsed" Margin="24" Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock x:Name="TxtServicesTitle" Grid.Row="0" Text="Windows Services"
                     Style="{StaticResource SectionTitleStyle}"/>
          <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="10,8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <!-- View filters -->
              <Button x:Name="BtnKeyServices" Grid.Column="0" 
                      Style="{StaticResource SubTabButtonActiveStyle}"
                      Click="LoadKeyServices_Click" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,2 L14,9 M11,12 A4,4 0 1 0 3,12 A4,4 0 1 0 11,12 Z M14,9 L16,11 M18,7 L20,9"/></Canvas></Viewbox><TextBlock Text="Key Services" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnAllServices" Grid.Column="1" 
                      Style="{StaticResource OutlineButtonStyle}" 
                      Click="LoadAllServices_Click" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M8,6 H21 M8,12 H21 M8,18 H21 M3,6 H3.01 M3,12 H3.01 M3,18 H3.01"/></Canvas></Viewbox><TextBlock Text="All Services" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnServicesMsc" Grid.Column="2" 
                      Style="{StaticResource OutlineButtonStyle}" 
                      Click="OpenServicesMsc_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,15 A3,3 0 1 0 12,9 A3,3 0 1 0 12,15 Z M19.4,15 L19,15.2 A1.65,1.65 0 0 0 18.9,17 L19.2,17.6 A2,2 0 1 1 16,19.6 L15.5,19 A1.65,1.65 0 0 0 14,19.6 H13.5 A2,2 0 1 1 10.5,19.6 H10 A1.65,1.65 0 0 0 8.5,19 L8,19.6 A2,2 0 1 1 4.8,17.6 L5.1,17 A1.65,1.65 0 0 0 5,15.2 L4.6,15 A1.65,1.65 0 0 0 4,14 H3.5 A2,2 0 1 1 3.5,10 H4 A1.65,1.65 0 0 0 4.6,9 L5,8.8 A1.65,1.65 0 0 0 5.1,7 L4.8,6.4 A2,2 0 1 1 8,4.4 L8.5,5 A1.65,1.65 0 0 0 10,4.4 H10.5 A2,2 0 1 1 13.5,4.4 H14 A1.65,1.65 0 0 0 15.5,5 L16,4.4 A2,2 0 1 1 19.2,6.4 L18.9,7 A1.65,1.65 0 0 0 19,8.8 L19.4,9 A1.65,1.65 0 0 0 20,10 H20.5 A2,2 0 1 1 20.5,14 H20 A1.65,1.65 0 0 0 19.4,15 Z"/></Canvas></Viewbox><TextBlock Text="services.msc" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <!-- Divider -->
              <Border Grid.Column="3" Width="1" Background="{DynamicResource BorderBrush2}" Margin="8,4"/>
              <!-- Quick toggles label -->
              <TextBlock x:Name="TxtQuickActLabel" Grid.Column="4" Text="Quick toggles:"
                         VerticalAlignment="Center" Margin="0,0,10,0"
                         Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
              <Button x:Name="BtnToggleUpdate" Grid.Column="6" 
                      Style="{StaticResource ToggleButtonStyle}"
                      Click="ToggleWindowsUpdate_Click" Margin="0,0,6,0"
                      ToolTip="Toggle Windows Update ON/OFF">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1,4 V10 H7 M23,20 V14 H17 M20.49,9 A9,9 0 0 0 5.64,5.64 L1,10 M23,14 L18.36,18.36 A9,9 0 0 1 3.51,15"/></Canvas></Viewbox><TextBlock Text="Win Update: ?" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnBlockWinVersion" Grid.Column="7" 
                      Style="{StaticResource ToggleButtonStyle}"
                      Click="BlockCurrentWinVersion_Click" Margin="0,0,6,0"
                      ToolTip="Blocks upgrade to the next major Windows version via Group Policy (gpedit). Keeps current version (e.g. 24H2) — security updates still work. Click again to unblock.">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M19,11 H5 A2,2 0 0 0 3,13 V20 A2,2 0 0 0 5,22 H19 A2,2 0 0 0 21,20 V13 A2,2 0 0 0 19,11 Z M7,11 V7 A5,5 0 0 1 17,7 V11"/></Canvas></Viewbox><TextBlock Text="Block Win Version" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnToggleSysMain" Grid.Column="8" 
                      Style="{StaticResource ToggleButtonStyle}"
                      Click="ToggleSysMain_Click" Margin="0,0,6,0"
                      ToolTip="Toggle SysMain (Superfetch) ON/OFF">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 V12 M5.636,5.636 A9,9 0 1 0 18.364,5.636"/></Canvas></Viewbox><TextBlock Text="SysMain: ?" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnToggleWinSearch" Grid.Column="9" 
                      Style="{StaticResource ToggleButtonStyle}"
                      Click="ToggleWindowsSearch_Click" Margin="0,0,6,0"
                      ToolTip="Toggle Windows Search ON/OFF">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M3,11 A8,8 0 1 1 19,11 A8,8 0 1 1 3,11 Z"/></Canvas></Viewbox><TextBlock Text="Win Search: ?" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              <Button x:Name="BtnDisableTelemetry" Grid.Column="10" 
                      Style="{StaticResource ToggleButtonStyle}"
                      Click="DisableTelemetry_Click"
                      ToolTip="Disables DiagTrack, dmwappushservice and sets telemetry registry keys to 0. This stops Windows from sending usage data to Microsoft. Can be re-enabled from Services.">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,22 C12,22 3,18 3,12 V5 L12,2 L21,5 V12 C21,18 12,22 12,22 Z M9,9 L15,15 M15,9 L9,15"/></Canvas></Viewbox><TextBlock Text="Telemetry OFF" VerticalAlignment="Center"/></StackPanel>
                    </Button>
            </Grid>
          </Border>
          <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="ServicesGrid" CanUserResizeColumns="True" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserSortColumns="True" RowHeight="30" ColumnHeaderHeight="32" FontSize="12"
                      GridLinesVisibility="None" BorderThickness="0">
              <DataGrid.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Start"       Click="StartService_Click"/>
                  <MenuItem Header="■ Stop"      Click="StopService_Click"/>
                  <Separator/>
                  <MenuItem Header="Set Manual"    Click="SetManual_Click"/>
                  <MenuItem Header="Set Automatic" Click="SetAutomatic_Click"/>
                  <MenuItem Header="Disable"       Click="DisableService_Click"/>
                </ContextMenu>
              </DataGrid.ContextMenu>
              <DataGrid.Columns>
                <DataGridTemplateColumn Header="Risc" Width="110" SortMemberPath="RiskLevel">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border CornerRadius="4" Padding="6,2" Margin="4,4" HorizontalAlignment="Left"
                              ToolTip="{Binding RiskLabel, Mode=OneWay}">
                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                   Foreground="{Binding RiskColor, Mode=OneWay}">
                          <Run Text="{Binding RiskIcon, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding RiskLabel, Mode=OneWay}"/>
                        </TextBlock>
                      </Border>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Serviciu"    Binding="{Binding DisplayName}" Width="*"   MinWidth="150"/>
                <DataGridTextColumn Header="Nume intern" Binding="{Binding Name}"        Width="130"/>
                <DataGridTemplateColumn Header="Status" Width="100">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}"
                                 FontWeight="SemiBold" FontSize="11" Margin="8,0"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Pornire" Width="100">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding StartType}" Foreground="{Binding StartColor}" FontSize="11" Margin="8,0"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Descriere" Binding="{Binding Description}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
          <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,8,0,0" Padding="10,7">
            <StackPanel Orientation="Horizontal">
              <Button x:Name="BtnStartService"
                      ToolTip="Start the selected Windows service"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="StartService_Click" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource ChartGreenBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M8,5.14 L19,12 L8,18.86 Z"/></Canvas></Viewbox>
                  <TextBlock Text="Start" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="BtnStopService"
                      ToolTip="Stop the selected Windows service"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="StopService_Click" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="11" Height="11" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource StatusErrorBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5,5 H19 V19 H5 Z"/></Canvas></Viewbox>
                  <TextBlock Text="Stop" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="BtnSetManual"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="SetManual_Click" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 L2,7 L12,12 L22,7 Z M2,17 L12,22 L22,17 M2,12 L12,17 L22,12"/></Canvas></Viewbox>
                  <TextBlock Text="Manual" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="BtnDisableService"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="DisableService_Click" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource StatusErrorBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M18.36 6.64a9 9 0 1 1-12.73 0 M12 2v10"/></Canvas></Viewbox>
                  <TextBlock Text="Disabled" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="BtnSetAutomatic"
                      Style="{StaticResource OutlineButtonStyle}"
                      Click="SetAutomatic_Click" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource ChartGreenBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12 M9.0,12.0 A3.0,3.0 0 1 1 15.0,12.0 A3.0,3.0 0 1 1 9.0,12.0 Z"/></Canvas></Viewbox>
                  <TextBlock Text="Automatic" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <!-- 5.3 Apply Safe Optimizations -->
              <Button Style="{StaticResource OutlineButtonStyle}"
                      Click="ApplySafeServiceOptimizations_Click"
                      Padding="12,5"
                      ToolTip="Dezactivează automat serviciile pre-selectate low-risk (Telemetrie, Fax, Xbox etc.)">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource ChartGreenBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M9,12 L11,14 L15,10 M12,22 C12,22 3,18 3,12 V5 L12,2 L21,5 V12 C21,18 12,22 12,22 Z"/></Canvas></Viewbox>
                  <TextBlock Text="Apply Safe Optimizations" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
        </Grid>

        <!-- ── SETTINGS ── -->
        <ScrollViewer x:Name="PanelSettings" Visibility="Collapsed">
          <StackPanel Margin="24">
            <Grid Margin="0,0,0,20">
              <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TxtSettingsTitle" Text="SMD Win Settings"
                           FontSize="20" FontWeight="Bold" FontFamily="{StaticResource AppFontDisplay}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Appearance • Behavior • Thresholds • Advanced"
                           FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0" Opacity="0.6"/>
              </StackPanel>
            </Grid>

            <!-- ══ ROW 1: VISUAL THEME + LANGUAGE + TEMPERATURE ══ -->
            <Grid Margin="0,0,0,14">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- VISUAL THEME -->
              <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z M9.0,12.0 A3.0,3.0 0 1 1 15.0,12.0 A3.0,3.0 0 1 1 9.0,12.0 Z"/></Canvas></Viewbox>
                    <TextBlock x:Name="TxtThemeLabel" Text="Visual Theme"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                  </StackPanel>
                  <!-- ── Dark / Light toggle pill ── -->
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <!-- Dark button -->
                    <Button x:Name="BtnThemeDark" Style="{StaticResource ThemeSwatchStyle}" Click="SetTheme_Click"
                            Tag="Dark" Margin="0,0,6,0" ToolTip="Dark theme" Padding="10,7">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center">
                          <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.7"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                          </Canvas>
                        </Viewbox>
                        <TextBlock Text="Dark" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                      </StackPanel>
                    </Button>
                    <!-- Light button -->
                    <Button x:Name="BtnThemeLight" Style="{StaticResource ThemeSwatchStyle}" Click="SetTheme_Click"
                            Tag="Light" Margin="0,0,6,0" ToolTip="Light theme" Padding="10,7">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center">
                          <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.7"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41 M9,12 A3,3 0 1 1 15,12 A3,3 0 1 1 9,12 Z"/>
                          </Canvas>
                        </Viewbox>
                        <TextBlock Text="Light" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                      </StackPanel>
                    </Button>
                    <!-- Auto button -->
                    <Button x:Name="BtnAutoTheme" Style="{StaticResource ThemeSwatchStyle}"
                            Click="BtnAutoTheme_Click" Tag="Auto" Padding="10,7"
                            ToolTip="Follows Windows dark/light mode automatically — animates on change">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center">
                          <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.7"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12 M9,12 A3,3 0 1 1 15,12 A3,3 0 1 1 9,12 Z"/>
                          </Canvas>
                        </Viewbox>
                        <TextBlock Text="Auto" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                      </StackPanel>
                    </Button>
                  </StackPanel>

                  <!-- ── Accent color row ── -->
                  <TextBlock Text="Accent Color" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <!-- Blue -->
                    <Button x:Name="BtnAccentBlue" Tag="Blue" Click="SetAccent_Click"
                            Width="30" Height="30" Margin="0,0,8,0" Cursor="Hand"
                            ToolTip="Blue accent" BorderThickness="2" BorderBrush="Transparent"
                            Background="Transparent" Padding="0">
                      <Button.Template>
                        <ControlTemplate TargetType="Button">
                          <Border x:Name="Bd" Width="26" Height="26" CornerRadius="13"
                                  Background="{DynamicResource WinBlueBrush}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                              <DropShadowEffect Color="{DynamicResource WinBlueColor}" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                              <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Button.Template>
                    </Button>
                    <!-- Red -->
                    <Button x:Name="BtnAccentRed" Tag="Red" Click="SetAccent_Click"
                            Width="30" Height="30" Margin="0,0,8,0" Cursor="Hand"
                            ToolTip="Red accent" BorderThickness="2" BorderBrush="Transparent"
                            Background="Transparent" Padding="0">
                      <Button.Template>
                        <ControlTemplate TargetType="Button">
                          <Border x:Name="Bd" Width="26" Height="26" CornerRadius="13"
                                  Background="{DynamicResource ActionRedBrush}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}">
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                              <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Button.Template>
                    </Button>
                    <!-- Green -->
                    <Button x:Name="BtnAccentGreen" Tag="Green" Click="SetAccent_Click"
                            Width="30" Height="30" Margin="0,0,8,0" Cursor="Hand"
                            ToolTip="Green accent" BorderThickness="2" BorderBrush="Transparent"
                            Background="Transparent" Padding="0">
                      <Button.Template>
                        <ControlTemplate TargetType="Button">
                          <Border x:Name="Bd" Width="26" Height="26" CornerRadius="13"
                                  Background="{DynamicResource ActionGreenBrush}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}">
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                              <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Button.Template>
                    </Button>
                    <!-- Orange -->
                    <Button x:Name="BtnAccentOrange" Tag="Orange" Click="SetAccent_Click"
                            Width="30" Height="30" Margin="0,0,0,0" Cursor="Hand"
                            ToolTip="Orange accent" BorderThickness="2" BorderBrush="Transparent"
                            Background="Transparent" Padding="0">
                      <Button.Template>
                        <ControlTemplate TargetType="Button">
                          <Border x:Name="Bd" Width="26" Height="26" CornerRadius="13"
                                  Background="{DynamicResource ChartOrangeBrush}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}">
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                              <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Button.Template>
                    </Button>
                  </StackPanel>

                  <TextBlock x:Name="TxtCurrentTheme" FontSize="11" Margin="0,2,0,0"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <CheckBox x:Name="ChkAutoTheme" Visibility="Collapsed"
                            Checked="ChkAutoTheme_Changed" Unchecked="ChkAutoTheme_Changed"/>
                  <!-- Widget size toggle -->
                  <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,10,0,10" Opacity="0.4"/>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Widget:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <RadioButton x:Name="BtnWidgetCompact" Tag="Graphs"
                            GroupName="WidgetModeGroup"
                            Style="{StaticResource UnderlineChipStyle}"
                            ToolTip="4 mini sparkline charts — CPU, RAM, Disk, Network"
                            Checked="WidgetModeChip_Click" Margin="0,0,4,0">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M8,3 H3 V8 M21,3 H16 V8 M3,16 V21 H8 M16,21 H21 V16"/></Canvas></Viewbox>
                        <TextBlock Text="Graphs" VerticalAlignment="Center"/>
                      </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="BtnWidgetGauges" Tag="Gauges"
                            GroupName="WidgetModeGroup"
                            Style="{StaticResource UnderlineChipStyle}"
                            ToolTip="Interactive arc meters for CPU, RAM, Disk and Network"
                            Checked="WidgetModeChip_Click" Margin="0">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 3.52,16.5 M12,12 A2,2 0 1 1 12,8 M12,12 L8,9"/></Canvas></Viewbox>
                        <TextBlock Text="Gauges" VerticalAlignment="Center"/>
                      </StackPanel>
                    </RadioButton>
                    <TextBlock x:Name="TxtWidgetModeVal" Visibility="Collapsed" Text="Graphs"/>
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- LANGUAGE -->
              <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z M2,12 L22,12 M2.0,12.0 A10.0,10.0 0 1 1 22.0,12.0 A10.0,10.0 0 1 1 2.0,12.0 Z"/></Canvas></Viewbox>
                    <TextBlock x:Name="TxtLangLabel" Text="Language / Limbă"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                  </StackPanel>
                  <!-- Language buttons + Import button on same row -->
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <WrapPanel x:Name="LangPacksPanel" VerticalAlignment="Center"/>
                    <Button x:Name="BtnImportLang" Grid.Column="1"
                            Style="{StaticResource OutlineButtonStyle}" Margin="8,0,0,0"
                            Click="ImportLang_Click" Padding="12,6" Height="30">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12.87,15.07 L10.33,12.56 L10.36,12.53 A17.52,17.52 0 0 0 13.07,8 H16 V6 H9 V4 H7 V6 H0 V8 H11.17 A16.65,16.65 0 0 1 8,13.41 A16.14,16.14 0 0 1 5.94,11 H3.94 A18.22,18.22 0 0 0 6.72,14.77 L1.38,20.06 L2.8,21.47 L8,16.25 L11.11,19.36 Z M18.5,10 H16.5 L12,22 H14 L15.12,19 H19.87 L21,22 H23 Z M15.88,17 L17.5,12.67 L19.12,17 Z"/></Canvas></Viewbox><TextBlock Text="Import Language Pack (.json)" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  </Grid>
                  <TextBlock x:Name="TxtCurrentLang" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}" Text="Current language: English"/>
                  <TextBlock x:Name="TxtLangImportHint" Visibility="Collapsed" Text=""/>
                </StackPanel>
              </Border>

              <!-- TEMPERATURE THRESHOLDS (3rd column) -->
              <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z M11.5,7 L12.5,7 M11.5,10 L12.5,10"/></Canvas></Viewbox>
                    <TextBlock x:Name="TxtTempLabel" Text="Temperature Thresholds"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Text="CPU Warning" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtTempCpuVal" Visibility="Collapsed" Text="85"/>
                    <WrapPanel Orientation="Horizontal">
                      <RadioButton Content="80°C"  Tag="80"  GroupName="TempCpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempCpuBtn_Click" x:Name="BtnCpuTemp80"  Margin="0,0,4,0"/>
                      <RadioButton Content="85°C"  Tag="85"  GroupName="TempCpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempCpuBtn_Click" x:Name="BtnCpuTemp85"  Margin="0,0,4,0"/>
                      <RadioButton Content="90°C"  Tag="90"  GroupName="TempCpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempCpuBtn_Click" x:Name="BtnCpuTemp90"  Margin="0,0,4,0"/>
                      <RadioButton Content="95°C"  Tag="95"  GroupName="TempCpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempCpuBtn_Click" x:Name="BtnCpuTemp95"  Margin="0,0,4,0"/>
                      <RadioButton Content="100°C" Tag="100" GroupName="TempCpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempCpuBtn_Click" x:Name="BtnCpuTemp100" Margin="0"/>
                    </WrapPanel>
                  </StackPanel>
                  <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="GPU Warning" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtTempGpuVal" Visibility="Collapsed" Text="85"/>
                    <WrapPanel Orientation="Horizontal">
                      <RadioButton Content="80°C"  Tag="80"  GroupName="TempGpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempGpuBtn_Click" x:Name="BtnGpuTemp80"  Margin="0,0,4,0"/>
                      <RadioButton Content="85°C"  Tag="85"  GroupName="TempGpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempGpuBtn_Click" x:Name="BtnGpuTemp85"  Margin="0,0,4,0"/>
                      <RadioButton Content="90°C"  Tag="90"  GroupName="TempGpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempGpuBtn_Click" x:Name="BtnGpuTemp90"  Margin="0,0,4,0"/>
                      <RadioButton Content="95°C"  Tag="95"  GroupName="TempGpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempGpuBtn_Click" x:Name="BtnGpuTemp95"  Margin="0,0,4,0"/>
                      <RadioButton Content="100°C" Tag="100" GroupName="TempGpuGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempGpuBtn_Click" x:Name="BtnGpuTemp100" Margin="0"/>
                    </WrapPanel>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>

            <!-- ══ ROW 2: REPORTS FOLDER + GENERAL + BEHAVIOR (3 columns) ══ -->
            <Grid Margin="0,0,0,14">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- REPORTS FOLDER -->
              <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></Canvas></Viewbox>
                    <TextBlock Text="Reports Folder"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                  </StackPanel>
                  <TextBlock x:Name="TxtReportFolderLabel" Text="Where diagnostic reports are saved:"
                             Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,8"/>
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtReportPath" Margin="0,0,6,0" TextChanged="ReportPath_Changed"/>
                    <Button Grid.Column="1" Style="{StaticResource SmallButtonStyle}"
                            Background="{DynamicResource BgHoverBrush}" Click="BrowseReportPath_Click">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></Canvas></Viewbox>
                        <TextBlock Text="Browse" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- REFRESH INTERVAL -->
              <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12 M9.0,12.0 A3.0,3.0 0 1 1 15.0,12.0 A3.0,3.0 0 1 1 9.0,12.0 Z"/></Canvas></Viewbox>
                    <TextBlock x:Name="TxtGeneralLabel" Text="Refresh Interval"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                  </StackPanel>
                  <TextBlock Text="Applies to temperatures, processes and sensors"
                             FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                             Margin="0,0,0,10" Opacity="0.8"/>
                  <TextBlock x:Name="TxtRefreshLabel" Visibility="Collapsed" Text="Refresh interval"/>
                  <TextBlock x:Name="TxtRefreshVal" Visibility="Collapsed" Text="2s"/>
                  <WrapPanel x:Name="TempRefreshChipPanel" Orientation="Horizontal">
                    <RadioButton Content="0.5s" Tag="0.5" x:Name="RefreshChip05" GroupName="TempRefreshGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempRefreshChip_Click" Margin="0,0,4,0"/>
                    <RadioButton Content="1s"   Tag="1"   x:Name="RefreshChip1"  GroupName="TempRefreshGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempRefreshChip_Click" Margin="0,0,4,0"/>
                    <RadioButton Content="2s"   Tag="2"   x:Name="RefreshChip2"  GroupName="TempRefreshGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempRefreshChip_Click" Margin="0,0,4,0"/>
                    <RadioButton Content="3s"   Tag="3"   x:Name="RefreshChip3"  GroupName="TempRefreshGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempRefreshChip_Click" Margin="0,0,4,0"/>
                    <RadioButton Content="5s"   Tag="5"   x:Name="RefreshChip5"  GroupName="TempRefreshGroup" Style="{StaticResource UnderlineChipStyle}" Checked="TempRefreshChip_Click" Margin="0"/>
                  </WrapPanel>
                  <Slider x:Name="SliderRefresh" Visibility="Collapsed" Minimum="0.2" Maximum="5" Value="1" ValueChanged="SliderRefresh_ValueChanged"/>
                  <WrapPanel x:Name="ProcRefreshChipPanel" Visibility="Collapsed">
                    <Button Content="0.5s" Tag="0.5" Click="ProcRefreshChip_Click" Style="{StaticResource ChipButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="1s" Tag="1" Click="ProcRefreshChip_Click" x:Name="ProcChip1" Style="{StaticResource ChipButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="2s" Tag="2" Click="ProcRefreshChip_Click" Style="{StaticResource ChipButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="3s" Tag="3" Click="ProcRefreshChip_Click" Style="{StaticResource ChipButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="5s" Tag="5" Click="ProcRefreshChip_Click" Style="{StaticResource ChipButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="10s" Tag="10" Click="ProcRefreshChip_Click" Style="{StaticResource ChipButtonStyle}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtProcRefreshVal" Text="1s"/>
                  </WrapPanel>
                  <TextBlock x:Name="TxtTempRefreshVal" Visibility="Collapsed" Text="2s"/>
                </StackPanel>
              </Border>

              <!-- BEHAVIOR (3rd column) -->
              <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                <TextBlock Text="Behavior" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                <StackPanel>
                    <CheckBox x:Name="ChkAutoScan" Content="Auto-scan on startup"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              IsChecked="True"
                              ToolTip="Automatically run a system scan when SMD Win starts. Recommended: ON"
                              Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="ChkMinimize" Content="Minimize to system tray on close"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              IsChecked="True"
                              ToolTip="When you click X, the app goes to the system tray instead of closing. Recommended: ON"
                              Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="ChkStartWithWindows" Content="Start with Windows"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              ToolTip="Launch SMD Win automatically when Windows starts. Adds a registry entry to HKCU\Run."
                              Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="ChkTempNotif" Content="Notify when temperature exceeds threshold"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              IsChecked="True"
                              ToolTip="Show a Windows notification when CPU or GPU temperature exceeds the warning thresholds set below. Recommended: ON"
                              Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="ChkEnableNotifications" Content="Enable system notifications (throttle, temperature, network alerts)"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              IsChecked="True"
                              ToolTip="Master switch for all Windows toast notifications from SMD Win — throttling, temperature warnings, network alerts. Recommended: ON"
                              Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                </StackPanel>
                <CheckBox x:Name="ChkAnimations" Visibility="Collapsed" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                <Slider x:Name="SliderEventDays" Visibility="Collapsed" Minimum="1" Maximum="30" Value="7" ValueChanged="SliderEventDays_ValueChanged"/>
                <TextBlock x:Name="TxtEventDaysVal" Visibility="Collapsed" Text="7d"/>
              </StackPanel>
              </Border>
            </Grid>

            <!-- ══ DRIVER SEARCH + ADVANCED ══ -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
              <StackPanel>
                <StackPanel Orientation="Horizontal">
                  <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M21,21 L16.65,16.65 M3.0,11.0 A8.0,8.0 0 1 1 19.0,11.0 A8.0,8.0 0 1 1 3.0,11.0 Z"/></Canvas></Viewbox>
                  <TextBlock Text="Driver Search &amp; Advanced"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                </StackPanel>
                <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="When clicking 'Search online' for a driver, use which site?"/>
                <WrapPanel Margin="0,0,0,12">
                  <RadioButton x:Name="RbDriverSearchDrp" Content="drp.su  (large database)"
                               GroupName="DriverSearch" IsChecked="True"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,20,4"/>
                  <RadioButton x:Name="RbDriverSearchGoogle" Content="Google.com"
                               GroupName="DriverSearch"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                </WrapPanel>
                <Border Height="1" Background="{DynamicResource BorderBrush2}" Margin="0,0,0,12"/>
                <TextBlock Text="Diagnostics" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <WrapPanel>
                  <Button Style="{StaticResource SmallButtonStyle}" Margin="0,0,8,6"
                          ToolTip="Clears cached event log data" Click="ClearLogCache_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6M10 11v6M14 11v6"/></Canvas></Viewbox>
                      <TextBlock Text="Clear Log Cache" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Style="{StaticResource SmallButtonStyle}" Margin="0,0,8,6"
                          ToolTip="Export current settings to a JSON file" Click="ExportSettings_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M12 15V3M7 10l5 5 5-5"/></Canvas></Viewbox>
                      <TextBlock Text="Export Settings JSON" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Style="{StaticResource SmallButtonStyle}" Margin="0,0,0,6"
                          ToolTip="Import settings from a JSON file" Click="ImportSettings_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5-5 5 5M12 5v10"/></Canvas></Viewbox>
                      <TextBlock Text="Import Settings JSON" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </WrapPanel>
              </StackPanel>
            </Border>



            <!-- hidden compat -->
            <TextBlock x:Name="TxtReportPathLabel" Visibility="Collapsed"/>

            <Button x:Name="BtnSaveSettings"
                    Style="{StaticResource OutlineButtonStyle}"
                    HorizontalAlignment="Left" Click="SaveSettings_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M17,21 H7 A2,2 0 0 1 5,19 V5 A2,2 0 0 1 7,3 H14 L19,8 V19 A2,2 0 0 1 17,21 Z M7,3 V8 H15 M12,18 A3,3 0 1 0 12,12 A3,3 0 1 0 12,18 Z"/></Canvas></Viewbox><TextBlock Text="Save Settings" VerticalAlignment="Center"/></StackPanel>
                    </Button>
          </StackPanel>
        </ScrollViewer>
        <!-- ── PROCESS MONITOR ── -->
        <Grid x:Name="PanelProcesses" Visibility="Collapsed" Margin="24" Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title -->
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="Auto"/>  <!-- CPU/RAM summary -->
            <RowDefinition Height="*"/>     <!-- tab content -->
          </Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtProcessesTitle" Text="Process Monitor"
                       Style="{StaticResource SectionTitleStyle}"/>
            <!-- Process count moved to search bar area -->
          </Grid>
          <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <Button x:Name="BtnRefreshProc"
                    Style="{StaticResource OutlineButtonStyle}"
                    Click="RefreshProcesses_Click" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></Canvas></Viewbox>
                <TextBlock Text="Refresh" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="BtnProcKill"
                    Style="{StaticResource OutlineButtonStyle}"
                    Click="KillProcess_Click" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M18 6L6 18M6 6l12 12"/></Canvas></Viewbox>
                <TextBlock Text="Kill Process" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button x:Name="BtnAnalyzeProc"
                    Style="{StaticResource OutlineButtonStyle}"
                     Click="AnalyzeProcess_Click" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,21 L16.65,16.65 M3.0,11.0 A8.0,8.0 0 1 1 19.0,11.0 A8.0,8.0 0 1 1 3.0,11.0 Z"/></Canvas></Viewbox>
                <TextBlock Text="Analyze Process" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </WrapPanel>

          <!-- CPU / RAM / Disk / Net summary bar — 4 charts in one row -->
          <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="10,8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <!-- CPU -->
              <StackPanel Grid.Column="0">
                <Grid Margin="0,0,0,3">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Text="CPU" FontSize="10" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                  <TextBlock x:Name="TxtProcCpuTotal" Text="—%" Grid.Column="1" FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}"/>
                </Grid>
                <Border Background="{DynamicResource BgDarkBrush}" CornerRadius="4" Height="88" ClipToBounds="True">
                  <Canvas x:Name="ProcCpuMiniChart" Height="88" ClipToBounds="True"/>
                </Border>
              </StackPanel>
              <!-- RAM -->
              <StackPanel Grid.Column="2">
                <Grid Margin="0,0,0,3">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Text="RAM" FontSize="10" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                  <TextBlock x:Name="TxtProcRamUsed" Text="—" Grid.Column="1" FontSize="14" FontWeight="Bold"
                             Foreground="{StaticResource GreenBrush}"/>
                </Grid>
                <Border Background="{DynamicResource BgDarkBrush}" CornerRadius="4" Height="88" ClipToBounds="True">
                  <Canvas x:Name="ProcRamMiniChart" Height="88" ClipToBounds="True"/>
                </Border>
              </StackPanel>
              <!-- Disk I/O -->
              <StackPanel Grid.Column="4">
                <Grid Margin="0,0,0,3">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Text="Disk" FontSize="10" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                  <TextBlock x:Name="TxtProcDiskTotal" Text="—" Grid.Column="1" FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource StatusWarningBrush}"/>
                </Grid>
                <Border Background="{DynamicResource BgDarkBrush}" CornerRadius="4" Height="88" ClipToBounds="True">
                  <Canvas x:Name="ProcDiskMiniChart" Height="88" ClipToBounds="True"/>
                </Border>
              </StackPanel>
              <!-- Network -->
              <StackPanel Grid.Column="6">
                <Grid Margin="0,0,0,3">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Text="Net" FontSize="10" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                  <TextBlock x:Name="TxtProcNetTotal" Text="—" Grid.Column="1" FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}"/>
                </Grid>
                <Border Background="{DynamicResource BgDarkBrush}" CornerRadius="4" Height="88" ClipToBounds="True">
                  <Canvas x:Name="ProcNetMiniChart" Height="88" ClipToBounds="True"/>
                </Border>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Tabbed: Apps / Background / All -->
          <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid Grid.Row="0" Margin="12,10,12,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                  <Button x:Name="BtnTabApps"
                          Style="{StaticResource SubTabButtonActiveStyle}"
                          Click="TabApps_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3,3 H10 V10 H3 Z M14,3 H21 V10 H14 Z M3,14 H10 V21 H3 Z M14,17.5 A3.5,3.5 0 1 0 21,17.5 A3.5,3.5 0 1 0 14,17.5 Z"/></Canvas></Viewbox><TextBlock Text="Apps" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  <Button x:Name="BtnTabBackground"
                          Style="{StaticResource OutlineButtonStyle}" 
                          Click="TabBackground_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,3 H2 A1,1 0 0 0 1,4 V16 A1,1 0 0 0 2,17 H22 A1,1 0 0 0 23,16 V4 A1,1 0 0 0 22,3 Z M8,21 H16 M12,17 V21"/></Canvas></Viewbox><TextBlock Text="Background" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                  <Button x:Name="BtnTabAll"
                          Style="{StaticResource OutlineButtonStyle}" 
                          Click="TabAll_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M8,6 H21 M8,12 H21 M8,18 H21 M3,6 H3.01 M3,12 H3.01 M3,18 H3.01"/></Canvas></Viewbox><TextBlock Text="All" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock x:Name="TxtProcCount" Text="—" FontSize="18" FontWeight="Light"
                             FontFamily="Segoe UI Light" Foreground="{DynamicResource AccentBrush}"
                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                  <TextBlock x:Name="TxtProcCountLabel" Text="processes" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
              </Grid>
              <Border Grid.Row="1" Margin="12,8,12,6" Background="{DynamicResource BgInputBrush}"
                      BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                      CornerRadius="8" Padding="10,4" Opacity="0.85">
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBlock Text="" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBox x:Name="TxtProcSearch" Grid.Column="1" Background="Transparent"
                           BorderThickness="0" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextChanged="ProcSearch_TextChanged"/>
                </Grid>
              </Border>
              <DataGrid x:Name="ProcessesGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                        VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                        CanUserSortColumns="True" RowHeight="30" ColumnHeaderHeight="38" FontSize="12"
                        GridLinesVisibility="None" BorderThickness="0"
                        MouseDoubleClick="ProcessesGrid_DoubleClick"
                        Sorting="ProcessesGrid_Sorting">
                <DataGrid.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Analyze process" Click="AnalyzeProcess_Click"/>
                    <MenuItem Header="Pin as Widget" Click="PinProcessAsWidget_Click">
                      <MenuItem.Icon>
                        <Viewbox Width="14" Height="14"><Canvas Width="24" Height="24"><Path Fill="{DynamicResource TextPrimaryBrush}" Data="M16,12 V5.82C17.18,5.4 18,4.28 18,3 H6 C6,4.28 6.82,5.4 8,5.82 V12 L6,14 V16 H11.18 V22 L12,23 L12.82,22 V16 H18 V14 L16,12 Z"/></Canvas></Viewbox>
                      </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Kill process" Click="KillProcess_Click"/>
                  </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                  <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="55"/>
                  <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="*" MinWidth="120"/>
                  <DataGridTemplateColumn Header="CPU %" Width="115" SortMemberPath="CpuPct">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Grid Margin="4,0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/><ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="{Binding CpuDisplay}" Foreground="{Binding CpuColor}"
                                     FontWeight="SemiBold" VerticalAlignment="Center"/>
                          <Border Grid.Column="1" Background="{DynamicResource BgInputBrush}"
                                  CornerRadius="4" Height="5" Margin="2,0,4,0" VerticalAlignment="Center">
                            <Border CornerRadius="4" Height="5" Background="{Binding CpuColor}"
                                    HorizontalAlignment="Left" Width="{Binding CpuBarWidth}"/>
                          </Border>
                        </Grid>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="RAM" Width="130" SortMemberPath="RamMB">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Grid Margin="4,0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55"/><ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="{Binding RamDisplay}"
                                     Foreground="{StaticResource GreenBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                          <Border Grid.Column="1" Background="{DynamicResource BgInputBrush}"
                                  CornerRadius="4" Height="5" Margin="2,0,4,0" VerticalAlignment="Center">
                            <Border CornerRadius="4" Height="5" Background="{StaticResource GreenBrush}"
                                    HorizontalAlignment="Left" Width="{Binding RamBarWidth}"/>
                          </Border>
                        </Grid>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Threads" Binding="{Binding Threads}" Width="70"/>
                  <DataGridTextColumn Header="Handles" Binding="{Binding Handles}" Width="70"/>
                  <DataGridTemplateColumn Header="Disk R KB/s" Width="95" SortMemberPath="DiskReadKBs">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Margin="4,0" Text="{Binding DiskReadDisplay}"
                                   Foreground="{DynamicResource StatusWarningBrush}" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Disk W KB/s" Width="95" SortMemberPath="DiskWriteKBs">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Margin="4,0" Text="{Binding DiskWriteDisplay}"
                                   Foreground="{DynamicResource OrangeBrush}" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <!-- Net ↑ Send -->
                  <DataGridTemplateColumn Width="90" SortMemberPath="NetSentKBs">
                    <DataGridTemplateColumn.Header>
                      <TextBlock Text="Net ↑ KB/s" ToolTip="Per-process network tracking requires admin rights or ETW. Not available in standard mode."/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Margin="4,0" Text="N/A"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                   VerticalAlignment="Center"
                                   ToolTip="Per-process network data unavailable — requires elevated permissions"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <!-- Net ↓ Recv -->
                  <DataGridTemplateColumn Width="90" SortMemberPath="NetRecvKBs">
                    <DataGridTemplateColumn.Header>
                      <TextBlock Text="Net ↓ KB/s" ToolTip="Per-process network tracking requires admin rights or ETW. Not available in standard mode."/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Margin="4,0" Text="N/A"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                   VerticalAlignment="Center"
                                   ToolTip="Per-process network data unavailable — requires elevated permissions"/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Border>
        </Grid>

        
        <!-- ── STARTUP MANAGER ── -->
        <Grid x:Name="PanelStartup" Visibility="Collapsed" Margin="24" Style="{StaticResource PageFadeStyle}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Header row: title + Basic/Advanced toggle -->
          <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="TxtStartupTitle" Text="Startup Manager"
                       Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Basic / Advanced pill toggle -->
            <Border Grid.Column="1" CornerRadius="8"
                    Background="{DynamicResource BgInputBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    Padding="3" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnStartupBasic"
                        Tag="Basic"
                        Click="StartupViewToggle_Click"
                        Padding="10,5" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand"
                        ToolTip="Show only user-installed startup programs — like Task Manager Startup tab"
                          Style="{StaticResource SubTabButtonActiveStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M8,6 H21 M8,12 H21 M8,18 H21 M3,6 H3.01 M3,12 H3.01 M3,18 H3.01"/></Canvas></Viewbox><TextBlock Text="Basic" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                <Button x:Name="BtnStartupAdvanced"
                        Tag="Advanced"
                        Click="StartupViewToggle_Click"
                        Padding="10,5" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand"
                        ToolTip="Show all startup entries including system, scheduled tasks and registry locations"
                          Style="{StaticResource SubTabButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,15 A3,3 0 1 0 12,9 A3,3 0 1 0 12,15 Z M19.4,15 L19,15.2 A1.65,1.65 0 0 0 18.9,17 L19.2,17.6 A2,2 0 1 1 16,19.6 L15.5,19 A1.65,1.65 0 0 0 14,19.6 H13.5 A2,2 0 1 1 10.5,19.6 H10 A1.65,1.65 0 0 0 8.5,19 L8,19.6 A2,2 0 1 1 4.8,17.6 L5.1,17 A1.65,1.65 0 0 0 5,15.2 L4.6,15 A1.65,1.65 0 0 0 4,14 H3.5 A2,2 0 1 1 3.5,10 H4 A1.65,1.65 0 0 0 4.6,9 L5,8.8 A1.65,1.65 0 0 0 5.1,7 L4.8,6.4 A2,2 0 1 1 8,4.4 L8.5,5 A1.65,1.65 0 0 0 10,4.4 H10.5 A2,2 0 1 1 13.5,4.4 H14 A1.65,1.65 0 0 0 15.5,5 L16,4.4 A2,2 0 1 1 19.2,6.4 L18.9,7 A1.65,1.65 0 0 0 19,8.8 L19.4,9 A1.65,1.65 0 0 0 20,10 H20.5 A2,2 0 1 1 20.5,14 H20 A1.65,1.65 0 0 0 19.4,15 Z"/></Canvas></Viewbox><TextBlock Text="Advanced" VerticalAlignment="Center"/></StackPanel>
                    </Button>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Info text, changes based on mode -->
          <TextBlock x:Name="TxtStartupInfo" Grid.Row="1" Margin="0,0,0,10"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Text="Shows programs that start automatically when you log in. Double-click or use Enable/Disable to control them. Changes take effect at the next restart."/>

          <!-- Toolbar -->
          <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="10,8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <StackPanel Orientation="Horizontal" Grid.Column="0">
                <Button x:Name="BtnReloadStartup"
                        Style="{StaticResource SmallButtonStyle}"
                        Click="LoadStartup_Click" Margin="0,0,6,0">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></Canvas></Viewbox>
                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button x:Name="BtnEnableStartup"
                        Style="{StaticResource SmallButtonStyle}"
                        Click="EnableStartup_Click" Margin="0,0,6,0">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M20 6L9 17l-5-5"/></Canvas></Viewbox>
                    <TextBlock Text="Enable" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button x:Name="BtnDisableStartup"
                        Style="{StaticResource SmallButtonStyle}"
                        Click="DisableStartup_Click" Margin="0,0,6,0">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M18.36 6.64a9 9 0 1 1-12.73 0 M12 2v10"/></Canvas></Viewbox>
                    <TextBlock Text="Disable" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button x:Name="BtnRemoveStartup"
                        Style="{StaticResource SmallButtonStyle}"
                        Click="RemoveStartup_Click" Margin="0,0,6,0">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6 M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2 M3,6 L21,6"/></Canvas></Viewbox>
                    <TextBlock Text="Remove" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button x:Name="BtnOpenTaskMgr"
                        Style="{StaticResource SmallButtonStyle}"
                        Click="OpenTaskManager_Click">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,12 L18,12 L15,21 L9,3 L6,12 L2,12"/></Canvas></Viewbox>
                    <TextBlock Text="Task Manager" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>

              <TextBlock x:Name="TxtStartupCount" Grid.Column="2" Text=""
                         VerticalAlignment="Center" HorizontalAlignment="Right"
                         Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
            </Grid>
          </Border>

          <!-- BASIC grid — like Task Manager: Name, Status, Category, Exe -->
          <DataGrid x:Name="StartupGridBasic" CanUserResizeColumns="True" Grid.Row="3"
                    AutoGenerateColumns="False" CanUserAddRows="False"
                    IsReadOnly="True" SelectionMode="Single"
                    SelectionChanged="StartupGrid_SelectionChanged"
                    MouseDoubleClick="StartupGrid_DoubleClick"
                    HeadersVisibility="Column" GridLinesVisibility="None"
                    RowHeaderWidth="0" FontSize="12" BorderThickness="0"
                    RowHeight="30" ColumnHeaderHeight="34"
                    Visibility="Visible">
            <DataGrid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Enable"       Click="EnableStartup_Click"/>
                <MenuItem Header="Disable"      Click="DisableStartup_Click"/>
                <MenuItem Header="Remove entry" Click="RemoveStartup_Click"/>
              </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
              <!-- 5.4 One-click toggle button -->
              <DataGridTemplateColumn Header="" Width="80">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Button Tag="{Binding}" Click="QuickToggleStartup_Click"
                            Padding="6,2" FontSize="10"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource AppButtonStyle}">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                              <Setter Property="Content" Value="⏸ Disable"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                              <Setter Property="Content" Value="▶ Enable"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Button.Style>
                    </Button>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <!-- 5.4 Impact rating -->
              <DataGridTemplateColumn Header="Impact" Width="75" SortMemberPath="ImpactRating">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                      <TextBlock Text="{Binding ImpactIcon}" FontSize="10" Margin="0,0,3,0"/>
                      <TextBlock Text="{Binding ImpactRating}" FontSize="10" FontWeight="SemiBold"
                                 Foreground="{Binding ImpactColor}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <!-- 5.4 Source: System/Microsoft vs Third-party -->
              <DataGridTemplateColumn Header="Source" Width="130" SortMemberPath="SourceGroup">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding SourceGroup}" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding SourceColor}" VerticalAlignment="Center" Margin="4,0"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Application"  Binding="{Binding Name}"     Width="*"/>
              <DataGridTextColumn Header="Category"  Binding="{Binding Category}" Width="120"/>
              <DataGridTextColumn Header="Executable" Binding="{Binding ExeName}"  Width="180"/>
            </DataGrid.Columns>
          </DataGrid>

          <!-- ADVANCED grid — full detail: all columns + Risk -->
          <DataGrid x:Name="StartupGridAdvanced" CanUserResizeColumns="True" Grid.Row="3"
                    AutoGenerateColumns="False" CanUserAddRows="False"
                    IsReadOnly="True" SelectionMode="Single"
                    SelectionChanged="StartupGrid_SelectionChanged"
                    MouseDoubleClick="StartupGrid_DoubleClick"
                    HeadersVisibility="Column" GridLinesVisibility="None"
                    RowHeaderWidth="0" FontSize="12" BorderThickness="0"
                    RowHeight="32" ColumnHeaderHeight="34"
                    Visibility="Collapsed">
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="Status" Width="90">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"
                               FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn Header="Impact" Width="80" SortMemberPath="ImpactRating">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding ImpactColor}" VerticalAlignment="Center" Margin="4,0">
                      <Run Text="{Binding ImpactIcon}"/><Run Text=" "/><Run Text="{Binding ImpactRating}"/>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="180"/>
              <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="160"/>
              <DataGridTemplateColumn Header="Risk" Width="110">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding RiskLevel, Mode=OneWay}" Foreground="{Binding RiskColor, Mode=OneWay}"
                               FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Command" Binding="{Binding ShortCommand}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>

<ScrollViewer x:Name="PanelShutdown" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="24">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="TxtShutdownTitle" Text="Tools"
                       Style="{StaticResource SectionTitleStyle}"/>
            </StackPanel>

            <!-- ══ ROW 1: Shutdown Timer | Quick Commands ══ -->
            <Grid Margin="0,0,0,16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- Shutdown Timer -->
              <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <StackPanel>
                  <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="12,12,0,0" Padding="14,10">
                    <StackPanel Orientation="Horizontal">
                      <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M9,3 L15,3 M12,3 L12,5 M4.0,13.0 A8.0,8.0 0 1 1 20.0,13.0 A8.0,8.0 0 1 1 4.0,13.0 Z M12,9 L12,13 L15,13"/></Canvas></Viewbox>
                      <TextBlock Text="Shutdown Timer" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                  </Border>
                  <StackPanel Margin="14,12,14,14">
                    <!-- Row 1: presets + countdown inline on right -->
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <WrapPanel Grid.Column="0">
                        <Button Content="15 min" Style="{StaticResource OutlineButtonStyle}" Click="ShutdownPreset_Click" Tag="15" Margin="0,0,5,5" Padding="8,4" Height="26"/>
                        <Button Content="30 min" Style="{StaticResource OutlineButtonStyle}" Click="ShutdownPreset_Click" Tag="30" Margin="0,0,5,5" Padding="8,4" Height="26"/>
                        <Button Content="45 min" Style="{StaticResource OutlineButtonStyle}" Click="ShutdownPreset_Click" Tag="45" Margin="0,0,5,5" Padding="8,4" Height="26"/>
                        <Button Content="1h" Style="{StaticResource OutlineButtonStyle}" Click="ShutdownPreset_Click" Tag="60" Margin="0,0,5,5" Padding="8,4" Height="26"/>
                        <Button Content="2h" Style="{StaticResource OutlineButtonStyle}" Click="ShutdownPreset_Click" Tag="120" Margin="0,0,5,5" Padding="8,4" Height="26"/>
                        <Button Content="4h" Style="{StaticResource OutlineButtonStyle}" Click="ShutdownPreset_Click" Tag="240" Margin="0,0,0,5" Padding="8,4" Height="26"/>
                      </WrapPanel>
                      <!-- Countdown clock shown inline right -->
                      <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock x:Name="TxtShutdownCountdown" Text="--:--:--" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"
                                   TextAlignment="Right"/>
                        <TextBlock x:Name="TxtShutdownETA" Text="" FontSize="9" TextAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </Grid>
                    <!-- Row 2: minutes input + single Start/Stop button + status -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                      <TextBox x:Name="TxtShutdownMinutes" Width="60" Text="60"
                               VerticalContentAlignment="Center" FontSize="12" Padding="6,4" Height="30"/>
                      <TextBlock Text="min" VerticalAlignment="Center" Margin="6,0,10,0"
                                 Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                      <!-- Single toggle button: Start when idle, Stop when running -->
                      <Button x:Name="BtnStartShutdown"
                              Style="{StaticResource OutlineButtonStyle}"
                              Click="StartShutdownTimer_Click" Padding="14,0" Height="32" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 M12,6 V12 L16,14" Width="24" Height="24" Stretch="Uniform"/></Viewbox><TextBlock Text="Start Timer" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      <!-- Hidden cancel button — code toggles these -->
                      <Button x:Name="BtnCancelShutdown"
                              Style="{StaticResource OutlineButtonStyle}"
                              Click="CancelShutdownTimer_Click" Padding="14,0" Height="32" IsEnabled="False"
                              Visibility="Collapsed"
                              ToolTip="Cancel shutdown timer">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"><Path Stroke="{DynamicResource StatusErrorBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M18,6 L6,18 M6,6 L18,18" Width="24" Height="24" Stretch="Uniform"/></Viewbox><TextBlock Text="Stop Timer" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    </StackPanel>
                    <!-- Status + progress -->
                    <TextBlock x:Name="TxtShutdownStatus" Text="Timer inactiv" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <Border Background="{DynamicResource BorderBrush2}" CornerRadius="3" Height="5"
                            HorizontalAlignment="Stretch">
                      <Border x:Name="ShutdownProgressBar" Background="{DynamicResource AccentBrush}"
                              CornerRadius="3" Height="5" HorizontalAlignment="Left" Width="0"/>
                    </Border>
                    <TextBlock x:Name="TxtTimeRemainingLabel" Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtShutdownInfo" TextWrapping="Wrap" FontSize="9.5" Margin="0,8,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7">
                      Folosește <Bold>shutdown /s /f /t</Bold>. Cancel: <Bold>shutdown /a</Bold>
                    </TextBlock>
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- Quick Commands -->
              <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <StackPanel>
                  <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="12,12,0,0" Padding="14,10">
                    <StackPanel Orientation="Horizontal">
                      <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M12,19 L20,19 M4,17 L10,11 L4,5"/></Canvas></Viewbox>
                      <TextBlock Text="Quick Commands" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                  </Border>
                  <StackPanel Margin="14,10,14,14">
                    <TextBlock Text="System repair &amp; maintenance commands"
                               FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <WrapPanel>
                      <Button x:Name="BtnCmdSfc"
                              Style="{StaticResource OutlineButtonStyle}" Margin="0,0,6,6" Padding="10,5" Height="28"
                              ToolTip="sfc /scannow — Scans and repairs protected system files"
                              Click="WinCmd_Click" Tag="sfc /scannow">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M14,2 H6 A2,2 0 0 0 4,4 V20 A2,2 0 0 0 6,22 H18 A2,2 0 0 0 20,20 V8 Z M14,2 V8 H20 M9,13 L11,15 L15,11"/></Canvas></Viewbox><TextBlock Text="SFC" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      <Button x:Name="BtnCmdDism"
                              Style="{StaticResource OutlineButtonStyle}" Margin="0,0,6,6" Padding="10,5" Height="28"
                              ToolTip="DISM /Online /Cleanup-Image /RestoreHealth — repairs Windows image"
                              Click="WinCmd_Click" Tag="DISM /Online /Cleanup-Image /RestoreHealth">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M4,17 L8.5,12 L4,7 M11,19 H21"/></Canvas></Viewbox><TextBlock Text="DISM" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      <Button x:Name="BtnCmdChkdsk"
                              Style="{StaticResource OutlineButtonStyle}" Margin="0,0,6,6" Padding="10,5" Height="28"
                              ToolTip="Schedules chkdsk C: /f /r on next reboot"
                              Click="WinCmd_Click" Tag="CHKDSK_PROMPT">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M12,22 C12,22 3,18 3,12 V5 L12,2 L21,5 V12 C21,18 12,22 12,22 Z M9,12 L11,14 L15,10"/></Canvas></Viewbox><TextBlock Text="chkdsk" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      <Button x:Name="BtnCmdIconCache"
                              Style="{StaticResource OutlineButtonStyle}" Margin="0,0,6,6" Padding="10,5" Height="28"
                              ToolTip="Kills Explorer, deletes icon cache, restarts Explorer"
                              Click="WinCmd_Click" Tag="ICONCACHE">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M1,4 V10 H7 M23,20 V14 H17 M20.49,9 A9,9 0 0 0 5.64,5.64 L1,10 M23,14 L18.36,18.36 A9,9 0 0 1 3.51,15"/></Canvas></Viewbox><TextBlock Text="Rebuild Icons" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                      <Button x:Name="BtnCmdTempFiles"
                              Style="{StaticResource OutlineButtonStyle}" Margin="0,0,0,6" Padding="10,5" Height="28"
                              ToolTip="Deletes %TEMP% and Windows\Temp files"
                              Click="WinCmd_Click" Tag="CLEARTEMP">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3,6 H21 M19,6 L18,20 A2,2 0 0 1 16,22 H8 A2,2 0 0 1 6,20 L5,6 M9,6 V4 A1,1 0 0 1 10,3 H14 A1,1 0 0 1 15,4 V6"/></Canvas></Viewbox><TextBlock Text="Clear Temp" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    </WrapPanel>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>

            <!-- ══ ROW 2: Auto-Clean+Hibernate | Optimize ══ -->
            <Grid Margin="0,0,0,16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- Card 1: Space Cleanup (Auto-Clean + Hibernate) -->
              <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <StackPanel>
                  <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="12,12,0,0" Padding="14,10">
                    <StackPanel Orientation="Horizontal">
                      <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M3,6 H21 M19,6 L18,20 A2,2 0 0 1 16,22 H8 A2,2 0 0 1 6,20 L5,6 M9,6 V4 A1,1 0 0 1 10,3 H14 A1,1 0 0 1 15,4 V6"/></Canvas></Viewbox>
                      <TextBlock Text="Space Cleanup" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                  </Border>
                  <Grid Margin="14,12,14,14">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="1"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Auto-Clean - titlu -->
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Auto-Clean" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <!-- Auto-Clean - descriere -->
                    <TextBlock Grid.Column="0" Grid.Row="1" Text="Temp files, cache and system junk"
                               FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10" VerticalAlignment="Top"/>
                    <!-- Auto-Clean - buton -->
                    <Button Grid.Column="0" Grid.Row="2" Style="{StaticResource OutlineButtonStyle}"
                            Padding="10,6" Click="AutoClean_Click" HorizontalAlignment="Left"
                            ToolTip="Safely deletes temporary files, browser cache and system junk">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6M10 11v6M14 11v6"/></Canvas></Viewbox>
                        <TextBlock Text="Auto-Clean…" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                    <!-- Separator vertical -->
                    <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource BorderBrush}" Margin="10,0"/>
                    <!-- Hibernate - titlu -->
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Hibernate" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <!-- Hibernate - descriere -->
                    <StackPanel Grid.Column="2" Grid.Row="1" VerticalAlignment="Top">
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="Status: " FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtHibernateStatus" Text="Checking..."
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                      </StackPanel>
                      <TextBlock x:Name="TxtHibernateInfo" Text="hiberfil.sys ocupies ~GB disk space"
                                 FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </StackPanel>
                    <!-- Hibernate - buton -->
                    <Button Grid.Column="2" Grid.Row="2" x:Name="BtnToggleHibernate" Style="{StaticResource OutlineButtonStyle}"
                            Padding="10,6" HorizontalAlignment="Left"
                            Click="ToggleHibernate_Click"
                            ToolTip="Enable/disable hibernate. When disabled, frees disk space equal to your RAM size (hiberfil.sys is deleted).">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0">
                          <Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M21,12.79 A9,9 0 0 1 11.21,3 A7,7 0 1 0 21,12.79 Z"/></Canvas>
                        </Viewbox>
                        <TextBlock Text="Hibernate: ?" x:Name="_HibBtnLbl" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- Card 2: Performance Optimize -->
              <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <StackPanel>
                  <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="12,12,0,0" Padding="14,10">
                    <StackPanel Orientation="Horizontal">
                      <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M22,12 H18 M6,12 H2 M12,2 V6 M12,22 V18 M12,8 A4,4 0 1 1 12,16 A4,4 0 1 1 12,8 Z"/></Canvas></Viewbox>
                      <TextBlock Text="Performance" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                  </Border>
                  <StackPanel Margin="14,12,14,14">
                    <TextBlock Text="Optimize" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Disable telemetry, visual effects and background services that slow down your PC"
                               FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <TextBlock Text="12 tweaks available — each individually selectable and reversible."
                               FontSize="9.5" Foreground="{DynamicResource TextSecondaryBrush}"
                               Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Button x:Name="BtnOptimizePerf"
                            Style="{StaticResource OutlineButtonStyle}"
                            Click="OptimizePerformance_Click" Padding="10,6" HorizontalAlignment="Left"
                            ToolTip="Opens optimization dialog — choose which tweaks to apply">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0">
                          <Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,12 H18 M6,12 H2 M12,2 V6 M12,22 V18 M12,8 A4,4 0 1 1 12,16 A4,4 0 1 1 12,8 Z"/></Canvas>
                        </Viewbox>
                        <TextBlock Text="Optimize Performance…" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>

            <!-- ══ PowerShell Quick Actions (full width — USB History removed) ══ -->
            <Grid Margin="0,0,0,16">
              <!-- Stub controls to satisfy code-behind references -->
              <StackPanel x:Name="UsbDeviceList" Visibility="Collapsed"/>
              <Button x:Name="BtnUsbScan" Visibility="Collapsed" Click="UsbScan_Click"/>
              <Button x:Name="BtnUsbExportCsv" Visibility="Collapsed" Click="UsbExportCsv_Click"/>
              <TextBlock x:Name="TxtUsbEmpty" Visibility="Collapsed"/>

              <!-- PowerShell Quick Actions (compact) -->
              <Border Style="{StaticResource CardStyle}" Padding="0">
                <StackPanel>
                  <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="12,12,0,0" Padding="14,10">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal">
                        <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M12,19 L20,19 M4,17 L10,11 L4,5"/></Canvas></Viewbox>
                        <TextBlock Text="PowerShell Quick Actions" FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                      </StackPanel>
                      <Button x:Name="BtnPsToggleEditor" Grid.Column="1"
                              Style="{StaticResource OutlineButtonStyle}" 
                              Click="PsToggleEditor_Click" Padding="8,4" Height="26">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M11,4 H4 A2,2 0 0 0 2,6 V20 A2,2 0 0 0 4,22 H18 A2,2 0 0 0 20,20 V13 M18.5,2.5 A2.121,2.121 0 1 1 21.5,5.5 L12,15 L8,16 L9,12 Z"/></Canvas></Viewbox><TextBlock Text="Edit" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    </Grid>
                  </Border>
                  <StackPanel Margin="14,12,14,14">
                    <!-- Hidden DataGrid for code compatibility -->
                    <DataGrid x:Name="PsCommandsGrid" Visibility="Collapsed" Height="0"
                              AutoGenerateColumns="False" IsHitTestVisible="False"
                              SelectionChanged="PsCommandsGrid_SelectionChanged"/>
                    <StackPanel Orientation="Horizontal">
                      <Viewbox Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M8,13 L16,13 M8,17 L16,17 M10,9 L16,9 M14,2 L14,8 L20,8"/></Canvas></Viewbox>
                      <TextBlock x:Name="TxtPsCommandsLabel" Text="Saved commands"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    </StackPanel>
                    <!-- Quick-action tiles (rebuilt in code via RebuildQuickButtons) -->
                    <WrapPanel x:Name="PsQuickButtonsPanel" Margin="0,0,0,4"/>
                    <!-- Inline editor (hidden by default) -->
                    <Grid x:Name="PsEditorPanel" Visibility="Collapsed" Margin="0,8,0,0">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      <TextBox x:Name="TxtPsCmdName" Grid.Row="0" Height="28" Padding="6,4"
                               FontSize="12" Margin="0,0,0,6" VerticalContentAlignment="Center"
                               ToolTip="Command name (shown on tile)"/>
                      <TextBox x:Name="TxtPsCommand" Grid.Row="1" Height="60" Padding="6,5"
                               FontSize="11" AcceptsReturn="True" TextWrapping="Wrap"
                               FontFamily="Consolas" Margin="0,0,0,6"
                               Text="# Write PowerShell command here&#x0a;"/>
                      <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Style="{StaticResource AppButtonStyle}"
                                Click="PsSave_Click" Padding="10,5" Height="28" Margin="0,0,8,0">
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2zM7 3v5h8M12 18a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></Canvas></Viewbox>
                            <TextBlock Text="Save" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Button>
                        <Button x:Name="BtnPsRun"
                                Style="{StaticResource OutlineButtonStyle}"
                                Click="PsRun_Click" Padding="10,5" Height="28" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M5,3 L19,12 L5,21 Z"/></Canvas></Viewbox><TextBlock Text="Run" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                        <Button Style="{StaticResource OutlineButtonStyle}"
                                Click="PsDelete_Click" Padding="10,5" Height="28">
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6M10 11v6M14 11v6"/></Canvas></Viewbox>
                            <TextBlock Text="Delete" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Button>
                      </StackPanel>
                    </Grid>
                    <!-- Compact status bar -->
                    <Border x:Name="PsOutputBar" Visibility="Collapsed" Margin="0,6,0,0"
                            Background="{DynamicResource BgInputBrush}" CornerRadius="6" Padding="8,5">
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtPsStatus" FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="" Width="20" Height="20" FontSize="9"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Click="PsStatusClose_Click"/>
                      </Grid>
                    </Border>
                    <!-- Full output panel -->
                    <Border x:Name="PsFullOutputPanel" Visibility="Collapsed" Margin="0,4,0,0"
                            Background="{DynamicResource BgInputBrush}" CornerRadius="6" Padding="8,6">
                      <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                          <TextBlock Text="Output" FontSize="10" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="" Width="22" Height="22" FontSize="10"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Click="PsClear_Click" ToolTip="Clear output"/>
                            <Button Content="" Width="22" Height="22" FontSize="9"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Click="PsOutputClose_Click"/>
                          </StackPanel>
                        </Grid>
                        <TextBlock x:Name="TxtPsOutput" Grid.Row="1" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}"/>
                      </Grid>
                    </Border>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>

            <!-- ══ PowerShell Quick Actions end ══ -->

          </StackPanel>
        </ScrollViewer>

        <!-- ── BATTERY ── -->
        <ScrollViewer x:Name="PanelBattery" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="24">
            <!-- Title row with Power Options button -->
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="TxtBatteryTitle" Text="Battery Monitor"
                         Style="{StaticResource SectionTitleStyle}" Margin="0" VerticalAlignment="Center"/>
              <!-- Action buttons in title bar -->
              <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnBatteryMonStart"
                        Style="{StaticResource OutlineButtonStyle}"
                        ToolTip="Reads battery %, voltage and charge power every 5 seconds."
                        Click="StartBatteryMonitor_Click" Margin="0,0,6,0" Height="30" Padding="10,4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M22,3 H2 A1,1 0 0 0 1,4 V16 A1,1 0 0 0 2,17 H22 A1,1 0 0 0 23,16 V4 A1,1 0 0 0 22,3 Z M8,21 H16 M12,17 V21"/></Canvas></Viewbox><TextBlock Text="Live Monitor" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                <Button x:Name="BtnBatteryMonStop"
                        Style="{StaticResource OutlineButtonStyle}"
                        Click="StopBatteryMonitor_Click" Margin="0,0,6,0" Height="30" Padding="10,4" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M4,4 H20 V20 H4 Z"/></Canvas></Viewbox><TextBlock Text="Stop" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                <Button x:Name="BtnBatteryTest"
                        Style="{StaticResource OutlineButtonStyle}" Height="30" Padding="10,4"
                        Click="BatteryTest_Click" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M23,10 H21 V14 H23 Z M1,8 H19 A1,1 0 0 1 20,9 V15 A1,1 0 0 1 19,16 H1 A1,1 0 0 1 0,15 V9 A1,1 0 0 1 1,8 Z"/></Canvas></Viewbox><TextBlock Text="Battery Test" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                <Button x:Name="BtnFullBatteryReport"
                        Style="{StaticResource OutlineButtonStyle}" Padding="10,4"
                        ToolTip="Generates a detailed battery report via powercfg — charge history, capacity, estimated life."
                        Click="GenerateBatteryReport_Click" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"><Canvas Width="24" Height="24"><Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M14,2 H6 A2,2 0 0 0 4,4 V20 A2,2 0 0 0 6,22 H18 A2,2 0 0 0 20,20 V8 Z M14,2 V8 H20 M16,13 H8 M16,17 H8 M10,9 H8"/></Canvas></Viewbox><TextBlock Text="Full Report" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                <Button x:Name="BtnOpenOptimizer" VerticalAlignment="Center"
                        Style="{StaticResource OutlineButtonStyle}" Height="30" Padding="10,4"
                        Click="OpenOptimizer_Click"
                        ToolTip="Opens Windows Power Options control panel — change power plan">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center">
                      <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.75"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Power Options" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </WrapPanel>
            </Grid>
            <!-- Battery device name — populated from WMI -->
            <TextBlock x:Name="TxtBatDeviceName" Text="" FontSize="12" FontStyle="Italic"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Style="{StaticResource CardStyle}" Grid.Column="0" Margin="0,0,4,0">
                <StackPanel>
                  <TextBlock x:Name="TxtChargeLabel" Text="Charge Level" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                  <TextBlock Text="Charge:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                  <TextBlock x:Name="TxtBatCharge" Text="—%" FontSize="28" FontWeight="Bold"
                             Foreground="{StaticResource GreenBrush}" Margin="0,2,0,6"/>
                  <Border Background="{DynamicResource BgInputBrush}" CornerRadius="4" Height="10" Margin="0,0,0,4">
                    <Border x:Name="BatChargeBar" Background="{StaticResource GreenBrush}"
                            CornerRadius="4" Height="10" HorizontalAlignment="Left" Width="0"/>
                  </Border>
                  <TextBlock x:Name="TxtBatStatus" Text="—" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0"/>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}" Grid.Column="1" Margin="4,0">
                <StackPanel>
                  <TextBlock x:Name="TxtChargerLabel" Text="Charger / Power" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtPowerLabel" Text="Current power:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtBatPower" Text="—" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" Grid.Column="1"/>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtVoltageLabel" Text="Tensiune:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtBatVoltage" Text="—" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Grid.Column="1"/>
                  </Grid>
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtRuntimeLabel" Text="Estimated runtime:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtBatRuntime" Text="—" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource GreenBrush}" Grid.Column="1"/>
                  </Grid>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}" Grid.Column="2" Margin="4,0,0,0">
                <StackPanel>
                  <TextBlock x:Name="TxtBatteryHealthLabel" Text="Battery Health" FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                  <TextBlock x:Name="TxtWearLabel" Text="Health:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                  <TextBlock x:Name="TxtBatWear" Text="—%" FontSize="28" FontWeight="Bold"
                             Foreground="{StaticResource GreenBrush}" Margin="0,2,0,6"/>
                  <Border Background="{DynamicResource BgInputBrush}" CornerRadius="4" Height="10" Margin="0,0,0,4">
                    <Border x:Name="BatWearBar" Background="{StaticResource GreenBrush}"
                            CornerRadius="4" Height="10" HorizontalAlignment="Left" Width="0"/>
                  </Border>
                  <TextBlock x:Name="TxtBatCycles" Text="Cicluri: —" FontSize="12"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                  <TextBlock x:Name="TxtBatCapacity" Text="—" FontSize="11"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                  <TextBlock x:Name="TxtBatLifeEst" Text="" FontSize="11" FontStyle="Italic"
                             Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
              </Border>
            </Grid>
            <!-- Battery action buttons moved to title bar above -->
            <!-- ── App Power Drain Card ── -->
            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
              <StackPanel>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="App Power Usage" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="TxtAppDrainStatus" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Loading..."
                               Margin="0,2,0,0"/>
                  </StackPanel>
                  <!-- Refresh button removed: auto-refreshes every 10s -->
                </Grid>
                <DataGrid x:Name="LstAppDrain" AutoGenerateColumns="False" IsReadOnly="True"
                          MaxHeight="440" BorderThickness="0" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource RowAltBrush}"
                          RowHeight="32" ColumnHeaderHeight="30" FontSize="11"
                          HeadersVisibility="Column"
                          MouseDoubleClick="AppDrainGrid_DoubleClick"
                          CanUserReorderColumns="False" CanUserResizeColumns="False" CanUserSortColumns="False"
                          SelectionMode="Single" SelectionUnit="FullRow">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Application" Binding="{Binding Name}" Width="*"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>
                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="110"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>
                    <DataGridTemplateColumn Header="CPU Usage" Width="*">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Grid VerticalAlignment="Center" Margin="4,0">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="44"/>
                              <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Usage}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding BarColor}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Height="7" CornerRadius="4" Margin="4,0,6,0"
                                    Background="{DynamicResource BgInputBrush}" VerticalAlignment="Center"
                                    ClipToBounds="True">
                              <Rectangle Height="7" HorizontalAlignment="Left"
                                         Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                                         Fill="{Binding BarColor}">
                                <Rectangle.RenderTransform>
                                  <ScaleTransform ScaleX="{Binding BarRatio}" ScaleY="1" CenterX="0" CenterY="0"/>
                                </Rectangle.RenderTransform>
                              </Rectangle>
                            </Border>
                          </Grid>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Level" Width="70">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Border CornerRadius="6" Padding="6,2" Margin="4,4" HorizontalAlignment="Center"
                                  Background="{Binding LevelBg}">
                            <TextBlock Text="{Binding UsageLevel}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding BarColor}" HorizontalAlignment="Center"/>
                          </Border>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                  <DataGrid.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="View process details" Click="AppDrainDetails_Click"/>
                      <MenuItem Header="Open Task Manager" Click="AppDrainAnalyze_Click"/>
                      <Separator/>
                      <MenuItem Header="Kill process" Click="AppDrainKill_Click"/>
                    </ContextMenu>
                  </DataGrid.ContextMenu>
                </DataGrid>
              </StackPanel>
            </Border>
            <!-- Battery Report button moved to button row above -->
            <!-- &#x2139; Battery info (laptop only note) — at end of section -->
            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0" Padding="12,8">
              <TextBlock x:Name="TxtBatteryInfo" FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                ℹ Battery data is only available on laptops. Charge power and voltage require complete ACPI drivers.
                Generate a full battery report with: powercfg /batteryreport
              </TextBlock>
            </Border>

            <!-- Power Options moved to title bar -->

          </StackPanel>
        </ScrollViewer>

        <!-- ── POWERSHELL RUNNER — moved into Tools panel above ── -->
        <Grid x:Name="PanelPowerShell" Visibility="Collapsed" Margin="24">
        </Grid>

        <!-- ── TOAST NOTIFICATION (replaces loading overlay) ── -->
        <Border x:Name="ToastBorder" Visibility="Collapsed"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,18" Panel.ZIndex="20"
                CornerRadius="20" Padding="14,8,14,8"
                Background="{DynamicResource ToastBgBrush}"
                BorderBrush="{DynamicResource ToastBorderBrush}" BorderThickness="1">
          <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="#000000"/>
          </Border.Effect>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="TxtToastIcon" Text="" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,7,0"/>
            <TextBlock x:Name="TxtLoadingMsg" Text="Loading..."
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- ── RESTRICTED MODE INDICATOR (no admin rights) ── -->
        <Border x:Name="RestrictedModeBanner" Visibility="Collapsed"
                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                Panel.ZIndex="20"
                CornerRadius="0" Padding="12,7"
                Background="{DynamicResource WarningBannerBgBrush}"
                BorderThickness="0">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="" FontSize="12" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
              <TextBlock Text="Running as User — some features require Administrator. Right-click SMDWin → Run as administrator."
                         FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1" Content="" Style="{StaticResource CloseIconButtonStyle}"
                    Foreground="White" Click="DismissRestrictedBanner_Click"/>
          </Grid>
        </Border>

      </Grid>      <!-- /MainContentBorder -->
    </Grid>      <!-- /content columns Grid = root Grid -->
  </Grid>        <!-- /root Grid (Row 0+1) -->
</Window>