<Window x:Class="SMDWin.Views.PinnedProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Widget"
        Width="280"
        SizeToContent="Height"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

  <!-- Outer transparent padding for drop shadow -->
  <Border Padding="12" Background="Transparent">
    <Border.Effect>
      <DropShadowEffect BlurRadius="20" ShadowDepth="8" Color="#000000" Opacity="0.55"/>
    </Border.Effect>

    <!-- Card — identical to WidgetWindow shell -->
    <Border x:Name="CardBorder" CornerRadius="14" ClipToBounds="True"
            BorderThickness="1">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#0E121C" Offset="0"/>
          <GradientStop Color="#0A0D14" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
      <Border.BorderBrush>
        <SolidColorBrush Color="#376499" Opacity="0.22"/>
      </Border.BorderBrush>

      <StackPanel>
        <!-- Header -->
        <Grid Margin="14,8,14,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Title -->
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="📌" FontSize="10" Margin="0,0,5,0" VerticalAlignment="Center"
                       Foreground="#FF60A5FA"/>
            <TextBlock x:Name="TxtProcessName" Text="—"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#CCFFFFFF" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" MaxWidth="150"/>
            <TextBlock x:Name="TxtPid" Text="" FontSize="8.5" Margin="6,0,0,0"
                       Foreground="#55FFFFFF" VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Buttons -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSelectProcess" ToolTip="Change process"
                    Click="BtnSelectProcess_Click" Width="20" Height="20"
                    Margin="0,0,3,0" FontSize="11" Content="⊕">
              <Button.Style>
                <Style TargetType="Button">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="Foreground" Value="#55FFFFFF"/>
                  <Setter Property="BorderThickness" Value="0"/>
                  <Setter Property="Cursor" Value="Hand"/>
                  <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#23FFFFFF"/>
                            <Setter Property="Foreground" Value="#CCFFFFFF"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </Button.Style>
            </Button>
            <Button Content="✕" Click="BtnClose_Click" Width="20" Height="20">
              <Button.Style>
                <Style TargetType="Button">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="Foreground" Value="#55FFFFFF"/>
                  <Setter Property="BorderThickness" Value="0"/>
                  <Setter Property="Cursor" Value="Hand"/>
                  <Setter Property="FontSize" Value="11"/>
                  <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#37EF4444"/>
                            <Setter Property="Foreground" Value="#FFEF4444"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </Button.Style>
            </Button>
          </StackPanel>
        </Grid>

        <!-- Section label -->
        <TextBlock Text="PROCESS MONITOR" FontSize="8" FontWeight="SemiBold"
                   Foreground="#37FFFFFF" Margin="14,0,14,6"/>

        <!-- 2×2 chart grid -->
        <Grid Margin="14,0,14,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="72"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- CPU -->
          <Border Grid.Row="0" Grid.Column="0" CornerRadius="6"
                  Background="#12FFFFFF" Padding="8,5">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid>
                <TextBlock Text="CPU" FontSize="9" FontWeight="SemiBold" Foreground="#8060A5FA"/>
                <TextBlock x:Name="TxtCpuVal" Text="—" FontSize="13" FontWeight="Bold"
                           Foreground="#FF60A5FA" HorizontalAlignment="Right"/>
              </Grid>
              <Canvas x:Name="CpuChart" Grid.Row="1" ClipToBounds="True"/>
            </Grid>
          </Border>

          <!-- RAM -->
          <Border Grid.Row="0" Grid.Column="2" CornerRadius="6"
                  Background="#1234D399" Padding="8,5">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid>
                <TextBlock Text="RAM" FontSize="9" FontWeight="SemiBold" Foreground="#8034D399"/>
                <TextBlock x:Name="TxtRamVal" Text="—" FontSize="13" FontWeight="Bold"
                           Foreground="#FF34D399" HorizontalAlignment="Right"/>
              </Grid>
              <Canvas x:Name="RamChart" Grid.Row="1" ClipToBounds="True"/>
            </Grid>
          </Border>

          <!-- Disk -->
          <Border Grid.Row="2" Grid.Column="0" CornerRadius="6"
                  Background="#12FBBF24" Padding="8,5">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid>
                <TextBlock Text="Disk" FontSize="9" FontWeight="SemiBold" Foreground="#80FBBF24"/>
                <TextBlock x:Name="TxtDiskVal" Text="—" FontSize="13" FontWeight="Bold"
                           Foreground="#FFFBBF24" HorizontalAlignment="Right"/>
              </Grid>
              <Canvas x:Name="DiskChart" Grid.Row="1" ClipToBounds="True"/>
            </Grid>
          </Border>

          <!-- Network -->
          <Border Grid.Row="2" Grid.Column="2" CornerRadius="6"
                  Background="#12A78BFA" Padding="8,5">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid>
                <TextBlock Text="Net" FontSize="9" FontWeight="SemiBold" Foreground="#80A78BFA"/>
                <TextBlock x:Name="TxtNetVal" Text="—" FontSize="13" FontWeight="Bold"
                           Foreground="#FFA78BFA" HorizontalAlignment="Right"/>
              </Grid>
              <Canvas x:Name="NetChart" Grid.Row="1" ClipToBounds="True"/>
            </Grid>
          </Border>
        </Grid>

        <!-- Status bar -->
        <Grid Margin="14,6,14,10">
          <TextBlock x:Name="TxtStatus" Text="Starting…" FontSize="8.5"
                     Foreground="#55FFFFFF" VerticalAlignment="Center"/>
          <TextBlock x:Name="TxtInterval" Text="1s" FontSize="8.5"
                     Foreground="#37FFFFFF"
                     HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
      </StackPanel>
    </Border>
  </Border>
</Window>
