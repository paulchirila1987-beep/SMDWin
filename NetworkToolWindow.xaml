<Window x:Class="SMDWin.NetworkToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Network Tools — SMDWin"
        Height="600" Width="920"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDarkBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                        GlassFrameThickness="-1,-1,-1,-1"
                        UseAeroCaptionButtons="True"/>
  </shell:WindowChrome.WindowChrome>
  <Window.Resources>
    <!-- Modern pill tab button style -->
    <Style x:Key="NetTabStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Margin" Value="0,0,2,0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" CornerRadius="6"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Primary action button (green) — theme aware -->
    <Style x:Key="BtnPrimaryStyle" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                    Padding="{TemplateBinding Padding}" Opacity="1">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Stop / secondary button — theme aware -->
    <Style x:Key="BtnSecondaryStyle" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Accent header bar -->
    <Border Grid.Row="0" x:Name="NetAccentHeader"
            Background="{DynamicResource SidebarBrush}"
            Padding="20,10" BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource BorderBrush2}">
      <TextBlock Text="🌐  Network Tools" FontSize="13" FontWeight="SemiBold"
                 Foreground="{DynamicResource SidebarTextPrimaryBrush}"/>
    </Border>

    <!-- Tool selector tabs -->
    <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" Padding="12,8,12,0"
            BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="0,0,0,1">
      <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
        <!-- Monitoring group -->
        <Button x:Name="TabPingMon"  Content="📡 Ping Monitor"    Tag="ping_monitor" Click="Tab_Click"
                Style="{StaticResource NetTabStyle}" Margin="0,0,4,0"/>
        <Button x:Name="TabTraffic"  Content="📈 Traffic"          Tag="traffic"      Click="Tab_Click"
                Style="{StaticResource NetTabStyle}" Margin="0,0,4,0"/>
        <Button x:Name="TabLanScan"  Content="🖥 LAN Devices"      Tag="lan_scan"     Click="Tab_Click"
                Style="{StaticResource NetTabStyle}" Margin="0,0,4,0"/>
        <!-- Separator -->
        <Border Width="1" Background="{DynamicResource BorderBrush2}" Margin="4,4,8,4" VerticalAlignment="Stretch"/>
        <!-- Tools group -->
        <Button x:Name="TabPortScan" Content="🔍 Port Scan"        Tag="port_scan"    Click="Tab_Click"
                Style="{StaticResource NetTabStyle}" Margin="0,0,4,0"/>
        <Button x:Name="TabLanSpeed" Content="⚡ Speed Test"       Tag="lan_speed"    Click="Tab_Click"
                Style="{StaticResource NetTabStyle}" Margin="0,0,4,0"/>
        <Button x:Name="TabDns"      Content="🌍 DNS"              Tag="dns"          Click="Tab_Click"
                Style="{StaticResource NetTabStyle}"/>
      </WrapPanel>
    </Border>

    <!-- Content area -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <Grid Margin="20">

        <!-- ── PING MONITOR ── -->
        <Grid x:Name="PanePingMonitor" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="📡 Continuous Ping Monitor" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
          <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/><ColumnDefinition Width="140"/>
              <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Host:" Grid.Column="0" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtPingHost" Grid.Column="1" Text="8.8.8.8" Padding="6,4"/>
            <TextBlock x:Name="TxtPingLive" Text="—  ms" Grid.Column="2"
                       FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ChartGreenBrush}"
                       VerticalAlignment="Center" Margin="16,0"/>
            <TextBlock x:Name="TxtPingLoss" Text="" Grid.Column="3"
                       FontSize="12" Foreground="{DynamicResource AccentBrush}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="4" Orientation="Horizontal">
              <Button x:Name="BtnPingStart" Content="▶ Start" Click="PingStart_Click"
                      Style="{StaticResource BtnPrimaryStyle}" Margin="0,0,6,0"/>
              <Button x:Name="BtnPingStop" Content="■ Stop" Click="PingStop_Click" IsEnabled="False"
                      Style="{StaticResource BtnSecondaryStyle}"/>
            </StackPanel>
          </Grid>
          <Border Grid.Row="2" Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="14,10" MinHeight="300">
            <Canvas x:Name="PingChart" ClipToBounds="True" MinHeight="280"
                    SizeChanged="PingChart_SizeChanged"/>
          </Border>
        </Grid>

        <!-- ── TRAFFIC MONITOR ── -->
        <Grid x:Name="PaneTraffic" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="📈 Live Network Traffic" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnTrafficStart" Content="▶ Start" Click="TrafficStart_Click"
                    Style="{StaticResource BtnPrimaryStyle}" Margin="0,0,8,0"/>
            <Button x:Name="BtnTrafficStop" Content="■ Stop" Click="TrafficStop_Click"
                    Style="{StaticResource BtnSecondaryStyle}"/>
          </StackPanel>
          <DataGrid Grid.Row="2" x:Name="TrafficGrid" AutoGenerateColumns="False" IsReadOnly="True"
                    Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                    RowBackground="{DynamicResource BgCardBrush}" AlternatingRowBackground="{DynamicResource RowAltBrush}"
                    GridLinesVisibility="None" RowHeight="36" ColumnHeaderHeight="38">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Adaptor"      Binding="{Binding Name}"        Width="*"/>
              <DataGridTextColumn Header="↑ Trimis"     Binding="{Binding SendDisplay}" Width="110"/>
              <DataGridTextColumn Header="↓ Primit"     Binding="{Binding RecvDisplay}" Width="110"/>
              <DataGridTextColumn Header="Total Trimis" Binding="{Binding TotalSentMB, StringFormat={}{0:F1} MB}" Width="105"/>
              <DataGridTextColumn Header="Total Primit" Binding="{Binding TotalRecvMB, StringFormat={}{0:F1} MB}" Width="105"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>

        <!-- ── PORT SCANNER ── -->
        <Grid x:Name="PanePortScan" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="🔍 TCP Port Scanner" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
          <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Host:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtScanHost" Width="130" Text="127.0.0.1" Padding="6,4" Margin="0,0,12,0"/>
            <TextBlock Text="Port start:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtScanPortStart" Width="60" Text="1" Padding="6,4" Margin="0,0,12,0"/>
            <TextBlock Text="Port stop:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtScanPortStop" Width="60" Text="1024" Padding="6,4" Margin="0,0,12,0"/>
            <Button x:Name="BtnScanRun" Content="▶ Scan" Click="PortScanRun_Click"
                    Style="{StaticResource BtnPrimaryStyle}" Margin="0,0,8,0"/>
            <Button x:Name="BtnScanStop" Content="■ Stop" Click="PortScanStop_Click"
                    Style="{StaticResource BtnSecondaryStyle}"/>
          </WrapPanel>
          <TextBlock x:Name="TxtScanStatus" Grid.Row="2" Text="Enter host and press Scan…"
                     FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
          <DataGrid Grid.Row="3" x:Name="PortScanGrid" AutoGenerateColumns="False" IsReadOnly="True"
                    Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                    RowBackground="{DynamicResource BgCardBrush}" AlternatingRowBackground="{DynamicResource RowAltBrush}"
                    GridLinesVisibility="None" RowHeight="32" ColumnHeaderHeight="36">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Port"     Binding="{Binding PortDisplay}" Width="65"/>
              <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}"   Width="70"/>
              <DataGridTemplateColumn Header="Status" Width="100">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Serviciu" Binding="{Binding Service}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>

        <!-- ── LAN SCANNER ── -->
        <Grid x:Name="PaneLanScan" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="🖥 LAN Scan" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnLanScanStart" Content="▶ Scan Network" Click="LanScanStart_Click"
                    Style="{StaticResource BtnPrimaryStyle}" Margin="0,0,8,0"/>
            <Button x:Name="BtnLanScanStop" Content="⏹ Stop" Click="LanScanStop_Click" IsEnabled="False"
                    Style="{StaticResource BtnSecondaryStyle}"/>
          </StackPanel>
          <TextBlock x:Name="TxtLanScanStatus" Grid.Row="2"
                     Text="Press Scan Network to discover devices on the local network."
                     FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
          <DataGrid Grid.Row="3" x:Name="LanDevicesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                    Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                    RowBackground="{DynamicResource BgCardBrush}" AlternatingRowBackground="{DynamicResource RowAltBrush}"
                    GridLinesVisibility="None" RowHeight="34" ColumnHeaderHeight="36"
                    MouseDoubleClick="LanDeviceGrid_DoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="IP"        Binding="{Binding IpAddress}"  Width="120"/>
              <DataGridTextColumn Header="Hostname"  Binding="{Binding Hostname}"   Width="*"/>
              <DataGridTextColumn Header="MAC"       Binding="{Binding MacAddress}" Width="135"/>
              <DataGridTextColumn Header="Vendor"    Binding="{Binding Vendor}"     Width="130"/>
              <DataGridTextColumn Header="Ping (ms)" Binding="{Binding PingDisplay}" Width="80"/>
              <DataGridTextColumn Header="Status"    Binding="{Binding Status}"     Width="70"/>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Device detail overlay -->
          <Border Grid.Row="3" x:Name="DeviceDetailPanel" Visibility="Collapsed"
                  Background="{DynamicResource BgCardBrush}" CornerRadius="12"
                  BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                  Padding="20,16" Margin="8" VerticalAlignment="Top" HorizontalAlignment="Left"
                  MinWidth="340" MaxWidth="500"
                  Panel.ZIndex="10">
            <StackPanel>
              <Grid Margin="0,0,0,12">
                <TextBlock x:Name="TxtDeviceDetailTitle" Text="🖥 Device Details"
                           FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Button x:Name="BtnCloseDeviceDetail" Content="✕" HorizontalAlignment="Right"
                        Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="0" FontSize="14" Cursor="Hand"
                        Click="CloseDeviceDetail_Click"/>
              </Grid>
              <ItemsControl x:Name="DeviceDetailItems">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,3">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12"
                                 Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button x:Name="BtnDevicePing" Content="📡 Ping Again" Click="DevicePing_Click"
                        Style="{StaticResource BtnPrimaryStyle}" Margin="0,0,8,0" Padding="10,5"/>
                <Button x:Name="BtnDevicePortScan" Content="🔍 Port Scan" Click="DevicePortScan_Click"
                        Style="{StaticResource BtnSecondaryStyle}" Padding="10,5"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>

        <!-- ── NETWORK SPEED TEST ── -->
        <Grid x:Name="PaneLanSpeed" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="⚡ LAN Speed Test" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
          <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"
                         Text="ℹ How this works — two modes:"/>
              <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"
                         Text="• Gateway ping test: measures round-trip latency to your router (works on any PC).&#x0a;• LAN TCP throughput: measures real transfer speed between THIS PC and a TARGET IP on the local network.&#x0a;  → For accurate LAN tests: run WinDiag on BOTH PCs, set each other's IP as target, or use iperf3.&#x0a;  → The test opens a temporary TCP server on port 15099 — make sure firewall allows it."/>
            </StackPanel>
          </Border>
          <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12" FlowDirection="LeftToRight">
            <TextBlock Text="Target IP:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtLanSpeedGateway" Width="140" Padding="6,4" Margin="0,0,12,0" Text=""
                     ToolTip="Enter the local IP of another PC running SMD Win (e.g. 192.168.1.5). Leave empty and press Self-test for a loopback benchmark on this PC only."/>
            <TextBlock Text="Duration (s):" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtLanSpeedDuration" Width="50" Padding="6,4" Margin="0,0,12,0" Text="5"
                     ToolTip="Duration of each TCP throughput test in seconds (default: 5s)"/>
            <Button x:Name="BtnLanSpeedRun" Content="▶ Run Test" Click="LanSpeedRun_Click"
                    Style="{StaticResource BtnPrimaryStyle}" Margin="0,0,8,0" Padding="14,6"
                    ToolTip="Run LAN speed test to the target IP. The other PC must also have SMD Win open with the TCP server active (click Self-test there first). Opens port 15099."/>
            <Button x:Name="BtnLanSpeedStop" Content="■ Stop" Click="LanSpeedStop_Click"
                    Style="{StaticResource BtnSecondaryStyle}" IsEnabled="False" Padding="14,6"
                    ToolTip="Stop the current LAN speed test"/>
            <Button x:Name="BtnLanSpeedSelf" Content="🖥 Self-test (loopback)" Click="LanSpeedSelf_Click"
                    Style="{StaticResource BtnSecondaryStyle}" Margin="8,0,0,0" Padding="14,6"
                    ToolTip="Two modes: (1) If no Target IP is set — runs a loopback benchmark on THIS PC to measure local network stack speed. (2) If a Target IP is set — starts a TCP server here so the other PC can connect and test. No need to install anything else — just SMD Win on both PCs!"/>
          </StackPanel>
          <StackPanel Grid.Row="3">
            <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="20,16" Margin="0,0,0,12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                  <TextBlock Text="⬇ Download (LAN)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                  <TextBlock x:Name="TxtLanSpeedDown" Text="—" FontSize="32" FontWeight="Bold"
                             Foreground="{DynamicResource ChartGreenBrush}" HorizontalAlignment="Center"/>
                  <TextBlock Text="Mbps" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                  <TextBlock Text="⬆ Upload (LAN)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                  <TextBlock x:Name="TxtLanSpeedUp" Text="—" FontSize="32" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                  <TextBlock Text="Mbps" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                  <TextBlock Text="🏓 Ping to GW" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                  <TextBlock x:Name="TxtLanSpeedPing" Text="—" FontSize="32" FontWeight="Bold"
                             Foreground="{DynamicResource BorderBrush2}" HorizontalAlignment="Center"/>
                  <TextBlock Text="ms" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
              </Grid>
            </Border>
            <TextBlock x:Name="TxtLanSpeedStatus" Text="Enter gateway IP and press Run Test."
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
            <Border Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="12">
              <TextBox x:Name="TxtLanSpeedLog" IsReadOnly="True" TextWrapping="Wrap"
                       Background="Transparent" BorderThickness="0"
                       FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                       MinHeight="160" MaxHeight="260"
                       VerticalScrollBarVisibility="Auto"/>
            </Border>
          </StackPanel>
        </Grid>

        <!-- ── DNS LOOKUP ── -->
        <Grid x:Name="PaneDns" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="🌍 DNS Lookup" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Host / IP:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtDnsHost" Width="200" Text="google.com" Padding="6,4" Margin="0,0,10,0"/>
            <Button Content="Lookup" Click="DnsLookup_Click"
                    Style="{StaticResource BtnPrimaryStyle}" Padding="14,6"/>
          </StackPanel>
          <Border Grid.Row="2" Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="12">
            <TextBox x:Name="TxtDnsResult" IsReadOnly="True" TextWrapping="Wrap"
                     Background="Transparent" BorderThickness="0"
                     FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                     Text="Enter a domain or IP and press Lookup…"
                     VerticalScrollBarVisibility="Auto" MinHeight="300"/>
          </Border>
        </Grid>

      </Grid>
    </ScrollViewer>
  </Grid>

</Window>
